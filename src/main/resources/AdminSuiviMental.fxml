<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.image.ImageView?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="Controllor.SuiviMentaleAdminController"
            prefWidth="1500" prefHeight="920"
            style="-fx-background-color: #F4F8FF;">

    <!-- ═══════════════ SIDEBAR ADMIN ═══════════════ -->
        <left><VBox prefWidth="260" prefHeight="700" style="-fx-background-color: #2C3E50;"><HBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding: 24 18 20 18; -fx-border-color: transparent transparent rgba(255,255,255,0.1) transparent; -fx-border-width: 0 0 1 0;"><StackPane><ImageView fx:id="logoImage" fitWidth="45" fitHeight="45" preserveRatio="true"/></StackPane><VBox spacing="2"><Label text="MentalUp Admin" style="-fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: bold;"/><Label text="Espace d administration" style="-fx-text-fill: rgba(255,255,255,0.65); -fx-font-size: 11px;"/></VBox></HBox><VBox spacing="2" style="-fx-padding: 16 12 0 12;" VBox.vgrow="ALWAYS"><HBox alignment="CENTER_LEFT" spacing="12" fx:id="navAccueil" onMouseClicked="#onNavHomeClicked" onMouseEntered="#onNavHoverEnter" onMouseExited="#onNavHoverExit" style="-fx-background-color: transparent; -fx-background-radius: 8; -fx-padding: 10 14; -fx-cursor: hand;"><Label text="Accueil" style="-fx-text-fill: rgba(255,255,255,0.85); -fx-font-size: 14px; -fx-font-weight: 500;"/></HBox><VBox spacing="0"><HBox alignment="CENTER_LEFT" spacing="12" fx:id="navSuivi" onMouseClicked="#onNavSuiviClicked" onMouseEntered="#onNavHoverEnter" onMouseExited="#onNavHoverExit" style="-fx-background-color: transparent; -fx-background-radius: 8; -fx-padding: 10 14; -fx-cursor: hand;"><Label text="Suivi Mental" style="-fx-text-fill: rgba(255,255,255,0.85); -fx-font-size: 14px; -fx-font-weight: 500;"/><Region HBox.hgrow="ALWAYS"/><Label fx:id="arrowSuivi" text=">" style="-fx-text-fill: rgba(255,255,255,0.5); -fx-font-size: 11px;"/></HBox><VBox fx:id="submenuSuivi" spacing="2" style="-fx-padding: 4 0 6 28;"><HBox alignment="CENTER_LEFT" spacing="10" onMouseClicked="#onNavSuiviStatsClicked" onMouseEntered="#onSubmenuHoverEnter" onMouseExited="#onSubmenuHoverExit" style="-fx-background-radius: 6; -fx-padding: 8 12; -fx-cursor: hand;"><Label text="Liste des suivis" style="-fx-text-fill: rgba(255,255,255,0.7); -fx-font-size: 13px;"/></HBox><HBox alignment="CENTER_LEFT" spacing="10" onMouseClicked="#onNavObjectifsClicked" onMouseEntered="#onSubmenuHoverEnter" onMouseExited="#onSubmenuHoverExit" style="-fx-background-radius: 6; -fx-padding: 8 12; -fx-cursor: hand;"><Label text="Objectifs" style="-fx-text-fill: rgba(255,255,255,0.7); -fx-font-size: 13px;"/></HBox></VBox></VBox><VBox spacing="0"><HBox alignment="CENTER_LEFT" spacing="12" fx:id="navForum" onMouseClicked="#onNavForumClicked" onMouseEntered="#onNavHoverEnter" onMouseExited="#onNavHoverExit" style="-fx-background-color: transparent; -fx-background-radius: 8; -fx-padding: 10 14; -fx-cursor: hand;"><Label text="Forum" style="-fx-text-fill: rgba(255,255,255,0.85); -fx-font-size: 14px; -fx-font-weight: 500;"/><Region HBox.hgrow="ALWAYS"/><Label fx:id="arrowForum" text=">" style="-fx-text-fill: rgba(255,255,255,0.5); -fx-font-size: 11px;"/></HBox><VBox fx:id="submenuForum" spacing="2" style="-fx-padding: 4 0 6 28;"><HBox alignment="CENTER_LEFT" spacing="10" onMouseClicked="#onNavSujetsClicked" onMouseEntered="#onSubmenuHoverEnter" onMouseExited="#onSubmenuHoverExit" style="-fx-background-radius: 6; -fx-padding: 8 12; -fx-cursor: hand;"><Label text="Sujets" style="-fx-text-fill: rgba(255,255,255,0.7); -fx-font-size: 13px;"/></HBox><HBox alignment="CENTER_LEFT" spacing="10" onMouseClicked="#onNavCommentairesClicked" onMouseEntered="#onSubmenuHoverEnter" onMouseExited="#onSubmenuHoverExit" style="-fx-background-radius: 6; -fx-padding: 8 12; -fx-cursor: hand;"><Label text="Commentaires" style="-fx-text-fill: rgba(255,255,255,0.7); -fx-font-size: 13px;"/></HBox></VBox></VBox><HBox alignment="CENTER_LEFT" spacing="12" fx:id="navRdv" onMouseClicked="#onNavRdvClicked" onMouseEntered="#onNavHoverEnter" onMouseExited="#onNavHoverExit" style="-fx-background-color: transparent; -fx-background-radius: 8; -fx-padding: 10 14; -fx-cursor: hand;"><Label text="Rendez-vous" style="-fx-text-fill: rgba(255,255,255,0.85); -fx-font-size: 14px; -fx-font-weight: 500;"/></HBox><HBox alignment="CENTER_LEFT" spacing="12" fx:id="navUtilisateurs" onMouseClicked="#onNavUtilisateursClicked" onMouseEntered="#onNavHoverEnter" onMouseExited="#onNavHoverExit" style="-fx-background-color: transparent; -fx-background-radius: 8; -fx-padding: 10 14; -fx-cursor: hand;"><Label text="Utilisateurs" style="-fx-text-fill: rgba(255,255,255,0.85); -fx-font-size: 14px; -fx-font-weight: 500;"/></HBox><HBox alignment="CENTER_LEFT" spacing="12" fx:id="navDossiers" onMouseClicked="#onNavDossiersClicked" onMouseEntered="#onNavHoverEnter" onMouseExited="#onNavHoverExit" style="-fx-background-color: transparent; -fx-background-radius: 8; -fx-padding: 10 14; -fx-cursor: hand;"><Label text="Dossiers medicaux" style="-fx-text-fill: rgba(255,255,255,0.85); -fx-font-size: 14px; -fx-font-weight: 500;"/></HBox><HBox alignment="CENTER_LEFT" spacing="12" fx:id="navContenus" onMouseClicked="#onNavContenusClicked" onMouseEntered="#onNavHoverEnter" onMouseExited="#onNavHoverExit" style="-fx-background-color: transparent; -fx-background-radius: 8; -fx-padding: 10 14; -fx-cursor: hand;"><Label text="Contenus" style="-fx-text-fill: rgba(255,255,255,0.85); -fx-font-size: 14px; -fx-font-weight: 500;"/></HBox><HBox alignment="CENTER_LEFT" spacing="12" fx:id="navActivites" onMouseClicked="#onNavActivitesClicked" onMouseEntered="#onNavHoverEnter" onMouseExited="#onNavHoverExit" style="-fx-background-color: transparent; -fx-background-radius: 8; -fx-padding: 10 14; -fx-cursor: hand;"><Label text="Activites" style="-fx-text-fill: rgba(255,255,255,0.85); -fx-font-size: 14px; -fx-font-weight: 500;"/></HBox><HBox alignment="CENTER_LEFT" spacing="12" fx:id="navReservations" onMouseClicked="#onNavReservationsClicked" onMouseEntered="#onNavHoverEnter" onMouseExited="#onNavHoverExit" style="-fx-background-color: transparent; -fx-background-radius: 8; -fx-padding: 10 14; -fx-cursor: hand;"><Label text="Reservations" style="-fx-text-fill: rgba(255,255,255,0.85); -fx-font-size: 14px; -fx-font-weight: 500;"/></HBox></VBox><VBox spacing="6" style="-fx-padding: 16 14 20 14; -fx-border-color: rgba(255,255,255,0.08); -fx-border-width: 1 0 0 0;"><HBox alignment="CENTER_LEFT" spacing="10"><Label fx:id="avatarInitials" text="AD" style="-fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold;"/><VBox spacing="1"><Label fx:id="labelUserName" text="Admin" style="-fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold;"/><Label text="Super Administrateur" style="-fx-text-fill: rgba(255,255,255,0.55); -fx-font-size: 11px;"/></VBox><Region HBox.hgrow="ALWAYS"/><Button text="Quitter" onAction="#onLogout" style="-fx-background-color: rgba(255,255,255,0.1); -fx-text-fill: white; -fx-background-radius: 6; -fx-padding: 5 10; -fx-cursor: hand; -fx-font-size: 11px;"/></HBox></VBox></VBox></left>

    <!-- ═══════════════ CONTENU PRINCIPAL ═══════════════ -->
    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER"
                    style="-fx-background-color: transparent; -fx-background: transparent;">
            <content>
                <VBox spacing="20" style="-fx-padding: 24; -fx-background-color: #F4F8FF;">
                    <!-- Titre principal -->
                    <VBox spacing="8"
                          style="-fx-background-color: white; -fx-background-radius: 18; -fx-padding: 18;
                                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 8, 0, 0, 2);">
                        <Label text="Suivis mentaux par utilisateur"
                               style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #223A5E;"/>
                        <Label text="Affichage de tous les suivis mentaux"
                               style="-fx-font-size: 13px; -fx-text-fill: #6B7280;"/>
                    </VBox>

                    <!-- Statistiques globales -->
                    <VBox spacing="14"
                          style="-fx-background-color: white; -fx-background-radius: 18; -fx-padding: 18;
                                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 8, 0, 0, 2);">
                        <Label text="Statistiques globales"
                               style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #223A5E;"/>
                        <FlowPane hgap="14" vgap="14" prefWrapLength="900">
                            <VBox style="-fx-background-color: linear-gradient(to right, #8E9AAF, #7D8CA3);
                                         -fx-background-radius: 16; -fx-padding: 16;" prefWidth="200">
                                <Label text="Total suivis" style="-fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold;"/>
                                <Label fx:id="lblTotalSuivis" text="0" style="-fx-text-fill: white; -fx-font-size: 28px; -fx-font-weight: bold;"/>
                            </VBox>
                            <VBox style="-fx-background-color: white; -fx-border-color: #DCE3EA; -fx-border-radius: 16; -fx-background-radius: 16; -fx-padding: 16;" prefWidth="200">
                                <Label text="Score mental moyen" style="-fx-text-fill: #6B7280; -fx-font-size: 13px; -fx-font-weight: bold;"/>
                                <Label fx:id="lblScoreMoyen" text="0" style="-fx-text-fill: #50627A; -fx-font-size: 26px; -fx-font-weight: bold;"/>
                            </VBox>
                            <VBox style="-fx-background-color: white; -fx-border-color: #DCE3EA; -fx-border-radius: 16; -fx-background-radius: 16; -fx-padding: 16;" prefWidth="200">
                                <Label text="Stress moyen" style="-fx-text-fill: #6B7280; -fx-font-size: 13px; -fx-font-weight: bold;"/>
                                <Label fx:id="lblStressMoyen" text="0" style="-fx-text-fill: #50627A; -fx-font-size: 26px; -fx-font-weight: bold;"/>
                            </VBox>
                            <VBox style="-fx-background-color: white; -fx-border-color: #DCE3EA; -fx-border-radius: 16; -fx-background-radius: 16; -fx-padding: 16;" prefWidth="200">
                                <Label text="Énergie moyenne" style="-fx-text-fill: #6B7280; -fx-font-size: 13px; -fx-font-weight: bold;"/>
                                <Label fx:id="lblEnergieMoyenne" text="0" style="-fx-text-fill: #50627A; -fx-font-size: 26px; -fx-font-weight: bold;"/>
                            </VBox>
                        </FlowPane>
                    </VBox>

                    <!-- Statistiques par utilisateur -->
                    <VBox spacing="14"
                          style="-fx-background-color: white; -fx-background-radius: 18; -fx-padding: 18;
                                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 8, 0, 0, 2);">
                        <Label text="Statistiques par utilisateur"
                               style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #223A5E;"/>
                        <FlowPane fx:id="containerStatsUsers" hgap="14" vgap="14" prefWrapLength="900"/>
                    </VBox>

                    <!-- Charts -->
                    <VBox spacing="14"
                          style="-fx-background-color: white; -fx-background-radius: 18; -fx-padding: 18;
                                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 8, 0, 0, 2);">
                        <Label text="Visualisation des statistiques"
                               style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #223A5E;"/>
                        <HBox spacing="16">
                            <VBox HBox.hgrow="ALWAYS" style="-fx-background-color: #F7F9FB; -fx-background-radius: 16; -fx-padding: 14;">
                                <Label text="Évolution du score mental" style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #3F5368;"/>
                                <LineChart fx:id="lineChartScoreMental" prefHeight="220" createSymbols="true" animated="false" legendVisible="false">
                                    <xAxis><CategoryAxis fx:id="xAxisScoreMental" label="Dates"/></xAxis>
                                    <yAxis><NumberAxis fx:id="yAxisScoreMental" label="Score mental"/></yAxis>
                                </LineChart>
                            </VBox>
                            <VBox HBox.hgrow="ALWAYS" style="-fx-background-color: #F7F9FB; -fx-background-radius: 16; -fx-padding: 14;">
                                <Label text="Répartition des humeurs" style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #3F5368;"/>
                                <PieChart fx:id="pieChartHumeurs" prefHeight="220" legendVisible="false" labelsVisible="true"/>
                            </VBox>
                        </HBox>
                    </VBox>

                    <!-- Recherche -->
                    <VBox spacing="14"
                          style="-fx-background-color: white; -fx-background-radius: 18; -fx-padding: 18;
                                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 8, 0, 0, 2);">
                        <Label text="Recherche et filtres"
                               style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #223A5E;"/>
                        <HBox spacing="12">
                            <TextField fx:id="txtRechercheUserId" promptText="User ID" HBox.hgrow="ALWAYS" style="-fx-background-radius: 12; -fx-padding: 12;"/>
                            <TextField fx:id="txtRechercheDate" promptText="yyyy-mm-dd" HBox.hgrow="ALWAYS" style="-fx-background-radius: 12; -fx-padding: 12;"/>
                            <TextField fx:id="txtRechercheHumeur" promptText="Humeur" HBox.hgrow="ALWAYS" style="-fx-background-radius: 12; -fx-padding: 12;"/>
                        </HBox>
                        <HBox spacing="10">
                            <Button text="Filtrer" onAction="#rechercherSuivis"
                                    style="-fx-background-color: #2C3E50; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 22; -fx-padding: 10 24; -fx-cursor: hand;"/>
                            <Button text="Réinitialiser" onAction="#reinitialiserRecherche"
                                    style="-fx-background-color: #E8EDF2; -fx-text-fill: #4B5563; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 22; -fx-padding: 10 24; -fx-cursor: hand;"/>
                        </HBox>
                    </VBox>

                    <!-- Liste -->
                    <VBox spacing="14">
                        <Label text="Liste des suivis"
                               style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #223A5E;"/>
                        <VBox fx:id="containerSuivis" spacing="14"/>
                    </VBox>
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>