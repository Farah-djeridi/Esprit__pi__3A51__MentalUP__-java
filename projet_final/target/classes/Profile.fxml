<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="600.0" prefWidth="460.0"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="Controllor.ProfileController"
            style="-fx-background-color: #f0f4f8;">

    <VBox alignment="CENTER" spacing="12"
          AnchorPane.topAnchor="30" AnchorPane.bottomAnchor="30"
          AnchorPane.leftAnchor="50" AnchorPane.rightAnchor="50">

        <Label text="Mon Profil"
               style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
        <Label fx:id="lblRole" text="" style="-fx-text-fill: #7f8c8d; -fx-font-size: 13px;"/>

        <Separator/>
        <Label text="Informations personnelles"
               style="-fx-font-weight: bold; -fx-font-size: 13px; -fx-text-fill: #2c3e50;"/>

        <VBox spacing="4">
            <Label text="Prénom" style="-fx-font-weight: bold; -fx-text-fill: #34495e;"/>
            <TextField fx:id="txtPrenom"
                       style="-fx-pref-height: 35px; -fx-border-color: #bdc3c7; -fx-border-radius: 5; -fx-background-radius: 5;"/>
        </VBox>

        <VBox spacing="4">
            <Label text="Nom" style="-fx-font-weight: bold; -fx-text-fill: #34495e;"/>
            <TextField fx:id="txtNom"
                       style="-fx-pref-height: 35px; -fx-border-color: #bdc3c7; -fx-border-radius: 5; -fx-background-radius: 5;"/>
        </VBox>

        <VBox spacing="4">
            <Label text="Email" style="-fx-font-weight: bold; -fx-text-fill: #34495e;"/>
            <TextField fx:id="txtEmail"
                       style="-fx-pref-height: 35px; -fx-border-color: #bdc3c7; -fx-border-radius: 5; -fx-background-radius: 5;"/>
        </VBox>

        <Separator/>
        <Label text="Changer le mot de passe (optionnel)"
               style="-fx-font-weight: bold; -fx-font-size: 13px; -fx-text-fill: #2c3e50;"/>

        <VBox spacing="4">
            <Label text="Mot de passe actuel" style="-fx-font-weight: bold; -fx-text-fill: #34495e;"/>
            <PasswordField fx:id="txtCurrentPassword" promptText="Laisser vide si pas de changement"
                           style="-fx-pref-height: 35px; -fx-border-color: #bdc3c7; -fx-border-radius: 5; -fx-background-radius: 5;"/>
        </VBox>

        <VBox spacing="4">
            <Label text="Nouveau mot de passe" style="-fx-font-weight: bold; -fx-text-fill: #34495e;"/>
            <PasswordField fx:id="txtNewPassword" promptText="Min. 8 caractères"
                           style="-fx-pref-height: 35px; -fx-border-color: #bdc3c7; -fx-border-radius: 5; -fx-background-radius: 5;"/>
        </VBox>

        <VBox spacing="4">
            <Label text="Confirmer nouveau mot de passe" style="-fx-font-weight: bold; -fx-text-fill: #34495e;"/>
            <PasswordField fx:id="txtConfirmPassword"
                           style="-fx-pref-height: 35px; -fx-border-color: #bdc3c7; -fx-border-radius: 5; -fx-background-radius: 5;"/>
        </VBox>

        <Label fx:id="lblMessage" text="" wrapText="true" style="-fx-font-size: 12px;"/>

        <HBox spacing="10">
            <Button text="Enregistrer" onAction="#handleSave"
                    HBox.hgrow="ALWAYS" maxWidth="Infinity"
                    style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold;
                           -fx-pref-height: 40px; -fx-background-radius: 5; -fx-cursor: hand;"/>
            <Button text="Déconnexion" onAction="#handleLogout"
                    style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold;
                           -fx-pref-height: 40px; -fx-background-radius: 5; -fx-cursor: hand;"/>
        </HBox>
    </VBox>
</AnchorPane>
