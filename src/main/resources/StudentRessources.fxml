<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.text.*?>
<?import javafx.scene.shape.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.image.ImageView?>

<StackPane xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="Controllor.ControllerStudentRessources"
           prefWidth="1024" prefHeight="650"
           stylesheets="@css/ressources.css">

    <BorderPane styleClass="student-bg">

    <!-- SIDEBAR -->
    <left>
        <VBox prefWidth="240" prefHeight="700"
              style="-fx-background-color: linear-gradient(to bottom, #D6E8F7, #2C5F8A);">

            <!-- Logo -->
            <HBox alignment="CENTER_LEFT" spacing="10"
                  style="-fx-padding: 24 18 20 18;
                         -fx-border-color: transparent transparent rgba(255,255,255,0.12) transparent;
                         -fx-border-width: 0 0 1 0;">
                <StackPane>
                    <ImageView fx:id="logoImage" fitWidth="45" fitHeight="45" preserveRatio="true"/>
                </StackPane>
                <VBox spacing="2">
                    <Label text="MentalUp"
                           style="-fx-text-fill: #1A3A52; -fx-font-size: 16px; -fx-font-weight: bold;"/>
                    <Label text="Bien-être étudiant"
                           style="-fx-text-fill: #2C5F8A; -fx-font-size: 11px; -fx-font-weight: 600;"/>
                </VBox>
            </HBox>

            <!-- Navigation -->
            <VBox spacing="4" style="-fx-padding: 20 14 0 14;" VBox.vgrow="ALWAYS">

                <HBox alignment="CENTER_LEFT" spacing="12" fx:id="navAccueil"
                      onMouseClicked="#onNavHomeClicked"
                      onMouseEntered="#onNavHoverEnter" onMouseExited="#onNavHoverExit"
                      style="-fx-background-color: transparent; -fx-background-radius: 8; -fx-padding: 10 14; -fx-cursor: hand;">
                    <Label text="🏠" style="-fx-font-size: 16px; -fx-text-fill: white;"/>
                    <Label text="Accueil" style="-fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: 500;"/>
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="12" fx:id="navSuivi"
                      onMouseClicked="#onNavSuiviClicked"
                      onMouseEntered="#onNavHoverEnter" onMouseExited="#onNavHoverExit"
                      style="-fx-background-color: transparent; -fx-background-radius: 8; -fx-padding: 10 14; -fx-cursor: hand;">
                    <Label text="📈" style="-fx-font-size: 16px; -fx-text-fill: white;"/>
                    <Label text="Suivi" style="-fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: 500;"/>
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="12" fx:id="navRdv"
                      onMouseClicked="#onNavRdvClicked"
                      onMouseEntered="#onNavHoverEnter" onMouseExited="#onNavHoverExit"
                      style="-fx-background-color: transparent; -fx-background-radius: 8; -fx-padding: 10 14; -fx-cursor: hand;">
                    <Label text="📅" style="-fx-font-size: 16px; -fx-text-fill: white;"/>
                    <Label text="Rendez-vous" style="-fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: 500;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <StackPane style="-fx-background-color: #E74C3C; -fx-background-radius: 10; -fx-padding: 1 6;">
                        <Label fx:id="badgeRdv" text="3" style="-fx-text-fill: white; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                    </StackPane>
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="12" fx:id="navForum"
                      onMouseClicked="#onNavBlogClicked"
                      onMouseEntered="#onNavHoverEnter" onMouseExited="#onNavHoverExit"
                      style="-fx-background-color: transparent; -fx-background-radius: 8; -fx-padding: 10 14; -fx-cursor: hand;">
                    <Label text="💬" style="-fx-font-size: 16px; -fx-text-fill: white;"/>
                    <Label text="Forum" style="-fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: 500;"/>
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="12" fx:id="navActivites"
                      onMouseClicked="#onNavActivitesClicked"
                      onMouseEntered="#onNavHoverEnter" onMouseExited="#onNavHoverExit"
                      style="-fx-background-color: transparent; -fx-background-radius: 8; -fx-padding: 10 14; -fx-cursor: hand;">
                    <Label text="⚡" style="-fx-font-size: 16px; -fx-text-fill: white;"/>
                    <Label text="Activités" style="-fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: 500;"/>
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="12" fx:id="navRessources"
                      style="-fx-background-color: #1E4568; -fx-background-radius: 8;
                             -fx-padding: 10 14; -fx-cursor: hand;
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 5, 0, 0, 2);">
                    <Label text="📚" style="-fx-font-size: 16px; -fx-text-fill: white;"/>
                    <Label text="Ressources" style="-fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                </HBox>

            </VBox>

            <!-- Profil utilisateur -->
            <VBox spacing="6" style="-fx-padding: 16 14 20 14;
                                     -fx-border-color: rgba(255,255,255,0.2);
                                     -fx-border-width: 1 0 0 0;">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <StackPane>
                        <Circle radius="18" style="-fx-fill: rgba(255,255,255,0.25);"/>
                        <Label fx:id="avatarInitials" text=""
                               style="-fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold;"/>
                    </StackPane>
                    <VBox spacing="1">
                        <Label fx:id="labelUserName" text=""
                               style="-fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold;"/>
                        <Label text="Étudiant"
                               style="-fx-text-fill: rgba(255,255,255,0.65); -fx-font-size: 11px;"/>
                    </VBox>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button fx:id="menuButton" text="⋮" onAction="#onMenuClicked"
                            style="-fx-background-color: rgba(255,255,255,0.15);
                                   -fx-text-fill: white;
                                   -fx-background-radius: 50;
                                   -fx-font-size: 18px;
                                   -fx-font-weight: bold;
                                   -fx-padding: 2 10;
                                   -fx-cursor: hand;
                                   -fx-min-width: 32; -fx-min-height: 32;"/>
                </HBox>
            </VBox>

        </VBox>
    </left>

    <!-- CONTENU PRINCIPAL -->
    <center>
        <VBox spacing="0" prefWidth="784" prefHeight="700"
              styleClass="student-bg">

            <!-- Barre supérieure -->
            <HBox alignment="CENTER_LEFT" spacing="12"
                  style="-fx-background-color: rgba(255,255,255,0.95);
                         -fx-padding: 14 24;
                         -fx-border-color: transparent transparent rgba(151,187,228,0.2) transparent;
                         -fx-border-width: 0 0 1 0;">
                <VBox spacing="2">
                    <Label text="Ressources"
                           style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2C3E50;"/>
                    <Label text="Explorez les articles, vidéos et podcasts pour votre bien-être"
                           style="-fx-font-size: 12px; -fx-text-fill: #5A6C7D; -fx-font-weight: 500;"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="notifButton" text="🔔" onAction="#onNotifications"
                        style="-fx-background-color: rgba(151,187,228,0.15);
                               -fx-text-fill: #2C5F8A; -fx-padding: 6; -fx-cursor: hand;
                               -fx-font-size: 16px; -fx-border-color: rgba(151,187,228,0.4);
                               -fx-border-radius: 50; -fx-border-width: 1;
                               -fx-min-width: 32; -fx-min-height: 32;"/>
            </HBox>

            <!-- Filtres et Recherche -->
            <HBox spacing="10" style="-fx-padding: 20 24 0 24;">
                <TextField fx:id="searchField" promptText="Rechercher une ressource..."
                           styleClass="modern-text-field" style="-fx-font-size: 13px;"
                           HBox.hgrow="ALWAYS"/>
                <ComboBox fx:id="categoryFilter" promptText="Toutes les catégories"
                          styleClass="modern-text-field" style="-fx-font-size: 13px; -fx-pref-width: 200;"/>
            </HBox>

            <!-- Cartes ressources -->
            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                        style="-fx-background-color: transparent; -fx-background: transparent; -fx-padding: 0 24;">
                <FlowPane fx:id="resourcesContainer" hgap="20" vgap="20" prefWrapLength="700"
                          style="-fx-padding: 20 0 20 0; -fx-background-color: transparent;"/>
            </ScrollPane>

        </VBox>
    </center>

    </BorderPane>

    <!-- FLOATING CHATBOT UI -->
    <AnchorPane pickOnBounds="false">
        <!-- Chat Window -->
        <VBox fx:id="chatWindow" visible="false"
              AnchorPane.bottomAnchor="80" AnchorPane.rightAnchor="30"
              prefWidth="320" prefHeight="450"
              style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 15, 0, 0, 5); -fx-border-color: #2C5F8A; -fx-border-radius: 15; -fx-border-width: 1;">
            
            <!-- Header -->
            <HBox alignment="CENTER_LEFT" style="-fx-background-color: #2C5F8A; -fx-padding: 12; -fx-background-radius: 14 14 0 0;">
                <Label text="🤖 Assistant Pédagogique" style="-fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="✕" onAction="#toggleChat" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;"/>
            </HBox>

            <!-- Messages Area -->
            <ScrollPane fx:id="chatScrollPane" fitToWidth="true" vbarPolicy="AS_NEEDED" hbarPolicy="NEVER" style="-fx-background-color: transparent; -fx-padding: 10;" VBox.vgrow="ALWAYS">
                <VBox fx:id="chatMessages" spacing="10" style="-fx-background-color: transparent;"/>
            </ScrollPane>

            <!-- Input Area -->
            <HBox spacing="10" style="-fx-padding: 10; -fx-border-color: #EEEEEE transparent transparent transparent; -fx-background-color: #FAFAFA; -fx-background-radius: 0 0 14 14;">
                <TextField fx:id="chatInput" promptText="Posez votre question..." HBox.hgrow="ALWAYS" style="-fx-background-radius: 20; -fx-padding: 8 12;"/>
                <Button fx:id="sendChatBtn" text="Envoyer" onAction="#sendMessage" style="-fx-background-color: #2C5F8A; -fx-text-fill: white; -fx-background-radius: 20; -fx-padding: 8 15; -fx-cursor: hand;"/>
            </HBox>
        </VBox>

        <!-- Floating Button -->
        <Button fx:id="floatingChatBtn" text="💬" onAction="#toggleChat"
                AnchorPane.bottomAnchor="20" AnchorPane.rightAnchor="30"
                style="-fx-background-color: #2C5F8A; -fx-text-fill: white; -fx-font-size: 24px; -fx-background-radius: 50; -fx-min-width: 50; -fx-min-height: 50; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.3), 10, 0, 0, 4);"/>
    </AnchorPane>
</StackPane>
