<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<?import javafx.scene.shape.*?>

<?import javafx.scene.image.ImageView?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="controllers.ControllerRdvCalendrier"
            prefWidth="1024" prefHeight="700"
            style="-fx-background-color: linear-gradient(to bottom right, #F4F8FF, #E8F0FE);">


    <left>
        <VBox prefWidth="240" prefHeight="700"
              style="-fx-background-color: linear-gradient(to bottom, #D6E8F7, #2C5F8A);">

            <HBox alignment="CENTER_LEFT" spacing="10"
                  style="-fx-padding: 24 18 20 18;
                         -fx-border-color: transparent transparent rgba(255,255,255,0.12) transparent;
                         -fx-border-width: 0 0 1 0;">
                <StackPane>
                    <ImageView fx:id="logoImage" fitWidth="45" fitHeight="45" preserveRatio="true"/>
                </StackPane>
                <VBox spacing="2">
                    <Label text="MentalUp"
                           style="-fx-text-fill: #1A3A52; -fx-font-size: 16px; -fx-font-weight: bold;"/>
                    <Label text="Bien-être étudiant"
                           style="-fx-text-fill: #2C5F8A; -fx-font-size: 11px; -fx-font-weight: 600;"/>
                </VBox>
            </HBox>

            <VBox spacing="4" style="-fx-padding: 20 14 0 14;" VBox.vgrow="ALWAYS">

                <HBox alignment="CENTER_LEFT" spacing="12"
                      onMouseClicked="#onNavHomeClicked"
                      onMouseEntered="#onNavHoverEnter" onMouseExited="#onNavHoverExit"
                      style="-fx-background-color: transparent; -fx-background-radius: 8; -fx-padding: 10 14; -fx-cursor: hand;">
                    <Label text="🏠" style="-fx-font-size: 16px; -fx-text-fill: white;"/>
                    <Label text="Accueil" style="-fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: 500;"/>
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="12"
                      onMouseEntered="#onNavHoverEnter" onMouseExited="#onNavHoverExit"
                      style="-fx-background-color: transparent; -fx-background-radius: 8; -fx-padding: 10 14; -fx-cursor: hand;">
                    <Label text="📈" style="-fx-font-size: 16px; -fx-text-fill: white;"/>
                    <Label text="Suivi" style="-fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: 500;"/>
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="12"
                      onMouseClicked="#onNavRdvClicked"
                      style="-fx-background-color: #1E4568; -fx-background-radius: 8; -fx-padding: 10 14; -fx-cursor: hand;
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 5, 0, 0, 2);">
                    <Label text="📅" style="-fx-font-size: 16px; -fx-text-fill: white;"/>
                    <Label text="Rendez-vous" style="-fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="12"
                      onMouseEntered="#onNavHoverEnter" onMouseExited="#onNavHoverExit"
                      style="-fx-background-color: transparent; -fx-background-radius: 8; -fx-padding: 10 14; -fx-cursor: hand;">
                    <Label text="💬" style="-fx-font-size: 16px; -fx-text-fill: white;"/>
                    <Label text="Forum" style="-fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: 500;"/>
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="12"
                      onMouseEntered="#onNavHoverEnter" onMouseExited="#onNavHoverExit"
                      style="-fx-background-color: transparent; -fx-background-radius: 8; -fx-padding: 10 14; -fx-cursor: hand;">
                    <Label text="⚡" style="-fx-font-size: 16px; -fx-text-fill: white;"/>
                    <Label text="Activités" style="-fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: 500;"/>
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="12"
                      onMouseEntered="#onNavHoverEnter" onMouseExited="#onNavHoverExit"
                      style="-fx-background-color: transparent; -fx-background-radius: 8; -fx-padding: 10 14; -fx-cursor: hand;">
                    <Label text="📚" style="-fx-font-size: 16px; -fx-text-fill: white;"/>
                    <Label text="Ressources" style="-fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: 500;"/>
                </HBox>

            </VBox>

            <VBox spacing="6" style="-fx-padding: 16 14 20 14; -fx-border-color: rgba(255,255,255,0.2); -fx-border-width: 1 0 0 0;">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Circle radius="18" style="-fx-fill: rgba(255,255,255,0.25);"/>
                    <Label fx:id="avatarInitials" text="SA"
                           style="-fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-translate-x: -28;"/>
                    <VBox spacing="1">
                        <Label fx:id="labelUserName" text="Sophie Amara"
                               style="-fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold;"/>
                        <Label text="L3 Informatique"
                               style="-fx-text-fill: rgba(255,255,255,0.65); -fx-font-size: 11px;"/>
                    </VBox>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="⏻" onAction="#onLogout"
                            style="-fx-background-color: rgba(255,255,255,0.15); -fx-text-fill: white;
                                   -fx-background-radius: 6; -fx-padding: 5 10; -fx-cursor: hand; -fx-font-size: 12px;"/>
                </HBox>
            </VBox>

        </VBox>
    </left>

  
    <center>
        <VBox spacing="0" prefWidth="784"
              style="-fx-background-color: #F4F8FF;">

            
            <HBox alignment="CENTER_LEFT" spacing="12"
                  style="-fx-background-color: rgba(255,255,255,0.95);
                         -fx-padding: 14 24;
                         -fx-border-color: transparent transparent rgba(151,187,228,0.2) transparent;
                         -fx-border-width: 0 0 1 0;">

                <Button text="← Retour" onAction="#onRetour"
                        style="-fx-background-color: rgba(44,95,138,0.1);
                               -fx-text-fill: #2C5F8A; -fx-font-weight: bold;
                               -fx-background-radius: 8; -fx-padding: 7 16; -fx-cursor: hand;
                               -fx-border-color: rgba(44,95,138,0.2); -fx-border-radius: 8; -fx-border-width: 1;"/>

                <VBox spacing="2">
                    <Label fx:id="labelPsyNom" text="Dr. Psychologue"
                           style="-fx-font-size: 17px; -fx-font-weight: bold; -fx-text-fill: #2C3E50;"/>
                    <Label text="Disponibilités du calendrier"
                           style="-fx-font-size: 12px; -fx-text-fill: #5A6C7D;"/>
                </VBox>

                <Region HBox.hgrow="ALWAYS"/>

                
                <HBox spacing="14" alignment="CENTER_RIGHT">
                    <HBox fx:id="filterGreen" onMouseClicked="#toggleFilterGreen" spacing="5" alignment="CENTER" style="-fx-cursor: hand;">
                        <Circle radius="6" style="-fx-fill: #27AE60;"/>
                        <Label text="Libre" style="-fx-font-size: 11px; -fx-text-fill: #5A6C7D; -fx-font-weight: 600;"/>
                    </HBox>
                    <HBox fx:id="filterRed" onMouseClicked="#toggleFilterRed" spacing="5" alignment="CENTER" style="-fx-cursor: hand;">
                        <Circle radius="6" style="-fx-fill: #E74C3C;"/>
                        <Label text="Réservé / Confirmé" style="-fx-font-size: 11px; -fx-text-fill: #5A6C7D; -fx-font-weight: 600;"/>
                    </HBox>
                </HBox>

            </HBox>

          
            <HBox alignment="CENTER" spacing="14"
                  style="-fx-background-color: white;
                         -fx-padding: 12 24;
                         -fx-border-color: transparent transparent rgba(151,187,228,0.15) transparent;
                         -fx-border-width: 0 0 1 0;">

                <Button text="‹" onAction="#onPrevWeek"
                        style="-fx-background-color: #2C5F8A; -fx-text-fill: white;
                               -fx-font-size: 18px; -fx-font-weight: bold;
                               -fx-background-radius: 8; -fx-min-width: 36; -fx-min-height: 36; -fx-cursor: hand;"/>

                <Button text="Aujourd'hui" onAction="#onToday"
                        style="-fx-background-color: #F0F4F8; -fx-text-fill: #2C5F8A;
                               -fx-font-weight: bold; -fx-font-size: 13px;
                               -fx-background-radius: 8; -fx-padding: 7 18; -fx-cursor: hand;
                               -fx-border-color: rgba(44,95,138,0.2); -fx-border-radius: 8; -fx-border-width: 1;"/>

                <Button text="›" onAction="#onNextWeek"
                        style="-fx-background-color: #2C5F8A; -fx-text-fill: white;
                               -fx-font-size: 18px; -fx-font-weight: bold;
                               -fx-background-radius: 8; -fx-min-width: 36; -fx-min-height: 36; -fx-cursor: hand;"/>

                <Label fx:id="labelSemaine" text="12 – 18 avr. 2026"
                       style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2C3E50;"/>

                <Region HBox.hgrow="ALWAYS"/>

              
                <HBox spacing="0"
                      style="-fx-background-color: #F0F4F8; -fx-background-radius: 8;
                             -fx-border-color: rgba(44,95,138,0.15); -fx-border-radius: 8; -fx-border-width: 1;">
                    <Button fx:id="btnVueSemaine" text="Semaine" onAction="#onVueSemaine"
                            style="-fx-background-color: #2C5F8A; -fx-text-fill: white;
                                   -fx-font-weight: bold; -fx-font-size: 12px;
                                   -fx-background-radius: 7 0 0 7; -fx-padding: 7 14; -fx-cursor: hand;"/>
                    <Button fx:id="btnVueJour" text="Jour" onAction="#onVueJour"
                            style="-fx-background-color: transparent; -fx-text-fill: #2C5F8A;
                                   -fx-font-weight: 600; -fx-font-size: 12px;
                                   -fx-background-radius: 0 7 7 0; -fx-padding: 7 14; -fx-cursor: hand;"/>
                </HBox>

            </HBox>


            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                        style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;">
                <VBox style="-fx-padding: 0 16 16 16; -fx-background-color: #F4F8FF;">

                    <HBox fx:id="headerJours" spacing="0"
                          style="-fx-background-color: white;
                                 -fx-background-radius: 12 12 0 0;
                                 -fx-padding: 0;
                                 -fx-border-color: rgba(151,187,228,0.2);
                                 -fx-border-width: 1 1 0 1;
                                 -fx-border-radius: 12 12 0 0;">
                        
                        <VBox minWidth="60" prefWidth="60"
                              style="-fx-padding: 12 8; -fx-border-color: transparent rgba(151,187,228,0.2) transparent transparent; -fx-border-width: 0 1 0 0;">
                            <Label text="" style="-fx-font-size: 11px;"/>
                        </VBox>

                    </HBox>


                    <HBox fx:id="grilleCalendrier" spacing="0"
                          style="-fx-background-color: white;
                                 -fx-background-radius: 0 0 12 12;
                                 -fx-border-color: rgba(151,187,228,0.2);
                                 -fx-border-width: 0 1 1 1;
                                 -fx-border-radius: 0 0 12 12;">
                        
                        <VBox fx:id="colonneHeures" minWidth="60" prefWidth="60"
                              style="-fx-border-color: transparent rgba(151,187,228,0.2) transparent transparent;
                                     -fx-border-width: 0 1 0 0;">

                        </VBox>

                    </HBox>

                </VBox>
            </ScrollPane>

        </VBox>
    </center>

</BorderPane>
