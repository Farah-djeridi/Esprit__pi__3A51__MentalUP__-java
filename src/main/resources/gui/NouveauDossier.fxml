<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.collections.FXCollections?>
<?import java.lang.String?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="controllers.NouveauDossierController"
            minWidth="900" minHeight="600">

    <left>
        <VBox prefWidth="270" style="-fx-background-color: #1a4a5f;">

            <!-- LOGO + BRAND -->
            <HBox alignment="CENTER_LEFT" spacing="12" style="-fx-padding: 26 20 22 20;">
                <StackPane>
                    <ImageView fx:id="logoImage" fitWidth="40" fitHeight="40" preserveRatio="true"/>
                </StackPane>
                <VBox spacing="3">
                    <Label text="MentalUp" textFill="white" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
                    <Label text="Espace Psychologue" textFill="#8ca3b3" style="-fx-font-size: 12px;"/>
                    <Label fx:id="currentDate" textFill="#8ca3b3" style="-fx-font-size: 11px;"/>
                </VBox>
            </HBox>

            <Separator style="-fx-background-color: #2a5a6f;"/>

            <VBox spacing="4" style="-fx-padding: 16 14 0 14;" VBox.vgrow="ALWAYS">

                <Label text="MENU PRINCIPAL" textFill="#6a8a9a"
                       style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-padding: 0 0 8 8;"/>

                <HBox fx:id="navHome" onMouseClicked="#goHome"
                      alignment="CENTER_LEFT" spacing="10"
                      style="-fx-padding: 11 14; -fx-background-radius: 10; -fx-cursor: hand;">
                    <Label text="🏠" style="-fx-font-size: 14px;"/>
                    <Label text="Accueil" textFill="white" style="-fx-font-size: 14px;"/>
                </HBox>

                <!-- Rendez-vous -->
                <VBox spacing="2">
                    <HBox fx:id="navRdv" onMouseClicked="#toggleRdvMenu"
                          alignment="CENTER_LEFT" spacing="10"
                          style="-fx-padding: 11 14; -fx-background-radius: 10; -fx-cursor: hand;">
                        <Label text="📅" style="-fx-font-size: 14px;"/>
                        <Label text="Rendez-vous" textFill="white" style="-fx-font-size: 14px;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="arrowRdv" text="▶" textFill="#6a8a9a" style="-fx-font-size: 9px;"/>
                    </HBox>
                    <VBox fx:id="submenuRdv" spacing="2" style="-fx-padding: 4 0 4 24;">
                        <HBox fx:id="navVoirRdv" onMouseClicked="#goVoirRendezVous"
                              alignment="CENTER_LEFT"
                              style="-fx-padding: 9 12; -fx-background-radius: 8; -fx-cursor: hand;">
                            <Label text="• Voir les rendez-vous" textFill="#b0c4d4" style="-fx-font-size: 13px;"/>
                        </HBox>
                        <HBox fx:id="navCalendrier" onMouseClicked="#goCalendrier"
                              alignment="CENTER_LEFT"
                              style="-fx-padding: 9 12; -fx-background-radius: 8; -fx-cursor: hand;">
                            <Label text="• Mon calendrier" textFill="#b0c4d4" style="-fx-font-size: 13px;"/>
                        </HBox>
                    </VBox>
                </VBox>

                <!-- Dossiers médicaux (ACTIVE) -->
                <VBox spacing="2">
                    <HBox fx:id="navDossiers" onMouseClicked="#toggleDossiersMenu"
                          alignment="CENTER_LEFT" spacing="10"
                          style="-fx-padding: 11 14; -fx-background-radius: 10; -fx-cursor: hand;
                                 -fx-background-color: rgba(255,255,255,0.12);">
                        <Label text="📁" style="-fx-font-size: 14px;"/>
                        <Label text="Dossiers médicaux" textFill="white" style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="arrowDossiers" text="▼" textFill="#6a8a9a" style="-fx-font-size: 9px;"/>
                    </HBox>
                    <VBox fx:id="submenuDossiers" spacing="2" style="-fx-padding: 4 0 4 24;">
                        <HBox fx:id="navConsulterDossiers" onMouseClicked="#goConsulterDossiers"
                              alignment="CENTER_LEFT"
                              style="-fx-padding: 9 12; -fx-background-radius: 8; -fx-cursor: hand;">
                            <Label text="• Consulter dossiers" textFill="#b0c4d4" style="-fx-font-size: 13px;"/>
                        </HBox>
                        <HBox fx:id="navNouveauDossier" onMouseClicked="#goNouveauDossier"
                              alignment="CENTER_LEFT"
                              style="-fx-padding: 9 12; -fx-background-radius: 8; -fx-cursor: hand;
                                     -fx-background-color: rgba(255,255,255,0.08);">
                            <Label text="• Nouveau dossier" textFill="white" style="-fx-font-size: 13px; -fx-font-weight: bold;"/>
                        </HBox>
                    </VBox>
                </VBox>

                <HBox fx:id="navActivites" onMouseClicked="#goActivites"
                      alignment="CENTER_LEFT" spacing="10"
                      style="-fx-padding: 11 14; -fx-background-radius: 10; -fx-cursor: hand;">
                    <Label text="🎯" style="-fx-font-size: 14px;"/>
                    <Label text="Activités" textFill="white" style="-fx-font-size: 14px;"/>
                </HBox>

                <HBox fx:id="navRessources" onMouseClicked="#goRessources"
                      alignment="CENTER_LEFT" spacing="10"
                      style="-fx-padding: 11 14; -fx-background-radius: 10; -fx-cursor: hand;">
                    <Label text="📚" style="-fx-font-size: 14px;"/>
                    <Label text="Ressources" textFill="white" style="-fx-font-size: 14px;"/>
                </HBox>

                <HBox fx:id="navStats" onMouseClicked="#goStats"
                      alignment="CENTER_LEFT" spacing="10"
                      style="-fx-padding: 11 14; -fx-background-radius: 10; -fx-cursor: hand;">
                    <Label text="📊" style="-fx-font-size: 14px;"/>
                    <Label text="Statistiques" textFill="white" style="-fx-font-size: 14px;"/>
                </HBox>
            </VBox>

            <Region VBox.vgrow="ALWAYS"/>

            <VBox spacing="12" style="-fx-padding: 18 18 18 18; -fx-background-color: #154a5f;">
                <Label text="APERÇU RAPIDE" textFill="#6a8a9a"
                       style="-fx-font-size: 10px; -fx-font-weight: bold;"/>
                <HBox alignment="CENTER_LEFT">
                    <Label text="Patients actifs" textFill="#b0c4d4" style="-fx-font-size: 12px;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="sidebarPatientsCount" text="24" textFill="#50C878"
                           style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
                </HBox>
                <HBox alignment="CENTER_LEFT">
                    <Label text="RDV aujourd'hui" textFill="#b0c4d4" style="-fx-font-size: 12px;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="sidebarRdvToday" text="0" textFill="#97BBE4"
                           style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
                </HBox>
                <HBox alignment="CENTER_LEFT">
                    <Label text="Dossiers total" textFill="#b0c4d4" style="-fx-font-size: 12px;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="sidebarDossiersTotal" text="42" textFill="#F39C12"
                           style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
                </HBox>
            </VBox>

            <VBox spacing="12" style="-fx-padding: 16 18 20 18; -fx-border-color: #2a5a6f; -fx-border-width: 1 0 0 0;">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Circle radius="20" fill="#2a5a6f"/>
                    <VBox spacing="2">
                        <Label text="Psychologue" textFill="white"
                               style="-fx-font-size: 13px; -fx-font-weight: bold;"/>
                        <Label text="Compte professionnel" textFill="#6a8a9a"
                               style="-fx-font-size: 10px;"/>
                    </VBox>
                </HBox>
                <Button fx:id="logoutBtn" text="Déconnexion" onAction="#logout"
                        maxWidth="Infinity"
                        style="-fx-background-color: transparent; -fx-text-fill: #b0c4d4;
                               -fx-border-color: #e74c3c; -fx-border-width: 1.5;
                               -fx-background-radius: 8; -fx-border-radius: 8;
                               -fx-padding: 9; -fx-cursor: hand; -fx-font-size: 12px;"/>
            </VBox>
        </VBox>
    </left>

    <center>
        <VBox style="-fx-background-color: #f0f4f8;" VBox.vgrow="ALWAYS">

            <!-- TOP BAR -->
            <HBox alignment="CENTER_LEFT" spacing="16"
                  style="-fx-padding: 16 28 14 28; -fx-background-color: white;
                         -fx-border-color: #e2e8f0; -fx-border-width: 0 0 1 0;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.04), 6, 0, 0, 2);">
                <VBox spacing="2">
                    <Label text="Nouveau dossier médical" textFill="#0f2942"
                           style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-font-family: 'Segoe UI';"/>
                    <Label text="Créez un nouveau dossier pour un patient" textFill="#94a3b8"
                           style="-fx-font-size: 12px; -fx-font-family: 'Segoe UI';"/>
                </VBox>
            </HBox>

            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                        style="-fx-background: transparent; -fx-background-color: transparent;">
                <VBox spacing="20" style="-fx-padding: 28 32 32 32;">

                    <!-- PATIENT SELECTION -->
                    <VBox spacing="12"
                          style="-fx-background-color: white; -fx-background-radius: 14;
                                 -fx-padding: 22 24; -fx-border-color: #e2e8f0; -fx-border-width: 1;
                                 -fx-border-left-width: 4; -fx-border-left-color: #1565c0;
                                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.04), 8, 0, 0, 2);">
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <StackPane>
                                <Circle radius="16" fill="#e8f4fd"/>
                                <Label text="👤" style="-fx-font-size: 13px;"/>
                            </StackPane>
                            <Label text="Sélection du patient" textFill="#0f2942"
                                   style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-font-family: 'Segoe UI';"/>
                        </HBox>
                        <VBox spacing="6">
                            <Label text="Patient *" textFill="#64748b"
                                   style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-font-family: 'Segoe UI';"/>
                            <ComboBox fx:id="patientComboBox"
                                      promptText="Sélectionner un patient..."
                                      maxWidth="Infinity"
                                      style="-fx-background-color: #f8fafc;
                                             -fx-border-color: #e2e8f0; -fx-border-radius: 8;
                                             -fx-background-radius: 8; -fx-font-size: 13px;
                                             -fx-font-family: 'Segoe UI'; -fx-padding: 6;"/>
                            <Label text="Sélectionnez un patient existant dans le système"
                                   textFill="#94a3b8"
                                   style="-fx-font-size: 11px; -fx-font-family: 'Segoe UI';"/>
                        </VBox>
                    </VBox>

                    <!-- DATE + RISQUE -->
                    <HBox spacing="20">
                        <VBox spacing="12" HBox.hgrow="ALWAYS"
                              style="-fx-background-color: white; -fx-background-radius: 14;
                                     -fx-padding: 22 24; -fx-border-color: #e2e8f0; -fx-border-width: 1;
                                     -fx-border-left-width: 4; -fx-border-left-color: #4caf50;
                                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.04), 8, 0, 0, 2);">
                            <HBox alignment="CENTER_LEFT" spacing="10">
                                <StackPane>
                                    <Circle radius="16" fill="#edf7ee"/>
                                    <Label text="📅" style="-fx-font-size: 13px;"/>
                                </StackPane>
                                <Label text="Date de création" textFill="#0f2942"
                                       style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-font-family: 'Segoe UI';"/>
                            </HBox>
                            <VBox spacing="6">
                                <Label text="Date *" textFill="#64748b"
                                       style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-font-family: 'Segoe UI';"/>
                                <DatePicker fx:id="datePicker" maxWidth="Infinity"
                                            style="-fx-background-color: #f8fafc;
                                                   -fx-border-color: #e2e8f0; -fx-border-radius: 8;
                                                   -fx-background-radius: 8;"/>
                            </VBox>
                        </VBox>

                        <VBox spacing="12" HBox.hgrow="ALWAYS"
                              style="-fx-background-color: white; -fx-background-radius: 14;
                                     -fx-padding: 22 24; -fx-border-color: #e2e8f0; -fx-border-width: 1;
                                     -fx-border-left-width: 4; -fx-border-left-color: #ff9800;
                                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.04), 8, 0, 0, 2);">
                            <HBox alignment="CENTER_LEFT" spacing="10">
                                <StackPane>
                                    <Circle radius="16" fill="#fff8e1"/>
                                    <Label text="⚠" style="-fx-font-size: 13px;"/>
                                </StackPane>
                                <Label text="Niveau de risque" textFill="#0f2942"
                                       style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-font-family: 'Segoe UI';"/>
                            </HBox>
                            <VBox spacing="6">
                                <Label text="Risque *" textFill="#64748b"
                                       style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-font-family: 'Segoe UI';"/>
                                <ComboBox fx:id="niveauRisqueBox"
                                          promptText="Sélectionner le niveau de risque"
                                          maxWidth="Infinity"
                                          style="-fx-background-color: #f8fafc;
                                                 -fx-border-color: #e2e8f0; -fx-border-radius: 8;
                                                 -fx-background-radius: 8; -fx-font-size: 13px;
                                                 -fx-font-family: 'Segoe UI'; -fx-padding: 6;">
                                    <items>
                                        <FXCollections fx:factory="observableArrayList">
                                            <String fx:value="Faible"/>
                                            <String fx:value="Modéré"/>
                                            <String fx:value="Élevé"/>
                                            <String fx:value="Critique"/>
                                        </FXCollections>
                                    </items>
                                </ComboBox>

                                <HBox spacing="8" style="-fx-padding: 4 0 0 0;">
                                    <Label text="Faible" style="-fx-text-fill: #2e7d32;
                                           -fx-background-color: #edf7ee; -fx-background-radius: 20;
                                           -fx-padding: 4 10; -fx-font-size: 11px;
                                           -fx-font-family: 'Segoe UI';"/>
                                    <Label text="Modéré" style="-fx-text-fill: #e65100;
                                           -fx-background-color: #fff3e0; -fx-background-radius: 20;
                                           -fx-padding: 4 10; -fx-font-size: 11px;
                                           -fx-font-family: 'Segoe UI';"/>
                                    <Label text="Élevé" style="-fx-text-fill: #c62828;
                                           -fx-background-color: #ffebee; -fx-background-radius: 20;
                                           -fx-padding: 4 10; -fx-font-size: 11px;
                                           -fx-font-family: 'Segoe UI';"/>
                                    <Label text="Critique" style="-fx-text-fill: white;
                                           -fx-background-color: #b71c1c; -fx-background-radius: 20;
                                           -fx-padding: 4 10; -fx-font-size: 11px;
                                           -fx-font-family: 'Segoe UI';"/>
                                </HBox>
                            </VBox>
                        </VBox>
                    </HBox>

                    <!-- NOTES -->
                    <VBox spacing="12"
                          style="-fx-background-color: white; -fx-background-radius: 14;
                                 -fx-padding: 22 24; -fx-border-color: #e2e8f0; -fx-border-width: 1;
                                 -fx-border-left-width: 4; -fx-border-left-color: #9c27b0;
                                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.04), 8, 0, 0, 2);">
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <StackPane>
                                <Circle radius="16" fill="#f3e5f5"/>
                                <Label text="📝" style="-fx-font-size: 13px;"/>
                            </StackPane>
                            <Label text="Notes générales" textFill="#0f2942"
                                   style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-font-family: 'Segoe UI';"/>
                        </HBox>
                        <VBox spacing="8">
                            <Label text="Observations et recommandations *" textFill="#0f2942"
                                   style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-font-family: 'Segoe UI';"/>
                            <TextArea fx:id="notesField"
                                      promptText="Décrivez l'état du patient, vos observations et recommandations détaillées..."
                                      wrapText="true" prefHeight="180"
                                      style="-fx-background-color: white;
                                             -fx-border-color: #cbd5e1; -fx-border-radius: 10;
                                             -fx-background-radius: 10; -fx-font-size: 14px;
                                             -fx-text-fill: #1e293b;
                                             -fx-font-family: 'Segoe UI'; -fx-padding: 8;"/>
                        </VBox>
                    </VBox>

                    <!-- IA SUMMARY PREVIEW -->
                    <VBox spacing="12"
                          style="-fx-background-color: white; -fx-background-radius: 14;
                                 -fx-padding: 22 24; -fx-border-color: #1565c0; -fx-border-width: 1;
                                 -fx-border-left-width: 4; -fx-border-left-color: #1565c0;
                                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.04), 8, 0, 0, 2);">
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <StackPane>
                                <Circle radius="16" fill="#e3f2fd"/>
                                <Label text="✦" textFill="#1565c0" style="-fx-font-size: 13px;"/>
                            </StackPane>
                            <Label text="Aperçu du résumé IA" textFill="#0f2942"
                                   style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-font-family: 'Segoe UI';"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Button text="🪄 Générer" onAction="#handleGenerateIA"
                                    style="-fx-background-color: #1565c0; -fx-text-fill: white;
                                           -fx-background-radius: 8; -fx-padding: 8 16;
                                           -fx-cursor: hand; -fx-font-size: 12px;
                                           -fx-font-weight: bold; -fx-font-family: 'Segoe UI';"/>
                        </HBox>
                        <TextArea fx:id="aiSummaryArea" editable="false" wrapText="true" prefRowCount="3"
                                  text="Rédigez au moins 50 caractères dans les notes pour générer un résumé."
                                  style="-fx-background-color: transparent; -fx-border-color: transparent;
                                         -fx-control-inner-background: white; -fx-font-size: 14px;
                                         -fx-font-family: 'Segoe UI'; -fx-line-spacing: 1.4;
                                         -fx-text-fill: #1e293b;"/>
                    </VBox>

                    <!-- ACTION BUTTONS -->
                    <HBox spacing="12" alignment="CENTER_RIGHT">
                        <Button text="Annuler" onAction="#handleCancel"
                                style="-fx-background-color: #f8fafc; -fx-text-fill: #64748b;
                                       -fx-border-color: #e2e8f0; -fx-border-width: 1;
                                       -fx-background-radius: 8; -fx-border-radius: 8;
                                       -fx-padding: 11 24; -fx-cursor: hand; -fx-font-size: 13px;
                                       -fx-font-family: 'Segoe UI';"/>
                        <Button text="✔ Enregistrer le dossier" onAction="#handleSave"
                                style="-fx-background-color: #0f2942; -fx-text-fill: white;
                                       -fx-background-radius: 8; -fx-padding: 11 28;
                                       -fx-cursor: hand; -fx-font-size: 13px;
                                       -fx-font-family: 'Segoe UI'; -fx-font-weight: bold;"/>
                    </HBox>

                </VBox>
            </ScrollPane>
        </VBox>
    </center>
</BorderPane>

