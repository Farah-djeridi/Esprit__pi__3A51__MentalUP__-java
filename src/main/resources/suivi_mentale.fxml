<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="controllers.SuiviMentaleController"
            prefWidth="1500.0" prefHeight="920.0"
            style="-fx-background-color: linear-gradient(to bottom, #f4f8ff, #eef4fb);">

    <top>
        <VBox spacing="0" style="-fx-padding: 4 10 0 10;">

            <VBox spacing="8"
                  style="-fx-background-color: white;
                         -fx-background-radius: 18;
                         -fx-effect: dropshadow(gaussian, rgba(30,58,95,0.08), 12, 0, 0, 2);
                         -fx-padding: 12 14 12 14;">

                <HBox alignment="CENTER_LEFT" spacing="10">
                    <VBox spacing="2">
                        <Label text="✨ MentalUp"
                               style="-fx-text-fill: #1e3a5f;
                                      -fx-font-size: 19px;
                                      -fx-font-weight: bold;"/>
                        <Label text="Espace suivi mental"
                               style="-fx-text-fill: #7b8ba1;
                                      -fx-font-size: 11px;
                                      -fx-font-weight: 600;"/>
                    </VBox>

                    <Region HBox.hgrow="ALWAYS"/>

                    <Label text="mercredi 8 avril 2026"
                           style="-fx-text-fill: #9aa8b8;
                                  -fx-font-size: 11px;
                                  -fx-font-weight: 600;"/>
                </HBox>

                <VBox spacing="10"
                      style="-fx-background-color: linear-gradient(to right, #7BA6C9, #2C5F8A);
                             -fx-background-radius: 22;
                             -fx-padding: 28 26 28 26;
                             -fx-effect: dropshadow(gaussian, rgba(44,95,138,0.20), 12, 0, 0, 3);">

                    <Label text="Suivi Mental"
                           style="-fx-text-fill: white;
                                  -fx-font-size: 32px;
                                  -fx-font-weight: 900;"/>

                    <Label text="Ajoutez vos suivis, consultez l'historique et les statistiques"
                           style="-fx-text-fill: rgba(255,255,255,0.9);
                                  -fx-font-size: 14px;
                                  -fx-font-weight: 500;"/>
                </VBox>

                <HBox spacing="8">
                    <Button fx:id="ajouterTabButton"
                            text="✚ Ajouter"
                            onAction="#showAjouterSection"
                            style="-fx-background-color: linear-gradient(to right, #3b82f6, #2C5F8A);
                                   -fx-text-fill: white;
                                   -fx-font-size: 14px;
                                   -fx-font-weight: 800;
                                   -fx-background-radius: 20;
                                   -fx-padding: 8 18;
                                   -fx-cursor: hand;"/>

                    <Button fx:id="statistiquesTabButton"
                            text="📊 Statistiques"
                            onAction="#showStatistiquesSection"
                            style="-fx-background-color: #f8fbff;
                                   -fx-text-fill: #234b7d;
                                   -fx-font-size: 14px;
                                   -fx-font-weight: 800;
                                   -fx-border-color: #d7e5f7;
                                   -fx-border-radius: 20;
                                   -fx-background-radius: 20;
                                   -fx-padding: 8 18;
                                   -fx-cursor: hand;"/>

                    <Button fx:id="historiqueTabButton"
                            text="🗓 Historique"
                            onAction="#showHistoriqueSection"
                            style="-fx-background-color: #f8fbff;
                                   -fx-text-fill: #234b7d;
                                   -fx-font-size: 14px;
                                   -fx-font-weight: 800;
                                   -fx-border-color: #d7e5f7;
                                   -fx-border-radius: 20;
                                   -fx-background-radius: 20;
                                   -fx-padding: 8 18;
                                   -fx-cursor: hand;"/>

                    <Button fx:id="chatTabButton"
                            text="💬 Chat"
                            onAction="#showChatSection"
                            style="-fx-background-color: #f8fbff;
                                   -fx-text-fill: #234b7d;
                                   -fx-font-size: 14px;
                                   -fx-font-weight: 800;
                                   -fx-border-color: #d7e5f7;
                                   -fx-border-radius: 20;
                                   -fx-background-radius: 20;
                                   -fx-padding: 8 18;
                                   -fx-cursor: hand;"/>

                    <Button fx:id="pdfButton"
                            text="📄 PDF"
                            onAction="#exporterPDF"
                            style="-fx-background-color: #f8fbff;
                                   -fx-text-fill: #234b7d;
                                   -fx-font-size: 14px;
                                   -fx-font-weight: 800;
                                   -fx-border-color: #d7e5f7;
                                   -fx-border-radius: 20;
                                   -fx-background-radius: 20;
                                   -fx-padding: 8 18;
                                   -fx-cursor: hand;"/>
                </HBox>
            </VBox>

            <Label fx:id="globalMessageLabel"
                   text=""
                   style="-fx-padding: 0;
                          -fx-font-size: 0;
                          -fx-background-color: transparent;"/>
        </VBox>
    </top>

    <center>
        <StackPane style="-fx-padding: 0 10 8 10;">

            <!-- AJOUT -->
            <ScrollPane fx:id="ajoutSectionScroll"
                        fitToWidth="true"
                        visible="true"
                        managed="true"
                        hbarPolicy="NEVER"
                        style="-fx-background-color: transparent;
                               -fx-background: transparent;
                               -fx-border-color: transparent;">
                <content>
                    <VBox fx:id="ajoutSection" spacing="4" style="-fx-padding: 0;">

                        <VBox spacing="8"
                              style="-fx-background-color: linear-gradient(to right, #f8fbff, #eef6ff);
                                     -fx-background-radius: 18;
                                     -fx-border-color: #dbe7f5;
                                     -fx-border-radius: 18;
                                     -fx-effect: dropshadow(gaussian, rgba(30,58,95,0.05), 8, 0, 0, 2);
                                     -fx-padding: 14;">

                            <HBox spacing="10" alignment="CENTER_LEFT">
                                <Label text="💡" style="-fx-font-size: 22px;"/>
                                <Label text="Citation bien-être du jour"
                                       style="-fx-text-fill: #1e3a5f;
                                              -fx-font-size: 17px;
                                              -fx-font-weight: 900;"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Button text="🔄 Actualiser"
                                        onAction="#actualiserCitationSeulement"
                                        style="-fx-background-color: #eaf3ff;
                                               -fx-text-fill: #234b7d;
                                               -fx-font-size: 12px;
                                               -fx-font-weight: 800;
                                               -fx-background-radius: 18;
                                               -fx-padding: 8 14;
                                               -fx-cursor: hand;"/>
                            </HBox>

                            <Label text="Un message bien-être et des citations inspirantes pour accompagner votre suivi d’aujourd’hui"
                                   style="-fx-text-fill: #7f8c9f;
                                          -fx-font-size: 12px;
                                          -fx-font-weight: 500;"/>

                            <Label fx:id="conseilLabel"
                                   text="Chargement du message bien-être..."
                                   wrapText="true"
                                   style="-fx-background-color: white;
                                          -fx-background-radius: 14;
                                          -fx-border-color: #dbe7f5;
                                          -fx-border-radius: 14;
                                          -fx-padding: 12 14;
                                          -fx-text-fill: #475569;
                                          -fx-font-size: 14px;
                                          -fx-font-weight: 600;"/>
                        </VBox>

                        <VBox spacing="8"
                              style="-fx-background-color: white;
                                     -fx-background-radius: 18;
                                     -fx-effect: dropshadow(gaussian, rgba(30,58,95,0.05), 8, 0, 0, 2);
                                     -fx-padding: 12;">

                            <HBox spacing="10" alignment="CENTER_LEFT">
                                <Label text="📝" style="-fx-font-size: 24px;"/>
                                <Label text="Nouveau suivi"
                                       style="-fx-text-fill: #1e3a5f;
                                              -fx-font-size: 18px;
                                              -fx-font-weight: 900;"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Label text="Formulaire"
                                       style="-fx-text-fill: #1e3a5f;
                                              -fx-font-size: 10px;
                                              -fx-font-weight: 800;
                                              -fx-background-color: #eaf3ff;
                                              -fx-background-radius: 14;
                                              -fx-padding: 4 11;"/>
                            </HBox>

                            <Label text="Complétez votre état du jour"
                                   style="-fx-text-fill: #7f8c9f;
                                          -fx-font-size: 13px;"/>

                            <GridPane hgap="14" vgap="12">
                                <columnConstraints>
                                    <ColumnConstraints percentWidth="50"/>
                                    <ColumnConstraints percentWidth="50"/>
                                </columnConstraints>

                                <VBox spacing="6" GridPane.rowIndex="0" GridPane.columnIndex="0">
                                    <Label text="📅 Date"
                                           style="-fx-text-fill: #1e3a5f;
                                                  -fx-font-size: 13px;
                                                  -fx-font-weight: 800;"/>
                                    <DatePicker fx:id="dateSuiviPicker"
                                                style="-fx-background-color: #fbfdff;
                                                       -fx-background-radius: 12;
                                                       -fx-border-radius: 12;
                                                       -fx-border-color: #dbe7f5;
                                                       -fx-pref-height: 38px;"/>
                                    <Label fx:id="dateErrorLabel"
                                           text=""
                                           wrapText="true"
                                           style="-fx-text-fill: #dc2626;
                                                  -fx-font-size: 11px;
                                                  -fx-font-weight: 600;"/>
                                </VBox>

                                <VBox spacing="6" GridPane.rowIndex="0" GridPane.columnIndex="1">
                                    <Label text="😊 Humeur"
                                           style="-fx-text-fill: #1e3a5f;
                                                  -fx-font-size: 13px;
                                                  -fx-font-weight: 800;"/>
                                    <ComboBox fx:id="humeurCombo"
                                              style="-fx-background-color: #fbfdff;
                                                     -fx-background-radius: 12;
                                                     -fx-border-radius: 12;
                                                     -fx-border-color: #dbe7f5;
                                                     -fx-pref-height: 38px;"/>
                                    <Label fx:id="humeurErrorLabel"
                                           text=""
                                           wrapText="true"
                                           style="-fx-text-fill: #dc2626;
                                                  -fx-font-size: 11px;
                                                  -fx-font-weight: 600;"/>
                                </VBox>

                                <VBox spacing="6" GridPane.rowIndex="1" GridPane.columnIndex="0">
                                    <Label text="💤 Qualité du sommeil"
                                           style="-fx-text-fill: #1e3a5f;
                                                  -fx-font-size: 13px;
                                                  -fx-font-weight: 800;"/>
                                    <ComboBox fx:id="qualiteSommeilCombo"
                                              style="-fx-background-color: #fbfdff;
                                                     -fx-background-radius: 12;
                                                     -fx-border-radius: 12;
                                                     -fx-border-color: #dbe7f5;
                                                     -fx-pref-height: 38px;"/>
                                    <Label fx:id="qualiteSommeilErrorLabel"
                                           text=""
                                           wrapText="true"
                                           style="-fx-text-fill: #dc2626;
                                                  -fx-font-size: 11px;
                                                  -fx-font-weight: 600;"/>
                                </VBox>

                                <VBox spacing="6" GridPane.rowIndex="1" GridPane.columnIndex="1">
                                    <Label text="⏰ Heures de sommeil"
                                           style="-fx-text-fill: #1e3a5f;
                                                  -fx-font-size: 13px;
                                                  -fx-font-weight: 800;"/>
                                    <TextField fx:id="heureSommeilField"
                                               promptText="Ex : 7.5"
                                               style="-fx-background-color: #fbfdff;
                                                      -fx-background-radius: 12;
                                                      -fx-border-radius: 12;
                                                      -fx-border-color: #dbe7f5;
                                                      -fx-pref-height: 38px;
                                                      -fx-padding: 0 12;"/>
                                    <Label fx:id="heureSommeilErrorLabel"
                                           text=""
                                           wrapText="true"
                                           style="-fx-text-fill: #dc2626;
                                                  -fx-font-size: 11px;
                                                  -fx-font-weight: 600;"/>
                                </VBox>

                                <VBox spacing="6" GridPane.rowIndex="2" GridPane.columnIndex="0">
                                    <Label text="😰 Stress (0-10)"
                                           style="-fx-text-fill: #1e3a5f;
                                                  -fx-font-size: 13px;
                                                  -fx-font-weight: 800;"/>
                                    <TextField fx:id="stressField"
                                               promptText="Ex : 6"
                                               style="-fx-background-color: #fbfdff;
                                                      -fx-background-radius: 12;
                                                      -fx-border-radius: 12;
                                                      -fx-border-color: #dbe7f5;
                                                      -fx-pref-height: 38px;
                                                      -fx-padding: 0 12;"/>
                                    <Label fx:id="stressErrorLabel"
                                           text=""
                                           wrapText="true"
                                           style="-fx-text-fill: #dc2626;
                                                  -fx-font-size: 11px;
                                                  -fx-font-weight: 600;"/>
                                </VBox>

                                <VBox spacing="6" GridPane.rowIndex="2" GridPane.columnIndex="1">
                                    <Label text="⚡ Énergie (0-10)"
                                           style="-fx-text-fill: #1e3a5f;
                                                  -fx-font-size: 13px;
                                                  -fx-font-weight: 800;"/>
                                    <TextField fx:id="energieField"
                                               promptText="Ex : 8"
                                               style="-fx-background-color: #fbfdff;
                                                      -fx-background-radius: 12;
                                                      -fx-border-radius: 12;
                                                      -fx-border-color: #dbe7f5;
                                                      -fx-pref-height: 38px;
                                                      -fx-padding: 0 12;"/>
                                    <Label fx:id="energieErrorLabel"
                                           text=""
                                           wrapText="true"
                                           style="-fx-text-fill: #dc2626;
                                                  -fx-font-size: 11px;
                                                  -fx-font-weight: 600;"/>
                                </VBox>
                            </GridPane>

                            <VBox spacing="6">
                                <Label text="📝 Journal"
                                       style="-fx-text-fill: #1e3a5f;
                                              -fx-font-size: 13px;
                                              -fx-font-weight: 800;"/>
                                <TextArea fx:id="journalArea"
                                          prefRowCount="4"
                                          promptText="Comment vous sentez-vous aujourd'hui ?"
                                          style="-fx-background-color: #fbfdff;
                                                 -fx-background-radius: 12;
                                                 -fx-border-radius: 12;
                                                 -fx-border-color: #dbe7f5;
                                                 -fx-padding: 8 10;"/>
                                <Label fx:id="journalErrorLabel"
                                       text=""
                                       wrapText="true"
                                       style="-fx-text-fill: #dc2626;
                                              -fx-font-size: 11px;
                                              -fx-font-weight: 600;"/>
                            </VBox>

                            <VBox spacing="6" visible="false" managed="false">
                                <Label text="🎯 Objectif lié"
                                       style="-fx-text-fill: #1e3a5f;
                                              -fx-font-size: 13px;
                                              -fx-font-weight: 800;"/>
                                <Label fx:id="objectifLieLabel"
                                       text="Aucun objectif en cours."
                                       wrapText="true"
                                       style="-fx-background-color: #f8fbff;
                                              -fx-background-radius: 12;
                                              -fx-border-color: #dbe7f5;
                                              -fx-border-radius: 12;
                                              -fx-padding: 10 12;
                                              -fx-text-fill: #64748b;
                                              -fx-font-size: 13px;
                                              -fx-font-weight: 600;"/>
                            </VBox>

                            <HBox spacing="10" alignment="CENTER_RIGHT">
                                <Label fx:id="messageLabel" text="" HBox.hgrow="ALWAYS"
                                       style="-fx-font-size: 12px; -fx-font-weight: bold;"/>

                                <Button fx:id="clearButton"
                                        text="🗑 Effacer"
                                        onAction="#clearForm"
                                        style="-fx-background-color: #f1f5f9;
                                               -fx-text-fill: #64748b;
                                               -fx-font-size: 12px;
                                               -fx-font-weight: 800;
                                               -fx-background-radius: 18;
                                               -fx-padding: 9 18;
                                               -fx-cursor: hand;"/>

                                <Button fx:id="saveButton"
                                        text="💾 Enregistrer"
                                        onAction="#saveSuivi"
                                        style="-fx-background-color: linear-gradient(to right, #234b7d, #2f5d97);
                                               -fx-text-fill: white;
                                               -fx-font-size: 12px;
                                               -fx-font-weight: 900;
                                               -fx-background-radius: 18;
                                               -fx-padding: 9 22;
                                               -fx-cursor: hand;
                                               -fx-effect: dropshadow(gaussian, rgba(35,75,125,0.28), 8, 0, 0, 2);"/>
                            </HBox>
                        </VBox>
                    </VBox>
                </content>
            </ScrollPane>

            <!-- HISTORIQUE -->
            <ScrollPane fx:id="historiqueSectionScroll"
                        fitToWidth="true"
                        visible="false"
                        managed="false"
                        style="-fx-background-color: transparent;
                               -fx-background: transparent;
                               -fx-border-color: transparent;">
                <content>
                    <VBox fx:id="historiqueSection" spacing="4" style="-fx-padding: 0;">

                        <VBox spacing="8"
                              style="-fx-background-color: white;
                                     -fx-background-radius: 18;
                                     -fx-effect: dropshadow(gaussian, rgba(30,58,95,0.05), 8, 0, 0, 2);
                                     -fx-padding: 12;">

                            <HBox spacing="10" alignment="CENTER_LEFT">
                                <Label text="📅" style="-fx-font-size: 22px;"/>
                                <Label text="Historique des suivis"
                                       style="-fx-text-fill: #1e3a5f;
                                              -fx-font-size: 18px;
                                              -fx-font-weight: 900;"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Label text="Recherche"
                                       style="-fx-text-fill: #1e3a5f;
                                              -fx-font-size: 10px;
                                              -fx-font-weight: 800;
                                              -fx-background-color: #eaf3ff;
                                              -fx-background-radius: 14;
                                              -fx-padding: 4 11;"/>
                            </HBox>

                            <Label text="Consultez et gérez tous vos suivis passés"
                                   style="-fx-text-fill: #7f8c9f;
                                          -fx-font-size: 12px;"/>

                            <HBox spacing="10" style="-fx-padding: 4 0 0 0;">
                                <DatePicker fx:id="searchDateSuiviPicker"
                                            onAction="#onFilterChanged"
                                            promptText="Date du suivi"
                                            prefWidth="180"
                                            style="-fx-background-color: #fbfdff;
                                                   -fx-background-radius: 12;
                                                   -fx-border-radius: 12;
                                                   -fx-border-color: #dbe7f5;
                                                   -fx-pref-height: 36px;"/>

                                <ComboBox fx:id="searchHumeurCombo"
                                          onAction="#onFilterChanged"
                                          promptText="Humeur"
                                          prefWidth="160"
                                          style="-fx-background-color: #fbfdff;
                                                 -fx-background-radius: 12;
                                                 -fx-border-radius: 12;
                                                 -fx-border-color: #dbe7f5;
                                                 -fx-pref-height: 36px;"/>

                                <ComboBox fx:id="searchQualiteSommeilCombo"
                                          onAction="#onFilterChanged"
                                          promptText="Sommeil"
                                          prefWidth="180"
                                          style="-fx-background-color: #fbfdff;
                                                 -fx-background-radius: 12;
                                                 -fx-border-radius: 12;
                                                 -fx-border-color: #dbe7f5;
                                                 -fx-pref-height: 36px;"/>

                                <TextField fx:id="searchJournalField"
                                           onKeyReleased="#onJournalSearchChanged"
                                           promptText="🔍 Rechercher dans le journal..."
                                           prefWidth="260"
                                           style="-fx-background-color: #fbfdff;
                                                  -fx-background-radius: 12;
                                                  -fx-border-radius: 12;
                                                  -fx-border-color: #dbe7f5;
                                                  -fx-pref-height: 36px;
                                                  -fx-padding: 0 12;"/>

                                <Button text="🔄 Réinitialiser"
                                        onAction="#resetFiltresHistorique"
                                        style="-fx-background-color: #f1f5f9;
                                               -fx-text-fill: #64748b;
                                               -fx-font-size: 12px;
                                               -fx-font-weight: 800;
                                               -fx-background-radius: 18;
                                               -fx-padding: 8 18;
                                               -fx-cursor: hand;"/>
                            </HBox>
                        </VBox>

                        <FlowPane fx:id="historiqueContainer"
                                  hgap="6"
                                  vgap="6"
                                  style="-fx-padding: 0;"/>
                    </VBox>
                </content>
            </ScrollPane>

            <!-- STATISTIQUES -->
            <ScrollPane fx:id="statistiquesSectionScroll"
                        fitToWidth="true"
                        visible="false"
                        managed="false"
                        hbarPolicy="NEVER"
                        style="-fx-background-color: transparent;
                               -fx-background: transparent;
                               -fx-border-color: transparent;">
                <content>
                    <VBox fx:id="statistiquesSection" spacing="8" style="-fx-padding: 0;">

                        <VBox spacing="6"
                              style="-fx-background-color: white;
                                     -fx-background-radius: 18;
                                     -fx-effect: dropshadow(gaussian, rgba(30,58,95,0.05), 8, 0, 0, 2);
                                     -fx-padding: 12;">

                            <HBox spacing="10" alignment="CENTER_LEFT">
                                <Label text="📊" style="-fx-font-size: 22px;"/>
                                <Label text="Statistiques"
                                       style="-fx-text-fill: #1e3a5f;
                                              -fx-font-size: 18px;
                                              -fx-font-weight: 900;"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Label text="Tableau de bord"
                                       style="-fx-text-fill: #1e3a5f;
                                              -fx-font-size: 10px;
                                              -fx-font-weight: 800;
                                              -fx-background-color: #eaf3ff;
                                              -fx-background-radius: 14;
                                              -fx-padding: 4 11;"/>
                            </HBox>
                        </VBox>

                        <GridPane hgap="6" vgap="6">
                            <columnConstraints>
                                <ColumnConstraints percentWidth="25"/>
                                <ColumnConstraints percentWidth="25"/>
                                <ColumnConstraints percentWidth="25"/>
                                <ColumnConstraints percentWidth="25"/>
                            </columnConstraints>

                            <VBox spacing="6" GridPane.rowIndex="0" GridPane.columnIndex="0"
                                  style="-fx-background-color: linear-gradient(to bottom right, #234b7d, #2f5d97);
                                         -fx-background-radius: 16;
                                         -fx-padding: 14;">
                                <Label text="📋 Total suivis" style="-fx-text-fill: #dbe8f8; -fx-font-size: 11px;"/>
                                <Label fx:id="totalSuivisLabel" text="0"
                                       style="-fx-text-fill: white; -fx-font-size: 24px; -fx-font-weight: 900;"/>
                            </VBox>

                            <VBox spacing="6" GridPane.rowIndex="0" GridPane.columnIndex="1"
                                  style="-fx-background-color: linear-gradient(to bottom right, #315f97, #3f75b8);
                                         -fx-background-radius: 16;
                                         -fx-padding: 14;">
                                <Label text="😰 Stress moyen" style="-fx-text-fill: #dbe8f8; -fx-font-size: 11px;"/>
                                <Label fx:id="stressMoyenLabel" text="0"
                                       style="-fx-text-fill: white; -fx-font-size: 24px; -fx-font-weight: 900;"/>
                            </VBox>

                            <VBox spacing="6" GridPane.rowIndex="0" GridPane.columnIndex="2"
                                  style="-fx-background-color: linear-gradient(to bottom right, #3f75b8, #4d87c8);
                                         -fx-background-radius: 16;
                                         -fx-padding: 14;">
                                <Label text="⚡ Énergie moyenne" style="-fx-text-fill: #dbe8f8; -fx-font-size: 11px;"/>
                                <Label fx:id="energieMoyenneLabel" text="0"
                                       style="-fx-text-fill: white; -fx-font-size: 24px; -fx-font-weight: 900;"/>
                            </VBox>

                            <VBox spacing="6" GridPane.rowIndex="0" GridPane.columnIndex="3"
                                  style="-fx-background-color: linear-gradient(to bottom right, #4d87c8, #5d99d6);
                                         -fx-background-radius: 16;
                                         -fx-padding: 14;">
                                <Label text="💤 Sommeil moyen" style="-fx-text-fill: #dbe8f8; -fx-font-size: 11px;"/>
                                <Label fx:id="sommeilMoyenLabel" text="0"
                                       style="-fx-text-fill: white; -fx-font-size: 24px; -fx-font-weight: 900;"/>
                            </VBox>
                        </GridPane>

                        <HBox spacing="8">
                            <VBox HBox.hgrow="ALWAYS"
                                  style="-fx-background-color: white;
                                         -fx-background-radius: 18;
                                         -fx-effect: dropshadow(gaussian, rgba(30,58,95,0.05), 8, 0, 0, 2);
                                         -fx-padding: 14;">
                                <Label text="Humeur dominante"
                                       style="-fx-text-fill: #64748b; -fx-font-size: 12px; -fx-font-weight: 800;"/>
                                <Label fx:id="humeurDominanteLabel" text="-"
                                       style="-fx-text-fill: #1e3a5f; -fx-font-size: 20px; -fx-font-weight: 900;"/>
                            </VBox>

                            <VBox HBox.hgrow="ALWAYS"
                                  style="-fx-background-color: white;
                                         -fx-background-radius: 18;
                                         -fx-effect: dropshadow(gaussian, rgba(30,58,95,0.05), 8, 0, 0, 2);
                                         -fx-padding: 14;">
                                <Label text="Score mental moyen"
                                       style="-fx-text-fill: #64748b; -fx-font-size: 12px; -fx-font-weight: 800;"/>
                                <Label fx:id="scoreMentalMoyenLabel" text="0"
                                       style="-fx-text-fill: #1e3a5f; -fx-font-size: 20px; -fx-font-weight: 900;"/>
                            </VBox>
                        </HBox>

                        <HBox spacing="8">
                            <VBox HBox.hgrow="ALWAYS"
                                  style="-fx-background-color: white;
                                         -fx-background-radius: 18;
                                         -fx-effect: dropshadow(gaussian, rgba(30,58,95,0.05), 8, 0, 0, 2);
                                         -fx-padding: 14;">
                                <Label text="Répartition des humeurs"
                                       style="-fx-text-fill: #1e3a5f;
                                              -fx-font-size: 15px;
                                              -fx-font-weight: 900;"/>
                                <PieChart fx:id="pieChartHumeursStats"
                                          prefHeight="260"
                                          legendVisible="false"
                                          labelsVisible="true"
                                          style="-fx-background-color: transparent;"/>
                            </VBox>

                            <VBox HBox.hgrow="ALWAYS"
                                  style="-fx-background-color: white;
                                         -fx-background-radius: 18;
                                         -fx-effect: dropshadow(gaussian, rgba(30,58,95,0.05), 8, 0, 0, 2);
                                         -fx-padding: 14;">
                                <Label text="Comparaison des moyennes"
                                       style="-fx-text-fill: #1e3a5f;
                                              -fx-font-size: 15px;
                                              -fx-font-weight: 900;"/>
                                <BarChart fx:id="barChartMoyennes"
                                          prefHeight="260"
                                          animated="false"
                                          legendVisible="false"
                                          style="-fx-background-color: transparent;">
                                    <xAxis>
                                        <CategoryAxis fx:id="xAxisMoyennes"
                                                      label="Indicateurs"
                                                      tickLabelFill="#4B5563"/>
                                    </xAxis>
                                    <yAxis>
                                        <NumberAxis fx:id="yAxisMoyennes"
                                                    label="Valeurs moyennes"
                                                    tickLabelFill="#4B5563"/>
                                    </yAxis>
                                </BarChart>
                            </VBox>
                        </HBox>

                        <VBox spacing="10"
                              style="-fx-background-color: white;
                                     -fx-background-radius: 18;
                                     -fx-effect: dropshadow(gaussian, rgba(30,58,95,0.05), 8, 0, 0, 2);
                                     -fx-padding: 14;">
                            <Label text="Évolution du score mental"
                                   style="-fx-text-fill: #1e3a5f;
                                          -fx-font-size: 15px;
                                          -fx-font-weight: 900;"/>

                            <LineChart fx:id="lineChartEvolutionScore"
                                       prefHeight="280"
                                       animated="false"
                                       legendVisible="false"
                                       createSymbols="true"
                                       style="-fx-background-color: transparent;">
                                <xAxis>
                                    <CategoryAxis fx:id="xAxisEvolution"
                                                  label="Dates"
                                                  tickLabelRotation="-20"
                                                  tickLabelFill="#4B5563"/>
                                </xAxis>
                                <yAxis>
                                    <NumberAxis fx:id="yAxisEvolution"
                                                label="Score mental moyen"
                                                tickLabelFill="#4B5563"/>
                                </yAxis>
                            </LineChart>

                        </VBox>
                    </VBox>
                </content>
            </ScrollPane>

            <!-- CHAT -->
            <VBox fx:id="chatSection"
                  visible="false"
                  managed="false"
                  spacing="12"
                  style="-fx-padding: 0;">

                <VBox spacing="8"
                      style="-fx-background-color: white;
                             -fx-background-radius: 18;
                             -fx-effect: dropshadow(gaussian, rgba(30,58,95,0.05), 8, 0, 0, 2);
                             -fx-padding: 14;">
                    <Label text="💬 Chat"
                           style="-fx-text-fill: #1e3a5f;
                                  -fx-font-size: 18px;
                                  -fx-font-weight: 900;"/>
                    <Label text="Section chat en cours de connexion."
                           style="-fx-text-fill: #64748b;
                                  -fx-font-size: 13px;
                                  -fx-font-weight: 600;"/>
                </VBox>
            </VBox>

        </StackPane>
    </center>
</BorderPane>