<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.image.ImageView?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="Controllors.ControllerAdminSujet"
            prefWidth="1024" prefHeight="650"
            style="-fx-background-color: linear-gradient(from 0% 0% to 100% 100%, #F4F8FF, #E8F0FE);">

    <!-- SIDEBAR ADMIN -->
    <left>
        <VBox prefWidth="260" prefHeight="700"
              style="-fx-background-color: #2C3E50;">

            <!-- Logo / Brand -->
            <HBox alignment="CENTER_LEFT" spacing="10"
                  style="-fx-padding: 24 18 20 18;
                         -fx-border-color: transparent transparent rgba(255,255,255,0.1) transparent;
                         -fx-border-width: 0 0 1 0;">
                <StackPane>
                    <ImageView fx:id="logoImage" fitWidth="45" fitHeight="45" preserveRatio="true"/>
                </StackPane>
                <VBox spacing="2">
                    <Label text="MentalUp Admin"
                           style="-fx-text-fill: white; -fx-font-size: 15px;
                                  -fx-font-weight: bold;"/>
                    <Label text="Espace d'administration"
                           style="-fx-text-fill: rgba(255,255,255,0.65); -fx-font-size: 11px; -fx-font-weight: 500;"/>
                </VBox>
            </HBox>

            <!-- Navigation -->
            <VBox spacing="2" style="-fx-padding: 16 12 0 12;" VBox.vgrow="ALWAYS">

                <HBox alignment="CENTER_LEFT" spacing="12"
                      fx:id="navAccueil"
                      onMouseClicked="#onNavHomeClicked"
                      style="-fx-background-color: transparent;
                             -fx-background-radius: 8;
                             -fx-padding: 10 14;
                             -fx-cursor: hand;">
                    <Label text="🏠" style="-fx-font-size: 16px; -fx-text-fill: rgba(255,255,255,0.85);"/>
                    <Label text="Accueil"
                           style="-fx-text-fill: rgba(255,255,255,0.85); -fx-font-size: 14px; -fx-font-weight: 500;"/>
                </HBox>

                <VBox spacing="0">
                    <HBox alignment="CENTER_LEFT" spacing="12"
                          fx:id="navSuivi"
                          onMouseClicked="#toggleSuiviMenu"
                          style="-fx-background-color: transparent;
                                 -fx-background-radius: 8;
                                 -fx-padding: 10 14;
                                 -fx-cursor: hand;">
                        <Label text="📈" style="-fx-font-size: 16px; -fx-text-fill: rgba(255,255,255,0.85);"/>
                        <Label text="Suivi Mental"
                               style="-fx-text-fill: rgba(255,255,255,0.85); -fx-font-size: 14px; -fx-font-weight: 500;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="arrowSuivi" text="▶" style="-fx-text-fill: rgba(255,255,255,0.5); -fx-font-size: 11px;"/>
                    </HBox>
                    <VBox fx:id="submenuSuivi" spacing="2" style="-fx-padding: 4 0 6 28; -fx-display: none;">
                        <HBox alignment="CENTER_LEFT" spacing="10"
                              fx:id="navSuiviStats"
                              onMouseClicked="#onNavSuiviStatsClicked"
                              style="-fx-background-radius: 6; -fx-padding: 8 12; -fx-cursor: hand;">
                            <Label text="📊" style="-fx-font-size: 13px; -fx-text-fill: rgba(255,255,255,0.55);"/>
                            <Label text="Statistiques"
                                   style="-fx-text-fill: rgba(255,255,255,0.7); -fx-font-size: 13px; -fx-font-weight: 500;"/>
                        </HBox>
                    </VBox>
                </VBox>

                <VBox spacing="0">
                    <HBox alignment="CENTER_LEFT" spacing="12"
                          fx:id="navForum"
                          onMouseClicked="#toggleForumMenu"
                          style="-fx-background-color: #34495E;
                                 -fx-background-radius: 8;
                                 -fx-padding: 10 14;
                                 -fx-cursor: hand;">
                        <Label text="💬" style="-fx-font-size: 16px; -fx-text-fill: white;"/>
                        <Label text="Forum"
                               style="-fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="arrowForum" text="▼" style="-fx-text-fill: white; -fx-font-size: 11px;"/>
                    </HBox>
                    <VBox fx:id="submenuForum" spacing="2" style="-fx-padding: 4 0 6 28;">
                        <HBox alignment="CENTER_LEFT" spacing="10"
                              fx:id="navSujets"
                              onMouseClicked="#onNavSujetsClicked"
                              style="-fx-background-color: #3D5A73; -fx-background-radius: 6; -fx-padding: 8 12; -fx-cursor: hand;">
                            <Label text="📝" style="-fx-font-size: 13px; -fx-text-fill: white;"/>
                            <Label text="Sujets"
                                   style="-fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold;"/>
                        </HBox>
                        <HBox alignment="CENTER_LEFT" spacing="10"
                              fx:id="navCommentaires"
                              onMouseClicked="#onNavCommentairesClicked"
                              style="-fx-background-radius: 6; -fx-padding: 8 12; -fx-cursor: hand;">
                            <Label text="💬" style="-fx-font-size: 13px; -fx-text-fill: rgba(255,255,255,0.55);"/>
                            <Label text="Commentaires"
                                   style="-fx-text-fill: rgba(255,255,255,0.7); -fx-font-size: 13px; -fx-font-weight: 500;"/>
                        </HBox>
                    </VBox>
                </VBox>

                <HBox alignment="CENTER_LEFT" spacing="12"
                      fx:id="navRdv"
                      onMouseClicked="#onNavRdvClicked"
                      style="-fx-background-color: transparent;
                             -fx-background-radius: 8;
                             -fx-padding: 10 14;
                             -fx-cursor: hand;">
                    <Label text="📅" style="-fx-font-size: 16px; -fx-text-fill: rgba(255,255,255,0.85);"/>
                    <Label text="Rendez-vous"
                           style="-fx-text-fill: rgba(255,255,255,0.85); -fx-font-size: 14px; -fx-font-weight: 500;"/>
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="12"
                      fx:id="navUtilisateurs"
                      onMouseClicked="#onNavUtilisateursClicked"
                      style="-fx-background-color: transparent;
                             -fx-background-radius: 8;
                             -fx-padding: 10 14;
                             -fx-cursor: hand;">
                    <Label text="👥" style="-fx-font-size: 16px; -fx-text-fill: rgba(255,255,255,0.85);"/>
                    <Label text="Utilisateurs"
                           style="-fx-text-fill: rgba(255,255,255,0.85); -fx-font-size: 14px; -fx-font-weight: 500;"/>
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="12"
                      fx:id="navDossiers"
                      onMouseClicked="#onNavDossiersClicked"
                      style="-fx-background-color: transparent;
                             -fx-background-radius: 8;
                             -fx-padding: 10 14;
                             -fx-cursor: hand;">
                    <Label text="📋" style="-fx-font-size: 16px; -fx-text-fill: rgba(255,255,255,0.85);"/>
                    <Label text="Dossiers médicaux"
                           style="-fx-text-fill: rgba(255,255,255,0.85); -fx-font-size: 14px; -fx-font-weight: 500;"/>
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="12"
                      fx:id="navContenus"
                      onMouseClicked="#onNavContenusClicked"
                      style="-fx-background-color: transparent;
                             -fx-background-radius: 8;
                             -fx-padding: 10 14;
                             -fx-cursor: hand;">
                    <Label text="📝" style="-fx-font-size: 16px; -fx-text-fill: rgba(255,255,255,0.85);"/>
                    <Label text="Contenus"
                           style="-fx-text-fill: rgba(255,255,255,0.85); -fx-font-size: 14px; -fx-font-weight: 500;"/>
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="12"
                      fx:id="navActivites"
                      onMouseClicked="#onNavActivitesClicked"
                      style="-fx-background-color: transparent;
                             -fx-background-radius: 8;
                             -fx-padding: 10 14;
                             -fx-cursor: hand;">
                    <Label text="⚡" style="-fx-font-size: 16px; -fx-text-fill: rgba(255,255,255,0.85);"/>
                    <Label text="Activités"
                           style="-fx-text-fill: rgba(255,255,255,0.85); -fx-font-size: 14px; -fx-font-weight: 500;"/>
                </HBox>

            </VBox>

            <!-- Profil administrateur -->
            <VBox spacing="6" style="-fx-padding: 16 14 20 14; -fx-border-color: rgba(255,255,255,0.08); -fx-border-width: 1 0 0 0;">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Circle radius="18" style="-fx-fill: rgba(255,255,255,0.15);"/>
                    <Label fx:id="avatarInitials" text="AD"
                           style="-fx-text-fill: white; -fx-font-size: 13px;
                                  -fx-font-weight: bold; -fx-translate-x: -28;"/>
                    <VBox spacing="1">
                        <Label fx:id="labelUserName" text="Admin MentalUp"
                               style="-fx-text-fill: white; -fx-font-size: 13px;
                                      -fx-font-weight: bold;"/>
                        <Label text="Super Administrateur"
                               style="-fx-text-fill: rgba(255,255,255,0.55); -fx-font-size: 11px; -fx-font-weight: 500;"/>
                    </VBox>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button fx:id="logoutButton" text="⏻" onAction="#onLogout"
                            style="-fx-background-color: rgba(255,255,255,0.1);
                                   -fx-text-fill: white;
                                   -fx-background-radius: 6;
                                   -fx-padding: 5 10;
                                   -fx-cursor: hand;
                                   -fx-font-size: 12px;
                                   -fx-font-weight: bold;"/>
                </HBox>
            </VBox>

        </VBox>
    </left>

    <!-- CONTENU PRINCIPAL - GESTION DES SUJETS -->
    <center>
        <VBox spacing="0" prefWidth="764" prefHeight="700"
              style="-fx-background-color: #F4F8FF;">

            <!-- Barre supérieure -->
            <HBox alignment="CENTER_LEFT" spacing="12"
                  style="-fx-background-color: white;
                         -fx-padding: 14 24;
                         -fx-border-color: transparent transparent #E8EEF4 transparent;
                         -fx-border-width: 0 0 1 0;">
                <VBox spacing="2">
                    <Label text="📝 Gestion des sujets du forum"
                           style="-fx-font-size: 18px; -fx-font-weight: bold;
                                  -fx-text-fill: #2C3E50;"/>
                    <Label fx:id="labelDate" text=""
                           style="-fx-font-size: 12px; -fx-text-fill: #5A6C7D; -fx-font-weight: 500;"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="notifButton" text="🔔" onAction="#onNotifications"
                        style="-fx-background-color: transparent;
                               -fx-text-fill: #5A6E7A;
                               -fx-padding: 6;
                               -fx-cursor: hand;
                               -fx-font-size: 16px;
                               -fx-border-color: #E8EEF4;
                               -fx-border-radius: 50;
                               -fx-border-width: 1;
                               -fx-min-width: 32;
                               -fx-min-height: 32;"/>
            </HBox>

            <VBox spacing="20" style="-fx-padding: 24 28 28 28;" VBox.vgrow="ALWAYS">

                <!-- Bannière -->
                <HBox style="-fx-background-color: linear-gradient(to right, #2C3E50, #34495E);
                             -fx-background-radius: 20;
                             -fx-padding: 25 35;
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 15, 0, 0, 5);"
                      alignment="CENTER_LEFT">
                    <VBox spacing="8" HBox.hgrow="ALWAYS">
                        <Label text="📝 Gestion des sujets"
                               style="-fx-text-fill: white; -fx-font-size: 22px;
                                      -fx-font-weight: bold;"/>
                        <Label text="Consultez, modifiez ou supprimez les sujets du forum"
                               style="-fx-text-fill: rgba(255,255,255,0.75);
                                      -fx-font-size: 13px;"/>
                    </VBox>
                    <Label text="💬" style="-fx-font-size: 60px; -fx-opacity: 0.12;"
                           HBox.hgrow="NEVER"/>
                </HBox>

                <!-- Barre de recherche -->
                <HBox spacing="15" alignment="CENTER_LEFT"
                      style="-fx-background-color: white;
                             -fx-background-radius: 15;
                             -fx-padding: 12 18;
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 8, 0, 0, 2);">
                    <HBox HBox.hgrow="ALWAYS" spacing="10" alignment="CENTER"
                          style="-fx-background-color: #F8FAFE;
                                 -fx-background-radius: 10;
                                 -fx-padding: 6 12;
                                 -fx-border-color: #E8EEF4;
                                 -fx-border-radius: 10;
                                 -fx-border-width: 1;">
                        <Label text="🔍" style="-fx-font-size: 14px;"/>
                        <TextField fx:id="searchField" promptText="Rechercher un sujet..."
                                   style="-fx-background-color: transparent; -fx-font-size: 13px;"
                                   HBox.hgrow="ALWAYS"/>
                    </HBox>
                    <ComboBox fx:id="filterCombo" prefWidth="140"
                              style="-fx-background-color: #F8FAFE;
                                     -fx-background-radius: 10;
                                     -fx-border-color: #E8EEF4;
                                     -fx-border-radius: 10;"/>
                    <Button text="🔍 Filtrer" onAction="#onFilter"
                            style="-fx-background-color: #2C3E50;
                                   -fx-text-fill: white;
                                   -fx-font-weight: bold;
                                   -fx-background-radius: 10;
                                   -fx-padding: 6 18;
                                   -fx-cursor: hand;"/>
                </HBox>

                <!-- Statistiques -->
                <HBox spacing="15">
                    <HBox spacing="10" alignment="CENTER_LEFT"
                          style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 12 18;">
                        <Label text="📊" style="-fx-font-size: 20px;"/>
                        <Label text="Total sujets :" style="-fx-text-fill: #5A6C7D;"/>
                        <Label fx:id="totalSujetsLabel" text="0" style="-fx-font-weight: bold; -fx-text-fill: #2C3E50; -fx-font-size: 18px;"/>
                    </HBox>
                    <Region HBox.hgrow="ALWAYS"/>
                </HBox>

                <!-- Tableau container -->
                <VBox spacing="0" style="-fx-background-color: white; -fx-background-radius: 16; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 8, 0, 0, 2);"
                      VBox.vgrow="ALWAYS">

                    <!-- En-tête du tableau -->
                    <HBox spacing="10" alignment="CENTER_LEFT"
                          style="-fx-background-color: #2C3E50; -fx-background-radius: 16 16 0 0; -fx-padding: 14 15;">
                        <Label text="ID" prefWidth="50" style="-fx-text-fill: white; -fx-font-weight: bold;"/>
                        <Label text="Titre" prefWidth="200" style="-fx-text-fill: white; -fx-font-weight: bold;"/>
                        <Label text="Auteur" prefWidth="130" style="-fx-text-fill: white; -fx-font-weight: bold;"/>
                        <Label text="Contenu" prefWidth="220" style="-fx-text-fill: white; -fx-font-weight: bold;"/>
                        <Label text="Date" prefWidth="100" style="-fx-text-fill: white; -fx-font-weight: bold;"/>
                        <Label text="👍" prefWidth="50" style="-fx-text-fill: white; -fx-font-weight: bold;" alignment="CENTER"/>
                        <Label text="👎" prefWidth="50" style="-fx-text-fill: white; -fx-font-weight: bold;" alignment="CENTER"/>
                        <Label text="Vues" prefWidth="50" style="-fx-text-fill: white; -fx-font-weight: bold;" alignment="CENTER"/>
                        <Label text="Actions" prefWidth="130" style="-fx-text-fill: white; -fx-font-weight: bold;" alignment="CENTER"/>
                    </HBox>

                    <!-- ScrollPane avec les lignes -->
                    <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent; -fx-padding: 0;">
                        <VBox spacing="0" fx:id="cardsContainer">
                            <!-- Les lignes seront ajoutées dynamiquement -->
                        </VBox>
                    </ScrollPane>
                </VBox>



            </VBox>

        </VBox>
    </center>

</BorderPane>