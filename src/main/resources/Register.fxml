<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="560.0" prefWidth="440.0"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="Controllor.RegisterController"
            style="-fx-background-color: #f0f4f8;">

    <VBox alignment="CENTER" spacing="12"
          AnchorPane.topAnchor="30" AnchorPane.bottomAnchor="30"
          AnchorPane.leftAnchor="50" AnchorPane.rightAnchor="50">

        <Label text="Cr├®er un compte"
               style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>

        <VBox spacing="4">
            <Label text="Pr├®nom" style="-fx-font-weight: bold; -fx-text-fill: #34495e;"/>
            <TextField fx:id="txtPrenom" promptText="Votre pr├®nom"
                       style="-fx-pref-height: 35px; -fx-border-color: #bdc3c7; -fx-border-radius: 5; -fx-background-radius: 5;"/>
        </VBox>

        <VBox spacing="4">
            <Label text="Nom" style="-fx-font-weight: bold; -fx-text-fill: #34495e;"/>
            <TextField fx:id="txtNom" promptText="Votre nom"
                       style="-fx-pref-height: 35px; -fx-border-color: #bdc3c7; -fx-border-radius: 5; -fx-background-radius: 5;"/>
        </VBox>

        <VBox spacing="4">
            <Label text="Email" style="-fx-font-weight: bold; -fx-text-fill: #34495e;"/>
            <TextField fx:id="txtEmail" promptText="votre@email.com"
                       style="-fx-pref-height: 35px; -fx-border-color: #bdc3c7; -fx-border-radius: 5; -fx-background-radius: 5;"/>
        </VBox>

        <VBox spacing="4">
            <Label text="Mot de passe (min. 8 caract├¿res)" style="-fx-font-weight: bold; -fx-text-fill: #34495e;"/>
            <PasswordField fx:id="txtPassword" promptText="ÔÇóÔÇóÔÇóÔÇóÔÇóÔÇóÔÇóÔÇó"
                           style="-fx-pref-height: 35px; -fx-border-color: #bdc3c7; -fx-border-radius: 5; -fx-background-radius: 5;"/>
        </VBox>

        <VBox spacing="4">
            <Label text="Confirmer le mot de passe" style="-fx-font-weight: bold; -fx-text-fill: #34495e;"/>
            <PasswordField fx:id="txtConfirmPassword" promptText="ÔÇóÔÇóÔÇóÔÇóÔÇóÔÇóÔÇóÔÇó"
                           style="-fx-pref-height: 35px; -fx-border-color: #bdc3c7; -fx-border-radius: 5; -fx-background-radius: 5;"/>
        </VBox>

        <VBox spacing="4">
            <Label text="R├┤le" style="-fx-font-weight: bold; -fx-text-fill: #34495e;"/>
            <ComboBox fx:id="comboRole" maxWidth="Infinity" style="-fx-pref-height: 35px;"/>
        </VBox>

        <Label fx:id="lblError" text="" wrapText="true"
               style="-fx-text-fill: #e74c3c; -fx-font-size: 12px;"/>

        <Button text="S'inscrire" onAction="#handleRegister" maxWidth="Infinity"
                style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-size: 14px;
                       -fx-font-weight: bold; -fx-pref-height: 40px; -fx-background-radius: 5; -fx-cursor: hand;"/>

        <Separator/>

        <HBox alignment="CENTER" spacing="5">
            <Label text="D├®j├á un compte ?" style="-fx-text-fill: #7f8c8d;"/>
            <Hyperlink text="Se connecter" onAction="#goToLogin"
                       style="-fx-text-fill: #3498db; -fx-font-weight: bold;"/>
        </HBox>
    </VBox>
</AnchorPane>
