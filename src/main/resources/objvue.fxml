                                              -fx-font-size: 24px;
                                              -fx-font-weight: 900;"/>
                            </VBox>

                            <VBox spacing="6" HBox.hgrow="ALWAYS"
                                  style="-fx-background-color: linear-gradient(to bottom right, #315f97, #3f75b8);
