<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.image.ImageView?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="Controllor.ObjectifAdminController"
            prefWidth="1500" prefHeight="920"
            style="-fx-background-color: #F4F8FF;">

    <!-- ═══════════════ SIDEBAR ADMIN ═══════════════ -->
    <left>
        <VBox prefWidth="260" maxWidth="260" VBox.vgrow="ALWAYS" style="-fx-background-color: #2C3E50;">

            <HBox alignment="CENTER_LEFT" spacing="10"
                  style="-fx-padding: 24 18 20 18;
                         -fx-border-color: transparent transparent rgba(255,255,255,0.1) transparent;
                         -fx-border-width: 0 0 1 0;">
                <StackPane>
                    <ImageView fx:id="logoImage" fitWidth="45" fitHeight="45" preserveRatio="true"/>
                </StackPane>
                <VBox spacing="2">
                    <Label text="MentalUp Admin"
                           style="-fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: bold;"/>
                    <Label text="Espace d'administration"
                           style="-fx-text-fill: rgba(255,255,255,0.65); -fx-font-size: 11px;"/>
                </VBox>
            </HBox>

            <VBox spacing="2" style="-fx-padding: 16 12 0 12;" VBox.vgrow="ALWAYS">

                <!-- Accueil -->
                <HBox alignment="CENTER_LEFT" spacing="12"
                      onMouseClicked="#onNavHomeClicked"
                      style="-fx-background-color: transparent; -fx-background-radius: 8; -fx-padding: 10 14; -fx-cursor: hand;">
                    <Label text="🏠" style="-fx-font-size: 16px; -fx-text-fill: rgba(255,255,255,0.85);"/>
                    <Label text="Accueil" style="-fx-text-fill: rgba(255,255,255,0.85); -fx-font-size: 14px; -fx-font-weight: 500;"/>
                </HBox>

                <!-- Suivi Mental ACTIF -->
                <VBox spacing="0">
                    <HBox alignment="CENTER_LEFT" spacing="12"
                          style="-fx-background-color: #34495E; -fx-background-radius: 8; -fx-padding: 10 14; -fx-cursor: hand;
                                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 5, 0, 0, 2);">
                        <Label text="📈" style="-fx-font-size: 16px; -fx-text-fill: white;"/>
                        <Label text="Suivi Mental" style="-fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label text="▼" style="-fx-text-fill: white; -fx-font-size: 11px;"/>
                    </HBox>

                    <VBox spacing="2" style="-fx-padding: 4 0 6 28;">
                        <HBox alignment="CENTER_LEFT" spacing="10"
                              onMouseClicked="#onNavSuiviStatsClicked"
                              style="-fx-background-radius: 6; -fx-padding: 8 12; -fx-cursor: hand;">
                            <Label text="📊" style="-fx-font-size: 13px; -fx-text-fill: rgba(255,255,255,0.55);"/>
                            <Label text="Liste des suivis" style="-fx-text-fill: rgba(255,255,255,0.7); -fx-font-size: 13px; -fx-font-weight: 500;"/>
                        </HBox>

                        <HBox alignment="CENTER_LEFT" spacing="10"
                              style="-fx-background-color: rgba(255,255,255,0.1); -fx-background-radius: 6; -fx-padding: 8 12; -fx-cursor: hand;">
                            <Label text="🎯" style="-fx-font-size: 13px; -fx-text-fill: white;"/>
                            <Label text="Objectifs" style="-fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold;"/>
                        </HBox>
                    </VBox>
                </VBox>

                <!-- Autres menus -->
                <HBox alignment="CENTER_LEFT" spacing="12"
                      onMouseClicked="#onNavRdvClicked"
                      style="-fx-background-color: transparent; -fx-background-radius: 8; -fx-padding: 10 14; -fx-cursor: hand;">
                    <Label text="📅" style="-fx-font-size: 16px; -fx-text-fill: rgba(255,255,255,0.85);"/>
                    <Label text="Rendez-vous" style="-fx-text-fill: rgba(255,255,255,0.85); -fx-font-size: 14px; -fx-font-weight: 500;"/>
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="12"
                      onMouseClicked="#onNavDossiersClicked"
                      style="-fx-background-color: transparent; -fx-background-radius: 8; -fx-padding: 10 14; -fx-cursor: hand;">
                    <Label text="📋" style="-fx-font-size: 16px; -fx-text-fill: rgba(255,255,255,0.85);"/>
                    <Label text="Dossiers médicaux" style="-fx-text-fill: rgba(255,255,255,0.85); -fx-font-size: 14px; -fx-font-weight: 500;"/>
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="12"
                      onMouseClicked="#onNavUtilisateursClicked"
                      style="-fx-background-color: transparent; -fx-background-radius: 8; -fx-padding: 10 14; -fx-cursor: hand;">
                    <Label text="👥" style="-fx-font-size: 16px; -fx-text-fill: rgba(255,255,255,0.85);"/>
                    <Label text="Utilisateurs" style="-fx-text-fill: rgba(255,255,255,0.85); -fx-font-size: 14px; -fx-font-weight: 500;"/>
                </HBox>

            </VBox>

            <!-- Profil administrateur -->
            <VBox spacing="6" style="-fx-padding: 16 14 20 14; -fx-border-color: rgba(255,255,255,0.08); -fx-border-width: 1 0 0 0;">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Circle radius="18" style="-fx-fill: rgba(255,255,255,0.15);"/>
                    <Label text="AD" style="-fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-translate-x: -28;"/>
                    <VBox spacing="1">
                        <Label text="Admin MentalUp" style="-fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold;"/>
                        <Label text="Super Administrateur" style="-fx-text-fill: rgba(255,255,255,0.55); -fx-font-size: 11px;"/>
                    </VBox>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="⏻" onAction="#onLogout"
                            style="-fx-background-color: rgba(255,255,255,0.1); -fx-text-fill: white;
                                   -fx-background-radius: 6; -fx-padding: 5 10; -fx-cursor: hand; -fx-font-size: 12px;"/>
                </HBox>
            </VBox>
        </VBox>
    </left>

    <!-- ═══════════════ CONTENU PRINCIPAL ═══════════════ -->
    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER"
                    style="-fx-background-color: transparent; -fx-background: transparent;">
            <content>
                <VBox spacing="20" style="-fx-padding: 24; -fx-background-color: #F4F8FF;">
                    <!-- Titre -->
                    <VBox spacing="8"
                          style="-fx-background-color: white; -fx-background-radius: 18; -fx-padding: 18;
                                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 8, 0, 0, 2);">
                        <Label text="Objectifs des utilisateurs"
                               style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #223A5E;"/>
                        <Label text="L’administrateur peut consulter, modifier et supprimer tous les objectifs."
                               style="-fx-font-size: 13px; -fx-text-fill: #6B7280;"/>
                    </VBox>

                    <!-- Statistiques -->
                    <VBox spacing="14"
                          style="-fx-background-color: white; -fx-background-radius: 18; -fx-padding: 18;
                                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 8, 0, 0, 2);">
                        <Label text="Statistiques globales"
                               style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #223A5E;"/>
                        <FlowPane hgap="14" vgap="14" prefWrapLength="1100">
                            <VBox prefWidth="220" style="-fx-background-color: linear-gradient(to right, #6D5EF6, #4F46E5); -fx-background-radius: 16; -fx-padding: 18;">
                                <Label text="Total" style="-fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                                <Label fx:id="lblTotal" text="0" style="-fx-text-fill: white; -fx-font-size: 28px; -fx-font-weight: bold;"/>
                            </VBox>
                            <VBox prefWidth="220" style="-fx-background-color: white; -fx-border-color: #E5E7EB; -fx-border-radius: 16; -fx-background-radius: 16; -fx-padding: 18;">
                                <Label text="En cours" style="-fx-text-fill: #6B7280; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                                <Label fx:id="lblEnCours" text="0" style="-fx-text-fill: #223A5E; -fx-font-size: 28px; -fx-font-weight: bold;"/>
                            </VBox>
                            <VBox prefWidth="220" style="-fx-background-color: white; -fx-border-color: #E5E7EB; -fx-border-radius: 16; -fx-background-radius: 16; -fx-padding: 18;">
                                <Label text="Atteints" style="-fx-text-fill: #6B7280; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                                <Label fx:id="lblAtteints" text="0" style="-fx-text-fill: #223A5E; -fx-font-size: 28px; -fx-font-weight: bold;"/>
                            </VBox>
                            <VBox prefWidth="220" style="-fx-background-color: white; -fx-border-color: #E5E7EB; -fx-border-radius: 16; -fx-background-radius: 16; -fx-padding: 18;">
                                <Label text="Annulés" style="-fx-text-fill: #6B7280; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                                <Label fx:id="lblAnnules" text="0" style="-fx-text-fill: #223A5E; -fx-font-size: 28px; -fx-font-weight: bold;"/>
                            </VBox>
                        </FlowPane>
                    </VBox>

                    <!-- Charts -->
                    <HBox spacing="18">
                        <VBox VBox.vgrow="ALWAYS" style="-fx-background-color: white; -fx-background-radius: 18; -fx-padding: 18; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 8, 0, 0, 2);" prefWidth="520">
                            <Label text="Répartition des statuts" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #223A5E;"/>
                            <PieChart fx:id="pieChartStatuts" prefHeight="320" legendVisible="false" labelsVisible="true"/>
                        </VBox>
                        <VBox VBox.vgrow="ALWAYS" style="-fx-background-color: white; -fx-background-radius: 18; -fx-padding: 18; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 8, 0, 0, 2);" prefWidth="520">
                            <Label text="Progression moyenne par statut" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #223A5E;"/>
                            <BarChart fx:id="barChartProgressionStatut" prefHeight="320" animated="false" legendVisible="false">
                                <xAxis><CategoryAxis fx:id="xAxisProgressionStatut" label="Statut"/></xAxis>
                                <yAxis><NumberAxis fx:id="yAxisProgressionStatut" label="Progression moyenne"/></yAxis>
                            </BarChart>
                        </VBox>
                    </HBox>

                    <!-- Recherche -->
                    <VBox spacing="14"
                          style="-fx-background-color: white; -fx-background-radius: 18; -fx-padding: 18;
                                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 8, 0, 0, 2);">
                        <Label text="Recherche et filtres"
                               style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #223A5E;"/>
                        <HBox spacing="12">
                            <TextField fx:id="txtRechercheTitre" promptText="Titre objectif" HBox.hgrow="ALWAYS" style="-fx-background-radius: 12; -fx-padding: 12;"/>
                            <ComboBox fx:id="comboStatut" promptText="Statut" HBox.hgrow="ALWAYS" style="-fx-background-radius: 12;"/>
                            <Button text="Filtrer" onAction="#filtrerObjectifs"
                                    style="-fx-background-color: #2C3E50; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 22; -fx-padding: 10 24; -fx-cursor: hand;"/>
                            <Button text="Réinitialiser" onAction="#reinitialiserFiltres"
                                    style="-fx-background-color: #E5E7EB; -fx-text-fill: #374151; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 22; -fx-padding: 10 24; -fx-cursor: hand;"/>
                        </HBox>
                    </VBox>

                    <!-- Liste -->
                    <VBox spacing="10"
                          style="-fx-background-color: white; -fx-background-radius: 18; -fx-padding: 18;
                                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 8, 0, 0, 2);">
                        <Label text="Liste des objectifs"
                               style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #223A5E;"/>
                        <VBox fx:id="containerObjectifs" spacing="10"/>
                    </VBox>
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>