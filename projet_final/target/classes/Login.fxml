<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="420.0" prefWidth="420.0"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="Controllor.LoginController"
            style="-fx-background-color: #f0f4f8;">

    <VBox alignment="CENTER" spacing="15"
          AnchorPane.topAnchor="40" AnchorPane.bottomAnchor="40"
          AnchorPane.leftAnchor="50" AnchorPane.rightAnchor="50">

        <Label text="Connexion"
               style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
        <Label text="Bienvenue ! Veuillez vous connecter."
               style="-fx-text-fill: #7f8c8d; -fx-font-size: 13px;"/>

        <VBox spacing="4">
            <Label text="Email" style="-fx-font-weight: bold; -fx-text-fill: #34495e;"/>
            <TextField fx:id="txtEmail" promptText="votre@email.com"
                       style="-fx-pref-height: 36px; -fx-border-color: #bdc3c7; -fx-border-radius: 5; -fx-background-radius: 5;"/>
        </VBox>

        <VBox spacing="4">
            <Label text="Mot de passe" style="-fx-font-weight: bold; -fx-text-fill: #34495e;"/>
            <PasswordField fx:id="txtPassword" promptText="••••••••"
                           style="-fx-pref-height: 36px; -fx-border-color: #bdc3c7; -fx-border-radius: 5; -fx-background-radius: 5;"/>
        </VBox>

        <Label fx:id="lblError" text="" wrapText="true"
               style="-fx-text-fill: #e74c3c; -fx-font-size: 12px;"/>

        <Button text="Se connecter" onAction="#handleLogin" maxWidth="Infinity"
                style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-size: 14px;
                       -fx-font-weight: bold; -fx-pref-height: 40px; -fx-background-radius: 5; -fx-cursor: hand;"/>

        <Separator/>

        <HBox alignment="CENTER" spacing="5">
            <Label text="Pas encore de compte ?" style="-fx-text-fill: #7f8c8d;"/>
            <Hyperlink text="S'inscrire" onAction="#goToRegister"
                       style="-fx-text-fill: #3498db; -fx-font-weight: bold;"/>
        </HBox>
    </VBox>
</AnchorPane>
