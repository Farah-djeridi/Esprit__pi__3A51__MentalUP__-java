<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.shape.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.image.ImageView?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="Controllor.ControllerHomePsy"
            prefWidth="1100" prefHeight="700">

    <!-- ================= SIDEBAR ================= -->
    <left>
        <VBox prefWidth="280" style="-fx-background-color: #1a4a5f;">

            <!-- LOGO + BRAND -->
            <HBox alignment="CENTER_LEFT" spacing="12" style="-fx-padding: 28 22 24 22;">
                <StackPane>
                    <ImageView fx:id="logoImage" fitWidth="40" fitHeight="40" preserveRatio="true"/>
                </StackPane>
                <VBox spacing="3">
                    <Label text="MentalUp" style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;"/>
                    <Label text="Espace Psychologue" style="-fx-text-fill: #8ca3b3; -fx-font-size: 12px;"/>
                </VBox>
            </HBox>

            <Separator style="-fx-background-color: #2a5a6f;"/>

            <!-- MENU NAVIGATION -->
            <VBox spacing="6" style="-fx-padding: 20 16 0 16;" VBox.vgrow="ALWAYS">

                <Label text="MENU PRINCIPAL" style="-fx-text-fill: #6a8a9a; -fx-font-size: 11px; -fx-font-weight: bold; -fx-padding: 0 0 8 12;"/>

                <HBox fx:id="navHome" onMouseClicked="#goHome"
                      alignment="CENTER_LEFT" spacing="12"
                      style="-fx-padding: 12 14; -fx-background-radius: 10; -fx-cursor: hand;">
                    <Label text="🏠" style="-fx-font-size: 15px;"/>
                    <Label text="Accueil" style="-fx-text-fill: white; -fx-font-size: 14px;"/>
                </HBox>

                <VBox spacing="2">
                    <HBox fx:id="navRdv" onMouseClicked="#toggleRdvMenu"
                          alignment="CENTER_LEFT" spacing="12"
                          style="-fx-padding: 12 14; -fx-background-radius: 10; -fx-cursor: hand;">
                        <Label text="📅" style="-fx-font-size: 15px;"/>
                        <Label text="Rendez-vous" style="-fx-text-fill: white; -fx-font-size: 14px;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="arrowRdv" text="▶" style="-fx-text-fill: #6a8a9a; -fx-font-size: 10px;"/>
                    </HBox>
                    <VBox fx:id="submenuRdv" spacing="2" style="-fx-padding: 4 0 4 20;">
                        <HBox fx:id="navVoirRdv" onMouseClicked="#goVoirRendezVous"
                              alignment="CENTER_LEFT" spacing="10"
                              style="-fx-padding: 10 12; -fx-background-radius: 8; -fx-cursor: hand;">
                            <Label text="• Voir les rendez-vous" style="-fx-text-fill: #b0c4d4; -fx-font-size: 13px;"/>
                        </HBox>
                        <HBox fx:id="navCalendrier" onMouseClicked="#goCalendrier"
                              alignment="CENTER_LEFT" spacing="10"
                              style="-fx-padding: 10 12; -fx-background-radius: 8; -fx-cursor: hand;">
                            <Label text="• Mon calendrier" style="-fx-text-fill: #b0c4d4; -fx-font-size: 13px;"/>
                        </HBox>
                    </VBox>
                </VBox>

                <VBox spacing="2">
                    <HBox fx:id="navDossiers" onMouseClicked="#toggleDossiersMenu"
                          alignment="CENTER_LEFT" spacing="12"
                          style="-fx-padding: 12 14; -fx-background-radius: 10; -fx-cursor: hand;">
                        <Label text="🗂️" style="-fx-font-size: 15px;"/>
                        <Label text="Dossiers médicaux" style="-fx-text-fill: white; -fx-font-size: 14px;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="arrowDossiers" text="▶" style="-fx-text-fill: #6a8a9a; -fx-font-size: 10px;"/>
                    </HBox>
                    <VBox fx:id="submenuDossiers" spacing="2" style="-fx-padding: 4 0 4 20;">
                        <HBox fx:id="navConsulterDossiers" onMouseClicked="#goConsulterDossiers"
                              alignment="CENTER_LEFT" spacing="10"
                              style="-fx-padding: 10 12; -fx-background-radius: 8; -fx-cursor: hand;">
                            <Label text="• Consulter dossiers" style="-fx-text-fill: #b0c4d4; -fx-font-size: 13px;"/>
                        </HBox>
                        <HBox fx:id="navNouveauDossier" onMouseClicked="#goNouveauDossier"
                              alignment="CENTER_LEFT" spacing="10"
                              style="-fx-padding: 10 12; -fx-background-radius: 8; -fx-cursor: hand;">
                            <Label text="• Nouveau dossier" style="-fx-text-fill: #b0c4d4; -fx-font-size: 13px;"/>
                        </HBox>
                    </VBox>
                </VBox>

                <HBox fx:id="navActivites" onMouseClicked="#goActivites"
                      alignment="CENTER_LEFT" spacing="12"
                      style="-fx-padding: 12 14; -fx-background-radius: 10; -fx-cursor: hand;">
                    <Label text="⚡" style="-fx-font-size: 15px;"/>
                    <Label text="Activités" style="-fx-text-fill: white; -fx-font-size: 14px;"/>
                </HBox>

                <HBox fx:id="navRessources" onMouseClicked="#goRessources"
                      alignment="CENTER_LEFT" spacing="12"
                      style="-fx-padding: 12 14; -fx-background-radius: 10; -fx-cursor: hand;">
                    <Label text="📚" style="-fx-font-size: 15px;"/>
                    <Label text="Ressources" style="-fx-text-fill: white; -fx-font-size: 14px;"/>
                </HBox>

                <HBox fx:id="navStats" onMouseClicked="#goStats"
                      alignment="CENTER_LEFT" spacing="12"
                      style="-fx-padding: 12 14; -fx-background-radius: 10; -fx-cursor: hand;">
                    <Label text="📊" style="-fx-font-size: 15px;"/>
                    <Label text="Statistiques" style="-fx-text-fill: white; -fx-font-size: 14px;"/>
                </HBox>

            </VBox>

            <Region VBox.vgrow="ALWAYS"/>

            <!-- APERÇU RAPIDE -->
            <VBox spacing="14" style="-fx-padding: 20; -fx-background-color: #154a5f;">
                <Label text="APERÇU RAPIDE" style="-fx-text-fill: #6a8a9a; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label text="Patients actifs" style="-fx-text-fill: #b0c4d4; -fx-font-size: 13px;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="sidebarPatientsCount" text="24" style="-fx-text-fill: #50C878; -fx-font-size: 16px; -fx-font-weight: bold;"/>
                </HBox>
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label text="RDV aujourd'hui" style="-fx-text-fill: #b0c4d4; -fx-font-size: 13px;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="sidebarRdvToday" text="5" style="-fx-text-fill: #97BBE4; -fx-font-size: 16px; -fx-font-weight: bold;"/>
                </HBox>
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label text="Dossiers total" style="-fx-text-fill: #b0c4d4; -fx-font-size: 13px;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="sidebarDossiersTotal" text="42" style="-fx-text-fill: #F39C12; -fx-font-size: 16px; -fx-font-weight: bold;"/>
                </HBox>
            </VBox>

            <!-- ✅ PROFIL + BOUTON 3 POINTS -->
            <VBox spacing="10" style="-fx-padding: 16 16 20 16;
                                      -fx-border-color: #2a5a6f; -fx-border-width: 1 0 0 0;">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <StackPane>
                        <Circle radius="20" style="-fx-fill: #2a5a6f;"/>
                        <Label fx:id="avatarPsy" text="PS"
                               style="-fx-text-fill: white; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                    </StackPane>
                    <VBox spacing="2" HBox.hgrow="ALWAYS">
                        <Label fx:id="lblPsyName" text=""
                               style="-fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold;"/>
                        <Label fx:id="lblPsyRole" text="Psychologue"
                               style="-fx-text-fill: #6a8a9a; -fx-font-size: 11px;"/>
                    </VBox>
                    <!-- ✅ Bouton 3 points -->
                    <Button fx:id="menuButton" text="⋮" onAction="#onMenuClicked"
                            style="-fx-background-color: rgba(255,255,255,0.1);
                                   -fx-text-fill: white; -fx-background-radius: 50;
                                   -fx-font-size: 18px; -fx-font-weight: bold;
                                   -fx-padding: 2 10; -fx-cursor: hand;
                                   -fx-min-width: 32; -fx-min-height: 32;"/>
                </HBox>
            </VBox>

        </VBox>
    </left>

    <!-- ================= CONTENU PRINCIPAL ================= -->
    <center>
        <VBox spacing="0" style="-fx-background-color: #F0F4F8;">

            <!-- TOP BAR -->
            <HBox alignment="CENTER_LEFT" spacing="15"
                  style="-fx-background-color: white; -fx-padding: 16 28;
                         -fx-border-color: #E8ECF0; -fx-border-width: 0 0 1 0;">
                <Label fx:id="pageTitle" text="Tableau de bord"
                       style="-fx-text-fill: #1a4a5f; -fx-font-size: 22px; -fx-font-weight: bold;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <HBox alignment="CENTER" spacing="12">
                    <Label fx:id="currentDate" style="-fx-text-fill: #5A6C7D; -fx-font-size: 13px;"/>
                    <Button fx:id="notifBtn" text="🔔" onAction="#showNotifications"
                            style="-fx-background-color: transparent; -fx-text-fill: #5A6C7D;
                                   -fx-cursor: hand; -fx-font-size: 18px; -fx-padding: 6;"/>
                </HBox>
            </HBox>

            <!-- CONTENU SCROLLABLE -->
            <ScrollPane fitToWidth="true"
                        style="-fx-background-color: transparent; -fx-background: transparent;"
                        VBox.vgrow="ALWAYS">
                <VBox spacing="25" style="-fx-padding: 28 32 32 32;">

                    <!-- BANNIÈRE -->
                    <HBox style="-fx-background-color: #1a4a5f; -fx-background-radius: 24; -fx-padding: 32 38;"
                          alignment="CENTER_LEFT">
                        <VBox spacing="12" HBox.hgrow="ALWAYS">
                            <Label text="Bienvenue 👩‍⚕️"
                                   style="-fx-text-fill: #b0c4d4; -fx-font-size: 16px; -fx-font-weight: bold;"/>
                            <Label text="Prenez soin de vos patients avec sérénité"
                                   style="-fx-text-fill: white; -fx-font-size: 26px; -fx-font-weight: bold;"/>
                            <Label text="Consultez votre agenda, suivez vos dossiers et organisez vos activités."
                                   style="-fx-text-fill: #b0c4d4; -fx-font-size: 14px;" wrapText="true"/>
                        </VBox>
                        <Label text="🌿" style="-fx-font-size: 80px; -fx-opacity: 0.2;"/>
                    </HBox>

                    <!-- CARTES STATS -->
                    <HBox spacing="20">
                        <VBox spacing="14" HBox.hgrow="ALWAYS"
                              style="-fx-background-color: white; -fx-background-radius: 18;
                                     -fx-padding: 20; -fx-border-color: #E8ECF0; -fx-border-width: 1;">
                            <Label text="📅  Rendez-vous aujourd'hui" style="-fx-text-fill: #5A6C7D; -fx-font-size: 13px;"/>
                            <Label fx:id="rdvCount" text="5" style="-fx-text-fill: #1a4a5f; -fx-font-size: 38px; -fx-font-weight: bold;"/>
                            <Label text="vs 3 hier" style="-fx-text-fill: #50C878; -fx-font-size: 12px;"/>
                        </VBox>
                        <VBox spacing="14" HBox.hgrow="ALWAYS"
                              style="-fx-background-color: white; -fx-background-radius: 18;
                                     -fx-padding: 20; -fx-border-color: #E8ECF0; -fx-border-width: 1;">
                            <Label text="🗂️  Dossiers actifs" style="-fx-text-fill: #5A6C7D; -fx-font-size: 13px;"/>
                            <Label fx:id="dossierCount" text="20" style="-fx-text-fill: #1a4a5f; -fx-font-size: 38px; -fx-font-weight: bold;"/>
                            <Label text="+4 ce mois" style="-fx-text-fill: #50C878; -fx-font-size: 12px;"/>
                        </VBox>
                        <VBox spacing="14" HBox.hgrow="ALWAYS"
                              style="-fx-background-color: white; -fx-background-radius: 18;
                                     -fx-padding: 20; -fx-border-color: #E8ECF0; -fx-border-width: 1;">
                            <Label text="⚡  Activités récentes" style="-fx-text-fill: #5A6C7D; -fx-font-size: 13px;"/>
                            <Label fx:id="activiteCount" text="8" style="-fx-text-fill: #1a4a5f; -fx-font-size: 38px; -fx-font-weight: bold;"/>
                            <Label text="Cette semaine" style="-fx-text-fill: #97BBE4; -fx-font-size: 12px;"/>
                        </VBox>
                        <VBox spacing="14" HBox.hgrow="ALWAYS"
                              style="-fx-background-color: white; -fx-background-radius: 18;
                                     -fx-padding: 20; -fx-border-color: #E8ECF0; -fx-border-width: 1;">
                            <Label text="⭐  Satisfaction" style="-fx-text-fill: #5A6C7D; -fx-font-size: 13px;"/>
                            <Label text="98%" style="-fx-text-fill: #F39C12; -fx-font-size: 38px; -fx-font-weight: bold;"/>
                            <Label text="+2% ce trimestre" style="-fx-text-fill: #50C878; -fx-font-size: 12px;"/>
                        </VBox>
                    </HBox>

                    <!-- ACTIONS RAPIDES -->
                    <VBox spacing="15"
                          style="-fx-background-color: white; -fx-background-radius: 18;
                                 -fx-padding: 22; -fx-border-color: #E8ECF0; -fx-border-width: 1;">
                        <Label text="⚡ Actions rapides"
                               style="-fx-text-fill: #1a4a5f; -fx-font-size: 18px; -fx-font-weight: bold;"/>
                        <HBox spacing="15">
                            <Button text="📅 Nouveau rendez-vous" onAction="#goCalendrier"
                                    style="-fx-background-color: #1a4a5f; -fx-text-fill: white;
                                           -fx-background-radius: 25; -fx-padding: 10 22; -fx-cursor: hand;"/>
                            <Button text="🗂️ Nouveau dossier" onAction="#goNouveauDossier"
                                    style="-fx-background-color: #2c6e8a; -fx-text-fill: white;
                                           -fx-background-radius: 25; -fx-padding: 10 22; -fx-cursor: hand;"/>
                            <Button text="📊 Voir statistiques" onAction="#goStats"
                                    style="-fx-background-color: #34495E; -fx-text-fill: white;
                                           -fx-background-radius: 25; -fx-padding: 10 22; -fx-cursor: hand;"/>
                        </HBox>
                    </VBox>

                </VBox>
            </ScrollPane>
        </VBox>
    </center>
</BorderPane>
