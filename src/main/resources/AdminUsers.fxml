<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.image.ImageView?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="Controllor.ControllerAdminUsers"
            prefWidth="1100" prefHeight="700"
            style="-fx-background-color: #F4F8FF;">

    <!-- ÔòÉÔòÉÔòÉ SIDEBAR ÔòÉÔòÉÔòÉ -->
    <left>
        <VBox prefWidth="240" prefHeight="700" style="-fx-background-color: #2C3E50;">
            <HBox alignment="CENTER_LEFT" spacing="10"
                  style="-fx-padding: 22 16 18 16; -fx-border-color: transparent transparent rgba(255,255,255,0.1) transparent; -fx-border-width: 0 0 1 0;">
                <ImageView fx:id="logoImage" fitWidth="40" fitHeight="40" preserveRatio="true"/>
                <VBox spacing="2">
                    <Label text="MentalUp Admin" style="-fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                    <Label text="Administration" style="-fx-text-fill: rgba(255,255,255,0.5); -fx-font-size: 11px;"/>
                </VBox>
            </HBox>

            <VBox spacing="2" style="-fx-padding: 14 10 0 10;" VBox.vgrow="ALWAYS">
                <HBox alignment="CENTER_LEFT" spacing="12" onMouseClicked="#goToDashboard"
                      style="-fx-background-color: transparent; -fx-background-radius: 8; -fx-padding: 10 12; -fx-cursor: hand;">
                    <Label text="­ƒÅá" style="-fx-font-size: 15px; -fx-text-fill: rgba(255,255,255,0.75);"/>
                    <Label text="Tableau de bord" style="-fx-text-fill: rgba(255,255,255,0.75); -fx-font-size: 13px;"/>
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="12"
                      style="-fx-background-color: #8E44AD; -fx-background-radius: 8; -fx-padding: 10 12; -fx-cursor: hand;">
                    <Label text="­ƒæÑ" style="-fx-font-size: 15px; -fx-text-fill: white;"/>
                    <Label text="Utilisateurs" style="-fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold;"/>
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="12" onMouseClicked="#goToSuivi"
                      style="-fx-background-color: transparent; -fx-background-radius: 8; -fx-padding: 10 12; -fx-cursor: hand;">
                    <Label text="­ƒôê" style="-fx-font-size: 15px; -fx-text-fill: rgba(255,255,255,0.75);"/>
                    <Label text="Suivi Global" style="-fx-text-fill: rgba(255,255,255,0.75); -fx-font-size: 13px;"/>
                </HBox>
            </VBox>

            <HBox alignment="CENTER_LEFT" spacing="10" onMouseClicked="#handleLogout"
                  style="-fx-padding: 16 14; -fx-cursor: hand; -fx-border-color: rgba(255,255,255,0.1) transparent transparent transparent; -fx-border-width: 1 0 0 0;">
                <Label text="­ƒÜ¬" style="-fx-font-size: 15px; -fx-text-fill: rgba(255,255,255,0.6);"/>
                <Label text="D├®connexion" style="-fx-text-fill: rgba(255,255,255,0.6); -fx-font-size: 13px;"/>
            </HBox>
        </VBox>
    </left>

    <!-- ÔòÉÔòÉÔòÉ CONTENU PRINCIPAL ÔòÉÔòÉÔòÉ -->
    <center>
        <VBox spacing="0" style="-fx-background-color: #F4F8FF;">

            <!-- Barre titre -->
            <HBox alignment="CENTER_LEFT" spacing="12"
                  style="-fx-background-color: white; -fx-padding: 18 28; -fx-border-color: transparent transparent #E8EFF6 transparent; -fx-border-width: 0 0 1 0;">
                <VBox spacing="3">
                    <Label text="­ƒæÑ  Gestion des Utilisateurs"
                           style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #2C3E50;"/>
                    <Label fx:id="lblTotalUsers" text="0 utilisateurs"
                           style="-fx-font-size: 12px; -fx-text-fill: #7A9CB8;"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>

                <!-- ­ƒöÑ NOUVEAU BOUTON CORBEILLE ­ƒöÑ -->
                <Button text="­ƒùæ´©Å Corbeille" onAction="#showDeletedUsers"
                        style="-fx-background-color: #E74C3C; -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 20; -fx-padding: 8 20; -fx-cursor: hand;"/>

                <!-- Vue Switch (optionnel) -->
                <ToggleButton fx:id="toggleViewBtn" text="­ƒâÅ Vue Cartes" onAction="#toggleView"
                              style="-fx-background-color: #8E44AD20; -fx-text-fill: #8E44AD; -fx-border-color: #8E44AD; -fx-border-radius: 20; -fx-background-radius: 20; -fx-padding: 6 14;"/>

                <!-- Recherche -->
                <HBox alignment="CENTER_LEFT" spacing="8"
                      style="-fx-background-color: #F0F6FF; -fx-border-color: #C8DDF0; -fx-border-radius: 20; -fx-background-radius: 20; -fx-padding: 6 14; -fx-pref-width: 220;">
                    <Label text="­ƒöì" style="-fx-font-size: 13px; -fx-text-fill: #7A9CB8;"/>
                    <TextField fx:id="txtSearch" promptText="Rechercher..." onKeyReleased="#handleSearch"
                               style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-font-size: 13px; -fx-pref-width: 160;"/>
                </HBox>

                <Button text="+ Nouvel utilisateur" onAction="#handleAdd"
                        style="-fx-background-color: #8E44AD; -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 20; -fx-padding: 8 20; -fx-cursor: hand;"/>
            </HBox>

            <!-- Filtres r├┤le -->
            <HBox spacing="8" style="-fx-padding: 16 24 0 24;">
                <Button fx:id="filterAll" text="Tous" onAction="#filterAll"
                        style="-fx-background-color: #8E44AD; -fx-text-fill: white; -fx-background-radius: 15; -fx-padding: 5 16; -fx-font-size: 12px; -fx-cursor: hand;"/>
                <Button text="├ëtudiants" onAction="#filterEtudiants"
                        style="-fx-background-color: #E8F5FF; -fx-text-fill: #2980B9; -fx-border-color: #AED6F1; -fx-border-radius: 15; -fx-background-radius: 15; -fx-padding: 5 16; -fx-font-size: 12px; -fx-cursor: hand;"/>
                <Button text="Psychologues" onAction="#filterPsychologues"
                        style="-fx-background-color: #E8FFF0; -fx-text-fill: #1E8449; -fx-border-color: #A9DFBF; -fx-border-radius: 15; -fx-background-radius: 15; -fx-padding: 5 16; -fx-font-size: 12px; -fx-cursor: hand;"/>
                <Button text="Admins" onAction="#filterAdmins"
                        style="-fx-background-color: #FFF0F0; -fx-text-fill: #C0392B; -fx-border-color: #F1948A; -fx-border-radius: 15; -fx-background-radius: 15; -fx-padding: 5 16; -fx-font-size: 12px; -fx-cursor: hand;"/>
            </HBox>

            <!-- ScrollPane avec FlowPane de cartes -->
            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent; -fx-background: transparent;">
                <FlowPane fx:id="cardContainer"
                          hgap="20" vgap="20"
                          style="-fx-padding: 24;"
                          alignment="TOP_LEFT"/>
            </ScrollPane>

            <!-- Pagination -->
            <HBox alignment="CENTER" spacing="12" style="-fx-padding: 16 0 20 0;">
                <Button text="ÔùÇ Pr├®c├®dent" fx:id="btnPrev" onAction="#prevPage"
                        style="-fx-background-color: white; -fx-border-color: #C8DDF0; -fx-border-radius: 8; -fx-background-radius: 8; -fx-text-fill: #2C5F8A; -fx-padding: 6 14; -fx-font-size: 12px; -fx-cursor: hand;"/>
                <Label fx:id="lblPage" text="Page 1 sur 1"
                       style="-fx-font-size: 12px; -fx-text-fill: #7A9CB8;"/>
                <Button text="Suivant ÔûÂ" fx:id="btnNext" onAction="#nextPage"
                        style="-fx-background-color: white; -fx-border-color: #C8DDF0; -fx-border-radius: 8; -fx-background-radius: 8; -fx-text-fill: #2C5F8A; -fx-padding: 6 14; -fx-font-size: 12px; -fx-cursor: hand;"/>
            </HBox>
        </VBox>
    </center>
</BorderPane>
