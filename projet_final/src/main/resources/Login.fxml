<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.shape.*?>

<AnchorPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="Controllor.LoginController"
            prefWidth="900" prefHeight="600"
            style="-fx-background-color: #F0F4F8;">

    <HBox AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0"
          AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">

        <!-- ═══ PANNEAU GAUCHE BLEU ═══ -->
        <VBox prefWidth="360" alignment="CENTER" spacing="20"
              style="-fx-background-color: #2C5F8A; -fx-padding: 50 36;">

            <!-- Logo cercle -->
            <StackPane prefWidth="116" prefHeight="116">
                <Circle radius="58"
                        style="-fx-fill: rgba(255,255,255,0.12);
                               -fx-stroke: rgba(255,255,255,0.3);
                               -fx-stroke-width: 2.5;"/>
                <ImageView fx:id="logoImage"
                           fitWidth="100" fitHeight="100"
                           preserveRatio="false"
                           smooth="true"/>
            </StackPane>

            <Label text="Mental Up"
                   style="-fx-text-fill: white; -fx-font-size: 28px; -fx-font-weight: bold;"/>
            <Label text="Bienvenue sur la plateforme&#10;de santé mentale."
                   style="-fx-text-fill: rgba(255,255,255,0.75); -fx-font-size: 13px;
                          -fx-text-alignment: center; -fx-alignment: center; -fx-wrap-text: true;"/>

            <VBox spacing="8" alignment="CENTER" style="-fx-padding: 12 0 0 0;">
                <!-- badge sécurisé -->
                <HBox alignment="CENTER" spacing="8"
                      style="-fx-background-color: rgba(255,255,255,0.12);
                             -fx-background-radius: 20; -fx-padding: 6 16;
                             -fx-border-color: rgba(255,255,255,0.2);
                             -fx-border-radius: 20; -fx-border-width: 1;">
                    <Label text="🔒" style="-fx-font-size: 13px;"/>
                    <Label text="Sécurisé" style="-fx-text-fill: rgba(255,255,255,0.85); -fx-font-size: 12px;"/>
                </HBox>
                <HBox alignment="CENTER" spacing="20">
                    <HBox alignment="CENTER" spacing="6"
                          style="-fx-background-color: rgba(255,255,255,0.12);
                                 -fx-background-radius: 20; -fx-padding: 6 14;
                                 -fx-border-color: rgba(255,255,255,0.2);
                                 -fx-border-radius: 20; -fx-border-width: 1;">
                        <Label text="⏱️" style="-fx-font-size: 13px;"/>
                        <Label text="24/7" style="-fx-text-fill: rgba(255,255,255,0.85); -fx-font-size: 12px;"/>
                    </HBox>
                    <HBox alignment="CENTER" spacing="6"
                          style="-fx-background-color: rgba(255,255,255,0.12);
                                 -fx-background-radius: 20; -fx-padding: 6 14;
                                 -fx-border-color: rgba(255,255,255,0.2);
                                 -fx-border-radius: 20; -fx-border-width: 1;">
                        <Label text="🤝" style="-fx-font-size: 13px;"/>
                        <Label text="Support" style="-fx-text-fill: rgba(255,255,255,0.85); -fx-font-size: 12px;"/>
                    </HBox>
                </HBox>
            </VBox>
        </VBox>

        <!-- ═══ PANNEAU DROIT FORMULAIRE ═══ -->
        <VBox HBox.hgrow="ALWAYS" alignment="CENTER"
              style="-fx-background-color: white; -fx-padding: 40 50;">

            <!-- Onglets -->
            <HBox spacing="0" style="-fx-border-color: transparent transparent #E0E7EF transparent;
                                     -fx-border-width: 0 0 2 0; -fx-padding: 0 0 0 0;">
                <Button fx:id="tabLogin" text="Connexion" onAction="#switchToLogin"
                        style="-fx-background-color: transparent; -fx-text-fill: #2C5F8A;
                               -fx-font-size: 14px; -fx-font-weight: bold;
                               -fx-padding: 10 20; -fx-cursor: hand;
                               -fx-border-color: transparent transparent #2C5F8A transparent;
                               -fx-border-width: 0 0 2.5 0;"/>
                <Button fx:id="tabRegister" text="S'inscrire" onAction="#switchToRegister"
                        style="-fx-background-color: transparent; -fx-text-fill: #7A9CB8;
                               -fx-font-size: 14px; -fx-padding: 10 20; -fx-cursor: hand;
                               -fx-border-color: transparent; -fx-border-width: 0;"/>
            </HBox>

            <VBox spacing="0" style="-fx-padding: 24 0 0 0;">

                <!-- FORMULAIRE LOGIN -->
                <VBox fx:id="loginForm" spacing="14" managed="true" visible="true">

                    <VBox spacing="5">
                        <Label text="EMAIL" style="-fx-font-size: 11px; -fx-font-weight: bold;
                                                   -fx-text-fill: #7A9CB8; -fx-letter-spacing: 1;"/>
                        <HBox alignment="CENTER_LEFT" spacing="10"
                              style="-fx-background-color: #F0F6FF;
                                     -fx-border-color: #C8DDF0; -fx-border-radius: 8;
                                     -fx-background-radius: 8; -fx-padding: 0 14; -fx-pref-height: 44;">
                            <Label text="✉" style="-fx-text-fill: #7A9CB8; -fx-font-size: 14px;"/>
                            <TextField fx:id="txtEmail" promptText="votre@email.com"
                                       style="-fx-background-color: transparent; -fx-border-color: transparent;
                                              -fx-font-size: 13px; -fx-text-fill: #2C3E50;"
                                       HBox.hgrow="ALWAYS"/>
                        </HBox>
                    </VBox>

                    <VBox spacing="5">
                        <Label text="MOT DE PASSE" style="-fx-font-size: 11px; -fx-font-weight: bold;
                                                          -fx-text-fill: #7A9CB8;"/>
                        <HBox alignment="CENTER_LEFT" spacing="10"
                              style="-fx-background-color: #F0F6FF;
                                     -fx-border-color: #C8DDF0; -fx-border-radius: 8;
                                     -fx-background-radius: 8; -fx-padding: 0 14; -fx-pref-height: 44;">
                            <Label text="🔒" style="-fx-text-fill: #7A9CB8; -fx-font-size: 13px;"/>
                            <PasswordField fx:id="txtPassword" promptText="••••••••"
                                           style="-fx-background-color: transparent; -fx-border-color: transparent;
                                                  -fx-font-size: 13px; -fx-text-fill: #2C3E50;"
                                           HBox.hgrow="ALWAYS"/>
                        </HBox>
                    </VBox>

                    <HBox alignment="CENTER_RIGHT">
                        <Hyperlink text="Mot de passe oublié ?"
                                   style="-fx-text-fill: #2C5F8A; -fx-font-size: 12px;"/>
                    </HBox>

                    <VBox spacing="5">
                        <Label text="COMMENT VOUS SENTEZ-VOUS AUJOURD'HUI ?"
                               style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #7A9CB8;"/>
                        <TextField promptText="Ex: Je suis stressé, fatigué, joyeux..."
                                   style="-fx-background-color: #F0F6FF;
                                          -fx-border-color: #C8DDF0; -fx-border-radius: 8;
                                          -fx-background-radius: 8; -fx-padding: 10 14;
                                          -fx-font-size: 13px; -fx-pref-height: 44;"/>
                        <Label text="Cette question remplace le CAPTCHA"
                               style="-fx-font-size: 11px; -fx-text-fill: #A0B4C8;"/>
                    </VBox>

                    <Label fx:id="lblError" text="" wrapText="true"
                           style="-fx-text-fill: #E74C3C; -fx-font-size: 12px;"/>

                    <Button text="➜  Se connecter" onAction="#handleLogin"
                            maxWidth="Infinity"
                            style="-fx-background-color: #2C5F8A; -fx-text-fill: white;
                                   -fx-font-size: 14px; -fx-font-weight: bold;
                                   -fx-pref-height: 44; -fx-background-radius: 8; -fx-cursor: hand;"/>
                </VBox>

                <!-- FORMULAIRE REGISTER -->
                <VBox fx:id="registerForm" spacing="14" managed="false" visible="false">

                    <HBox spacing="12">
                        <VBox spacing="5" HBox.hgrow="ALWAYS">
                            <Label text="PRÉNOM" style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #7A9CB8;"/>
                            <HBox alignment="CENTER_LEFT" spacing="10"
                                  style="-fx-background-color: #F0F6FF; -fx-border-color: #C8DDF0;
                                         -fx-border-radius: 8; -fx-background-radius: 8;
                                         -fx-padding: 0 14; -fx-pref-height: 42;">
                                <TextField fx:id="txtPrenom" promptText="Prénom"
                                           style="-fx-background-color: transparent; -fx-border-color: transparent;
                                                  -fx-font-size: 13px;" HBox.hgrow="ALWAYS"/>
                            </HBox>
                        </VBox>
                        <VBox spacing="5" HBox.hgrow="ALWAYS">
                            <Label text="NOM" style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #7A9CB8;"/>
                            <HBox alignment="CENTER_LEFT" spacing="10"
                                  style="-fx-background-color: #F0F6FF; -fx-border-color: #C8DDF0;
                                         -fx-border-radius: 8; -fx-background-radius: 8;
                                         -fx-padding: 0 14; -fx-pref-height: 42;">
                                <TextField fx:id="txtNom" promptText="Nom"
                                           style="-fx-background-color: transparent; -fx-border-color: transparent;
                                                  -fx-font-size: 13px;" HBox.hgrow="ALWAYS"/>
                            </HBox>
                        </VBox>
                    </HBox>

                    <VBox spacing="5">
                        <Label text="EMAIL" style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #7A9CB8;"/>
                        <HBox alignment="CENTER_LEFT" spacing="10"
                              style="-fx-background-color: #F0F6FF; -fx-border-color: #C8DDF0;
                                     -fx-border-radius: 8; -fx-background-radius: 8;
                                     -fx-padding: 0 14; -fx-pref-height: 42;">
                            <Label text="✉" style="-fx-text-fill: #7A9CB8; -fx-font-size: 14px;"/>
                            <TextField fx:id="txtEmailReg" promptText="votre@email.com"
                                       style="-fx-background-color: transparent; -fx-border-color: transparent;
                                              -fx-font-size: 13px;" HBox.hgrow="ALWAYS"/>
                        </HBox>
                    </VBox>

                    <VBox spacing="5">
                        <Label text="MOT DE PASSE" style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #7A9CB8;"/>
                        <HBox alignment="CENTER_LEFT" spacing="10"
                              style="-fx-background-color: #F0F6FF; -fx-border-color: #C8DDF0;
                                     -fx-border-radius: 8; -fx-background-radius: 8;
                                     -fx-padding: 0 14; -fx-pref-height: 42;">
                            <Label text="🔒" style="-fx-text-fill: #7A9CB8; -fx-font-size: 13px;"/>
                            <PasswordField fx:id="txtPasswordReg" promptText="Min. 8 caractères"
                                           style="-fx-background-color: transparent; -fx-border-color: transparent;
                                                  -fx-font-size: 13px;" HBox.hgrow="ALWAYS"/>
                        </HBox>
                    </VBox>

                    <VBox spacing="5">
                        <Label text="RÔLE" style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #7A9CB8;"/>
                        <HBox spacing="10">
                            <Button fx:id="btnEtudiant" text="Étudiant" onAction="#selectEtudiant"
                                    HBox.hgrow="ALWAYS" maxWidth="Infinity"
                                    style="-fx-background-color: #2C5F8A; -fx-text-fill: white;
                                           -fx-background-radius: 8; -fx-pref-height: 40;
                                           -fx-font-size: 13px; -fx-cursor: hand;"/>
                            <Button fx:id="btnPsy" text="Psychologue" onAction="#selectPsy"
                                    HBox.hgrow="ALWAYS" maxWidth="Infinity"
                                    style="-fx-background-color: #F0F6FF; -fx-text-fill: #7A9CB8;
                                           -fx-border-color: #C8DDF0; -fx-border-radius: 8;
                                           -fx-background-radius: 8; -fx-pref-height: 40;
                                           -fx-font-size: 13px; -fx-cursor: hand;"/>
                        </HBox>
                    </VBox>

                    <Label fx:id="lblErrorReg" text="" wrapText="true"
                           style="-fx-text-fill: #E74C3C; -fx-font-size: 12px;"/>

                    <Button text="★  Créer mon compte" onAction="#handleRegister"
                            maxWidth="Infinity"
                            style="-fx-background-color: #2C5F8A; -fx-text-fill: white;
                                   -fx-font-size: 14px; -fx-font-weight: bold;
                                   -fx-pref-height: 44; -fx-background-radius: 8; -fx-cursor: hand;"/>
                </VBox>

            </VBox>
        </VBox>
    </HBox>
</AnchorPane>
