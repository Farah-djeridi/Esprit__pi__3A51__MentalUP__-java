                                         -fx-padding: 14;">
                                <Label text="✅ Objectifs atteints"
                                       style="-fx-text-fill: #dbe8f8;
                                              -fx-font-size: 11px;
                                              -fx-font-weight: 700;"/>
                                <Label fx:id="objectifsAtteintsLabel" text="0"
                                       style="-fx-text-fill: white;
                                              -fx-font-size: 24px;
                                              -fx-font-weight: 900;"/>
                            </VBox>

                            <VBox spacing="6" HBox.hgrow="ALWAYS"
                                  style="-fx-background-color: linear-gradient(to bottom right, #3f75b8, #4d87c8);
