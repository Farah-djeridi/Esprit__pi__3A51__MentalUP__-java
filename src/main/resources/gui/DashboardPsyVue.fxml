<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<?import javafx.scene.shape.*?>

<?import javafx.scene.image.ImageView?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="controllers.DashboardPsyController"
            prefWidth="1100" prefHeight="700">

    <left>
        <VBox prefWidth="270" style="-fx-background-color: #1a4a5f;">

            <!-- LOGO + BRAND -->
            <HBox alignment="CENTER_LEFT" spacing="12" style="-fx-padding: 26 20 22 20;">
                <StackPane>
                    <ImageView fx:id="logoImage" fitWidth="40" fitHeight="40" preserveRatio="true"/>
                </StackPane>
                <VBox spacing="3">
                    <Label text="MentalUp" textFill="white" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
                    <Label text="Espace Psychologue" textFill="#8ca3b3" style="-fx-font-size: 12px;"/>
                    <Label fx:id="currentDate" textFill="#8ca3b3" style="-fx-font-size: 11px;"/>
                </VBox>
            </HBox>

            <Separator style="-fx-background-color: #2a5a6f;"/>

            <!-- MENU -->
            <VBox spacing="4" style="-fx-padding: 16 14 0 14;" VBox.vgrow="ALWAYS">

                <Label text="MENU PRINCIPAL" textFill="#6a8a9a"
                       style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-padding: 0 0 8 8;"/>

                <!-- Accueil (ACTIVE on this page) -->
                <HBox fx:id="navHome" onMouseClicked="#goHome"
                      alignment="CENTER_LEFT" spacing="10"
                      style="-fx-padding: 11 14; -fx-background-radius: 10; -fx-cursor: hand;
                             -fx-background-color: rgba(255,255,255,0.12);">
                    <Label text="🏠" style="-fx-font-size: 14px;"/>
                    <Label text="Accueil" textFill="white" style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
                </HBox>

                <!-- Rendez-vous -->
                <VBox spacing="2">
                    <HBox fx:id="navRdv" onMouseClicked="#toggleRdvMenu"
                          alignment="CENTER_LEFT" spacing="10"
                          style="-fx-padding: 11 14; -fx-background-radius: 10; -fx-cursor: hand;">
                        <Label text="📅" style="-fx-font-size: 14px;"/>
                        <Label text="Rendez-vous" textFill="white" style="-fx-font-size: 14px;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="arrowRdv" text="▶" textFill="#6a8a9a" style="-fx-font-size: 9px;"/>
                    </HBox>
                    <VBox fx:id="submenuRdv" spacing="2" style="-fx-padding: 4 0 4 24;">
                        <HBox fx:id="navVoirRdv" onMouseClicked="#goVoirRendezVous"
                              alignment="CENTER_LEFT"
                              style="-fx-padding: 9 12; -fx-background-radius: 8; -fx-cursor: hand;">
                            <Label text="• Voir les rendez-vous" textFill="#b0c4d4" style="-fx-font-size: 13px;"/>
                        </HBox>
                        <HBox fx:id="navCalendrier" onMouseClicked="#goCalendrier"
                              alignment="CENTER_LEFT"
                              style="-fx-padding: 9 12; -fx-background-radius: 8; -fx-cursor: hand;">
                            <Label text="• Mon calendrier" textFill="#b0c4d4" style="-fx-font-size: 13px;"/>
                        </HBox>
                    </VBox>
                </VBox>

                <!-- Dossiers médicaux -->
                <VBox spacing="2">
                    <HBox fx:id="navDossiers" onMouseClicked="#toggleDossiersMenu"
                          alignment="CENTER_LEFT" spacing="10"
                          style="-fx-padding: 11 14; -fx-background-radius: 10; -fx-cursor: hand;">
                        <Label text="📁" style="-fx-font-size: 14px;"/>
                        <Label text="Dossiers médicaux" textFill="white" style="-fx-font-size: 14px;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="arrowDossiers" text="▶" textFill="#6a8a9a" style="-fx-font-size: 9px;"/>
                    </HBox>
                    <VBox fx:id="submenuDossiers" spacing="2" style="-fx-padding: 4 0 4 24;">
                        <HBox fx:id="navConsulterDossiers" onMouseClicked="#goConsulterDossiers"
                              alignment="CENTER_LEFT"
                              style="-fx-padding: 9 12; -fx-background-radius: 8; -fx-cursor: hand;">
                            <Label text="• Consulter dossiers" textFill="#b0c4d4" style="-fx-font-size: 13px;"/>
                        </HBox>
                        <HBox fx:id="navNouveauDossier" onMouseClicked="#goNouveauDossier"
                              alignment="CENTER_LEFT"
                              style="-fx-padding: 9 12; -fx-background-radius: 8; -fx-cursor: hand;">
                            <Label text="• Nouveau dossier" textFill="#b0c4d4" style="-fx-font-size: 13px;"/>
                        </HBox>
                    </VBox>
                </VBox>

                <!-- Activités -->
                <HBox fx:id="navActivites" onMouseClicked="#goActivites"
                      alignment="CENTER_LEFT" spacing="10"
                      style="-fx-padding: 11 14; -fx-background-radius: 10; -fx-cursor: hand;">
                    <Label text="🎯" style="-fx-font-size: 14px;"/>
                    <Label text="Activités" textFill="white" style="-fx-font-size: 14px;"/>
                </HBox>

                <!-- Ressources -->
                <HBox fx:id="navRessources" onMouseClicked="#goRessources"
                      alignment="CENTER_LEFT" spacing="10"
                      style="-fx-padding: 11 14; -fx-background-radius: 10; -fx-cursor: hand;">
                    <Label text="📚" style="-fx-font-size: 14px;"/>
                    <Label text="Ressources" textFill="white" style="-fx-font-size: 14px;"/>
                </HBox>

                <!-- Statistiques -->
                <HBox fx:id="navStats" onMouseClicked="#goStats"
                      alignment="CENTER_LEFT" spacing="10"
                      style="-fx-padding: 11 14; -fx-background-radius: 10; -fx-cursor: hand;">
                    <Label text="📊" style="-fx-font-size: 14px;"/>
                    <Label text="Statistiques" textFill="white" style="-fx-font-size: 14px;"/>
                </HBox>
            </VBox>

            <Region VBox.vgrow="ALWAYS"/>

            <!-- APERÇU RAPIDE -->
            <VBox spacing="12" style="-fx-padding: 18 18 18 18; -fx-background-color: #154a5f;">
                <Label text="APERÇU RAPIDE" textFill="#6a8a9a"
                       style="-fx-font-size: 10px; -fx-font-weight: bold;"/>
                <HBox alignment="CENTER_LEFT">
                    <Label text="Patients actifs" textFill="#b0c4d4" style="-fx-font-size: 12px;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="sidebarPatientsCount" text="24" textFill="#50C878"
                           style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
                </HBox>
                <HBox alignment="CENTER_LEFT">
                    <Label text="RDV aujourd'hui" textFill="#b0c4d4" style="-fx-font-size: 12px;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="sidebarRdvToday" text="0" textFill="#97BBE4"
                           style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
                </HBox>
                <HBox alignment="CENTER_LEFT">
                    <Label text="Dossiers total" textFill="#b0c4d4" style="-fx-font-size: 12px;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="sidebarDossiersTotal" text="42" textFill="#F39C12"
                           style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
                </HBox>
            </VBox>

            <!-- PROFIL + LOGOUT -->
            <VBox spacing="12" style="-fx-padding: 16 18 20 18; -fx-border-color: #2a5a6f; -fx-border-width: 1 0 0 0;">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Circle radius="20" fill="#2a5a6f"/>
                    <VBox spacing="2">
                        <Label text="Psychologue" textFill="white"
                               style="-fx-font-size: 13px; -fx-font-weight: bold;"/>
                        <Label text="Compte professionnel" textFill="#6a8a9a"
                               style="-fx-font-size: 10px;"/>
                    </VBox>
                </HBox>
                <Button fx:id="logoutBtn" text="Déconnexion" onAction="#logout"
                        maxWidth="Infinity"
                        style="-fx-background-color: transparent; -fx-text-fill: #b0c4d4;
                               -fx-border-color: #e74c3c; -fx-border-width: 1.5;
                               -fx-background-radius: 8; -fx-border-radius: 8;
                               -fx-padding: 9; -fx-cursor: hand; -fx-font-size: 12px;"/>
            </VBox>
        </VBox>
    </left>


    <center>
        <VBox spacing="0" style="-fx-background-color: #F0F4F8;">
            <!-- TOP BAR / ACTION BAR -->
            <HBox alignment="CENTER_LEFT" spacing="20" 
                  style="-fx-background-color: white; -fx-padding: 15 32; -fx-border-color: #E8ECF0; -fx-border-width: 0 0 1 0;">
                <VBox spacing="2">
                    <Label text="Tableau de Bord" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1a4a5f;"/>
                    <Label text="Vue d'ensemble de votre activité" style="-fx-font-size: 11px; -fx-text-fill: #94a3b8;"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <MenuButton text="📄 Exporter" 
                            style="-fx-background-color: #1a4a5f; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 5 15; -fx-cursor: hand;">
                    <items>
                        <MenuItem text="Dossier Médical (Patient)" onAction="#handleExportPatientPDF"/>
                        <MenuItem text="Rapport des Rendez-vous" onAction="#handleExportPlanningPDF"/>
                    </items>
                </MenuButton>
            </HBox>



            <!-- SCROLLABLE CONTENT -->
            <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;"
                        VBox.vgrow="ALWAYS">

                <VBox spacing="25" style="-fx-padding: 28 32 32 32;">

                    <!-- BANNIÈRE DE BIENVENUE -->
                    <HBox style="-fx-background-color: #1a4a5f; -fx-background-radius: 24; -fx-padding: 32 38;"
                          alignment="CENTER_LEFT">
                        <VBox spacing="12" HBox.hgrow="ALWAYS">
                            <Label text="Bienvenue" textFill="#b0c4d4" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
                            <Label text="Prenez soin de vos patients avec sérénité" textFill="white" style="-fx-font-size: 26px; -fx-font-weight: bold;"/>
                            <Label text="Consultez votre agenda, suivez vos dossiers et organisez vos activités en un clin d'œil." textFill="#b0c4d4" style="-fx-font-size: 14px;" wrapText="true"/>
                        </VBox>
                    </HBox>

                    <!-- CARTES STATISTIQUES -->
                    <HBox spacing="20">

                        <VBox spacing="14" HBox.hgrow="ALWAYS"
                              style="-fx-background-color: white; -fx-background-radius: 18; -fx-padding: 20; -fx-border-color: #E8ECF0; -fx-border-width: 1;">
                            <Label text="Rendez-vous aujourd'hui" textFill="#5A6C7D" style="-fx-font-size: 14px;"/>
                            <Label fx:id="rdvCount" text="5" textFill="#1a4a5f" style="-fx-font-size: 38px; -fx-font-weight: bold;"/>
                            <Label text="vs 3 hier" textFill="#50C878" style="-fx-font-size: 12px;"/>
                        </VBox>

                        <VBox spacing="14" HBox.hgrow="ALWAYS"
                              style="-fx-background-color: white; -fx-background-radius: 18; -fx-padding: 20; -fx-border-color: #E8ECF0; -fx-border-width: 1;">
                            <Label text="Dossiers actifs" textFill="#5A6C7D" style="-fx-font-size: 14px;"/>
                            <Label fx:id="dossierCount" text="20" textFill="#1a4a5f" style="-fx-font-size: 38px; -fx-font-weight: bold;"/>
                            <Label text="+4 ce mois" textFill="#50C878" style="-fx-font-size: 12px;"/>
                        </VBox>

                        <VBox spacing="14" HBox.hgrow="ALWAYS"
                              style="-fx-background-color: white; -fx-background-radius: 18; -fx-padding: 20; -fx-border-color: #E8ECF0; -fx-border-width: 1;">
                            <Label text="Activités récentes" textFill="#5A6C7D" style="-fx-font-size: 14px;"/>
                            <Label fx:id="activiteCount" text="8" textFill="#1a4a5f" style="-fx-font-size: 38px; -fx-font-weight: bold;"/>
                            <Label text="Cette semaine" textFill="#97BBE4" style="-fx-font-size: 12px;"/>
                        </VBox>

                        <VBox spacing="14" HBox.hgrow="ALWAYS"
                              style="-fx-background-color: white; -fx-background-radius: 18; -fx-padding: 20; -fx-border-color: #E8ECF0; -fx-border-width: 1;">
                            <Label text="Satisfaction" textFill="#5A6C7D" style="-fx-font-size: 14px;"/>
                            <Label text="98%" textFill="#F39C12" style="-fx-font-size: 38px; -fx-font-weight: bold;"/>
                            <Label text="+2% ce trimestre" textFill="#50C878" style="-fx-font-size: 12px;"/>
                        </VBox>
                    </HBox>

                    <!-- SECTION RENDEZ-VOUS RÉCENTS -->
                    <VBox spacing="15"
                          style="-fx-background-color: white; -fx-background-radius: 18; -fx-padding: 22; -fx-border-color: #E8ECF0; -fx-border-width: 1;">

                        <HBox alignment="CENTER_LEFT">
                            <Label text="Prochains rendez-vous" textFill="#1a4a5f" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Button text="Voir tout" onAction="#goVoirRendezVous"
                                    style="-fx-background-color: transparent; -fx-text-fill: #1a4a5f; -fx-border-color: #1a4a5f; -fx-border-radius: 20; -fx-padding: 6 18; -fx-cursor: hand; -fx-font-size: 12px;"/>
                        </HBox>

                        <Separator style="-fx-background-color: #E8ECF0;"/>

                        <VBox spacing="12">
                            <Label text="Aucun rendez-vous programmé" textFill="#95A5A6" style="-fx-padding: 20; -fx-font-size: 14px;"/>
                        </VBox>
                    </VBox>

                    <!-- SECTION ACTIONS RAPIDES -->
                    <VBox spacing="15"
                          style="-fx-background-color: white; -fx-background-radius: 18; -fx-padding: 22; -fx-border-color: #E8ECF0; -fx-border-width: 1;">

                        <Label text="Actions rapides" textFill="#1a4a5f" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

                        <HBox spacing="15">
                            <Button text="Nouveau rendez-vous" onAction="#goCalendrier"
                                    style="-fx-background-color: #1a4a5f; -fx-text-fill: white; -fx-background-radius: 25; -fx-padding: 10 22; -fx-cursor: hand; -fx-font-size: 13px;"/>
                            <Button text="Nouveau dossier" onAction="#goNouveauDossier"
                                    style="-fx-background-color: #2c6e8a; -fx-text-fill: white; -fx-background-radius: 25; -fx-padding: 10 22; -fx-cursor: hand; -fx-font-size: 13px;"/>
                            <Button text="Voir statistiques" onAction="#goStats"
                                    style="-fx-background-color: #34495E; -fx-text-fill: white; -fx-background-radius: 25; -fx-padding: 10 22; -fx-cursor: hand; -fx-font-size: 13px;"/>
                        </HBox>
                    </VBox>

                </VBox>
            </ScrollPane>
        </VBox>
    </center>
</BorderPane>