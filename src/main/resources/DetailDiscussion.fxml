<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.image.ImageView?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="Controllors.ControllerDetailDiscussion"
            prefWidth="1024" prefHeight="650"
            style="-fx-background-color: linear-gradient(from 0% 0% to 100% 100%, #F4F8FF, #E8F0FE);">

    <!-- SIDEBAR (identique au forum) -->
    <left>
        <VBox prefWidth="240" prefHeight="700"
              style="-fx-background-color: linear-gradient(from 0% 0% to 0% 100%, #D6E8F7, #2C5F8A);">

            <!-- Logo / Brand -->
            <HBox alignment="CENTER_LEFT" spacing="10"
                  style="-fx-padding: 24 18 20 18;
                         -fx-border-color: transparent transparent rgba(255,255,255,0.12) transparent;
                         -fx-border-width: 0 0 1 0;">
                <StackPane>
                    <ImageView fx:id="logoImage" fitWidth="45" fitHeight="45" preserveRatio="true"/>
                </StackPane>
                <VBox spacing="2">
                    <Label text="MentalUp"
                           style="-fx-text-fill: #1A3A52; -fx-font-size: 16px;
                                  -fx-font-weight: bold;"/>
                    <Label text="Bien-être étudiant"
                           style="-fx-text-fill: #2C5F8A; -fx-font-size: 11px; -fx-font-weight: 600;"/>
                </VBox>
            </HBox>

            <!-- Navigation -->
            <VBox spacing="4" style="-fx-padding: 20 14 0 14;" VBox.vgrow="ALWAYS">

                <HBox alignment="CENTER_LEFT" spacing="12"
                      fx:id="navAccueil"
                      onMouseClicked="#onNavHomeClicked"
                      onMouseEntered="#onNavHoverEnter"
                      onMouseExited="#onNavHoverExit"
                      style="-fx-background-color: transparent;
                             -fx-background-radius: 8;
                             -fx-padding: 10 14;
                             -fx-cursor: hand;">
                    <Label text="🏠" style="-fx-font-size: 16px; -fx-text-fill: white;"/>
                    <Label text="Accueil" style="-fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: 500;"/>
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="12"
                      fx:id="navSuivi"
                      onMouseClicked="#onNavSuiviClicked"
                      onMouseEntered="#onNavHoverEnter"
                      onMouseExited="#onNavHoverExit"
                      style="-fx-background-color: transparent;
                             -fx-background-radius: 8;
                             -fx-padding: 10 14;
                             -fx-cursor: hand;">
                    <Label text="📈" style="-fx-font-size: 16px; -fx-text-fill: white;"/>
                    <Label text="Suivi Mental" style="-fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: 500;"/>
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="12"
                      fx:id="navRendezVous"
                      onMouseClicked="#onNavRendezVousClicked"
                      onMouseEntered="#onNavHoverEnter"
                      onMouseExited="#onNavHoverExit"
                      style="-fx-background-color: transparent;
                             -fx-background-radius: 8;
                             -fx-padding: 10 14;
                             -fx-cursor: hand;">
                    <Label text="📅" style="-fx-font-size: 16px; -fx-text-fill: white;"/>
                    <Label text="Rendez-vous" style="-fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: 500;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <StackPane style="-fx-background-color: #E74C3C;
                                     -fx-background-radius: 10; -fx-padding: 1 6;">
                        <Label fx:id="badgeRdv" text="3"
                               style="-fx-text-fill: white; -fx-font-size: 11px;
                                      -fx-font-weight: bold;"/>
                    </StackPane>
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="12"
                      fx:id="navForum"
                      onMouseClicked="#onNavForumClicked"
                      style="-fx-background-color: #1E4568;
                             -fx-background-radius: 8;
                             -fx-padding: 10 14;
                             -fx-cursor: hand;
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 5, 0, 0, 2);">
                    <Label text="💬" style="-fx-font-size: 16px; -fx-text-fill: white;"/>
                    <Label text="Forum" style="-fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="12"
                      fx:id="navActivites"
                      onMouseClicked="#onNavActivitesClicked"
                      onMouseEntered="#onNavHoverEnter"
                      onMouseExited="#onNavHoverExit"
                      style="-fx-background-color: transparent;
                             -fx-background-radius: 8;
                             -fx-padding: 10 14;
                             -fx-cursor: hand;">
                    <Label text="⚡" style="-fx-font-size: 16px; -fx-text-fill: white;"/>
                    <Label text="Activités" style="-fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: 500;"/>
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="12"
                      fx:id="navContenu"
                      onMouseClicked="#onNavContenuClicked"
                      onMouseEntered="#onNavHoverEnter"
                      onMouseExited="#onNavHoverExit"
                      style="-fx-background-color: transparent;
                             -fx-background-radius: 8;
                             -fx-padding: 10 14;
                             -fx-cursor: hand;">
                    <Label text="📚" style="-fx-font-size: 16px; -fx-text-fill: white;"/>
                    <Label text="Contenu" style="-fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: 500;"/>
                </HBox>

            </VBox>

            <!-- Profil utilisateur -->
            <VBox spacing="6" style="-fx-padding: 16 14 20 14; -fx-border-color: rgba(255,255,255,0.2); -fx-border-width: 1 0 0 0;">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Circle radius="18" style="-fx-fill: rgba(255,255,255,0.25);"/>
                    <Label fx:id="avatarInitials" text="SA"
                           style="-fx-text-fill: white; -fx-font-size: 13px;
                                  -fx-font-weight: bold; -fx-translate-x: -28;"/>
                    <VBox spacing="1">
                        <Label fx:id="labelUserName" text="Sophie Amara"
                               style="-fx-text-fill: white; -fx-font-size: 13px;
                                      -fx-font-weight: bold;"/>
                        <Label fx:id="userRoleLabel" text="L3 Informatique"
                               style="-fx-text-fill: rgba(255,255,255,0.65); -fx-font-size: 11px; -fx-font-weight: 500;"/>
                    </VBox>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button fx:id="logoutButton" text="⏻" onAction="#onLogout"
                            style="-fx-background-color: rgba(255,255,255,0.15);
                                   -fx-text-fill: white;
                                   -fx-background-radius: 6;
                                   -fx-padding: 5 10;
                                   -fx-cursor: hand;
                                   -fx-font-size: 12px;
                                   -fx-font-weight: bold;"/>
                </HBox>
            </VBox>

        </VBox>
    </left>

    <!-- CONTENU PRINCIPAL - DÉTAIL DISCUSSION -->
    <center>
        <VBox spacing="0" prefWidth="784" prefHeight="700"
              style="-fx-background-color: #F4F8FF;">

            <!-- Barre supérieure -->
            <HBox alignment="CENTER_LEFT" spacing="12"
                  style="-fx-background-color: rgba(255,255,255,0.95);
                         -fx-padding: 14 24;
                         -fx-border-color: transparent transparent rgba(151,187,228,0.2) transparent;
                         -fx-border-width: 0 0 1 0;">
                <VBox spacing="2">
                    <Label text="Discussion 💬"
                           style="-fx-font-size: 18px; -fx-font-weight: bold;
                                  -fx-text-fill: #2C3E50;"/>
                    <Label fx:id="labelDate" text=""
                           style="-fx-font-size: 12px; -fx-text-fill: #5A6C7D; -fx-font-weight: 500;"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="notifButton" text="🔔" onAction="#onNotifications"
                        style="-fx-background-color: rgba(151,187,228,0.15);
                               -fx-text-fill: #2C5F8A;
                               -fx-padding: 6;
                               -fx-cursor: hand;
                               -fx-font-size: 16px;
                               -fx-border-color: rgba(151,187,228,0.4);
                               -fx-border-radius: 50;
                               -fx-border-width: 1;
                               -fx-min-width: 32;
                               -fx-min-height: 32;"/>
            </HBox>

            <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent; -fx-padding: 0;">
                <content>
                    <VBox spacing="20" style="-fx-padding: 20 24 24 24;">

                        <!-- Bouton retour -->
                        <HBox>
                            <Button onAction="#onBackToForum" style="-fx-background-color: transparent; -fx-cursor: hand;">
                                <graphic>
                                    <HBox spacing="8" alignment="CENTER">
                                        <Label text="←" style="-fx-font-size: 16px; -fx-text-fill: #2C5F8A;"/>
                                        <Label text="Retour au forum" style="-fx-text-fill: #2C5F8A; -fx-font-size: 13px; -fx-font-weight: 500;"/>
                                    </HBox>
                                </graphic>
                            </Button>
                            <Region HBox.hgrow="ALWAYS"/>
                        </HBox>

                        <!-- Sujet Principal -->
                        <VBox style="-fx-background-color: white; -fx-background-radius: 20; -fx-padding: 24;
                                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 2);"
                              spacing="15">

                            <HBox spacing="15" alignment="CENTER_LEFT">
                                <StackPane>
                                    <Circle radius="30" style="-fx-fill: linear-gradient(from 0% 0% to 100% 100%, #4A6FA5, #2C5F8A);"/>
                                    <Label fx:id="sujetAvatar" text="S"
                                           style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;"/>
                                </StackPane>
                                <VBox spacing="5" HBox.hgrow="ALWAYS">
                                    <Label fx:id="sujetTitre" text="Titre"
                                           style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #2C3E50;"
                                           wrapText="true"/>
                                    <HBox spacing="15">
                                        <Label fx:id="sujetAuteur" text="Par auteur"
                                               style="-fx-font-size: 12px; -fx-text-fill: #7F8C8D;"/>
                                        <Label text="•" style="-fx-font-size: 12px; -fx-text-fill: #7F8C8D;"/>
                                        <Label fx:id="sujetDate" text="Date"
                                               style="-fx-font-size: 12px; -fx-text-fill: #7F8C8D;"/>
                                    </HBox>
                                </VBox>

                                <!-- Menu actions (si propriétaire) -->
                                <MenuButton fx:id="topicMenuButton" text="⋮" style="-fx-background-color: transparent; -fx-cursor: hand;"
                                            visible="false" managed="false">
                                    <items>
                                        <MenuItem text="✏️ Modifier" onAction="#onEditSujet"/>
                                        <SeparatorMenuItem/>
                                        <MenuItem text="🗑️ Supprimer" onAction="#onDeleteSujet" style="-fx-text-fill: #E74C3C;"/>
                                    </items>
                                </MenuButton>
                            </HBox>

                            <Separator/>

                            <Label fx:id="sujetContenu" text="Contenu"
                                   wrapText="true" style="-fx-font-size: 14px; -fx-text-fill: #5A6C7D; -fx-line-spacing: 1.5;"/>

                            <Button fx:id="translateSujetBtn" text="🌐 Voir traduction"
                                    style="-fx-background-color: transparent; -fx-text-fill: #2C5F8A; -fx-cursor: hand; -fx-alignment: CENTER_LEFT;"/>

                            <HBox spacing="20" alignment="CENTER_LEFT">
                                <Button fx:id="likeButton" text="👍 0"
                                        style="-fx-background-color: transparent; -fx-text-fill: #7F8C8D; -fx-cursor: hand; -fx-padding: 5 10; -fx-background-radius: 20;"/>
                                <Button fx:id="dislikeButton" text="👎 0"
                                        style="-fx-background-color: transparent; -fx-text-fill: #7F8C8D; -fx-cursor: hand; -fx-padding: 5 10; -fx-background-radius: 20;"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Label style="-fx-background-color: rgba(74,111,165,0.1); -fx-padding: 5 12; -fx-background-radius: 15; -fx-text-fill: #2C5F8A;">
                                    <fx:define>
                                        <Label fx:id="nbVuesLabel" text="0 vues"/>
                                    </fx:define>
                                </Label>
                            </HBox>
                        </VBox>

                        <!-- Section Commentaires avec ScrollPane -->
                        <VBox spacing="15">
                            <HBox alignment="CENTER_LEFT" spacing="15">
                                <Label text="💬 Commentaires" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2C3E50;"/>
                                <Label fx:id="totalCommentsLabel" style="-fx-font-size: 13px; -fx-text-fill: #7F8C8D; -fx-background-color: #E8EEF4; -fx-padding: 2 8; -fx-background-radius: 10;"/>
                                <Region HBox.hgrow="ALWAYS"/>
                            </HBox>

                            <!-- ScrollPane pour les commentaires -->
                            <ScrollPane fx:id="commentsScrollPane" fitToWidth="true"
                                        style="-fx-background-color: transparent; -fx-background: transparent; -fx-padding: 0;"
                                        prefHeight="350" maxHeight="350">
                                <content>
                                    <VBox>
                                        <VBox fx:id="commentsContainer" spacing="12">
                                            <!-- Commentaires ajoutés dynamiquement -->
                                        </VBox>

                                        <!-- Message aucun commentaire -->
                                        <VBox fx:id="emptyCommentsState" spacing="15" alignment="CENTER"
                                              style="-fx-padding: 60 20; -fx-display: none;">
                                            <Label text="💬" style="-fx-font-size: 64px; -fx-opacity: 0.5;"/>
                                            <Label text="Aucun commentaire"
                                                   style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2C3E50;"/>
                                            <Label text="Soyez le premier à commenter cette discussion !"
                                                   style="-fx-font-size: 13px; -fx-text-fill: #7F8C8D;"/>
                                        </VBox>
                                    </VBox>
                                </content>
                            </ScrollPane>

                            <!-- Pagination des commentaires -->
                            <HBox fx:id="commentPaginationBox" spacing="10" alignment="CENTER"
                                  style="-fx-padding: 10 0 0 0; -fx-display: none;">
                                <!-- Pagination ajoutée dynamiquement -->
                            </HBox>
                        </VBox>

                        <!-- Formulaire d'ajout de commentaire -->
                        <VBox spacing="15" style="-fx-background-color: white; -fx-background-radius: 20; -fx-padding: 20;
                                                  -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 2);">
                            <Label text="📝 Ajouter un commentaire"
                                   style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #2C3E50;"/>

                            <HBox spacing="10" alignment="CENTER_LEFT">
                                <CheckBox fx:id="anonymeCheckBox" text="Publier anonymement"
                                          style="-fx-text-fill: #7F8C8D;"/>
                                <Label text="Votre identité sera cachée"
                                       style="-fx-text-fill: #95A5A6; -fx-font-size: 11px;"/>
                            </HBox>

                            <TextArea fx:id="commentTextArea" promptText="Partagez votre réponse, opinion ou conseil..."
                                      prefHeight="100" wrapText="true"
                                      style="-fx-padding: 12; -fx-background-radius: 12; -fx-border-color: #E8EEF4; -fx-border-radius: 12;"/>

                            <HBox spacing="15" alignment="CENTER_RIGHT">
                                <Button text="Annuler" onAction="#onCancelComment"
                                        style="-fx-background-color: transparent; -fx-text-fill: #7F8C8D; -fx-cursor: hand; -fx-padding: 8 20;"/>
                                <Button fx:id="submitCommentButton" text="💬 Publier le commentaire" onAction="#onSubmitComment"
                                        style="-fx-background-color: #2C5F8A; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 25; -fx-cursor: hand; -fx-padding: 8 25;"/>
                            </HBox>
                        </VBox>

                    </VBox>
                </content>
            </ScrollPane>

        </VBox>
    </center>

</BorderPane>