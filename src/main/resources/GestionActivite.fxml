<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/22" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="Controller.ActiviteController"
            style="-fx-background-color: #f5f7fa;">

    <!-- Sidebar -->
    <left>
        <VBox style="-fx-background-color: #2d3748; -fx-pref-width: 220;">
            <padding><Insets top="20" right="0" bottom="20" left="0"/></padding>

            <HBox alignment="CENTER_LEFT" spacing="12" style="-fx-padding: 20;">
                <Label text="🧠" style="-fx-font-size: 28px;"/>
                <VBox spacing="2">
                    <Label text="MentalUp Admin" style="-fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: bold;"/>
                    <Label text="Espace d'administration" style="-fx-text-fill: #a0aec0; -fx-font-size: 10px;"/>
                </VBox>
            </HBox>

            <Region style="-fx-background-color: #4a5568; -fx-pref-height: 1;">
                <VBox.margin><Insets top="5" bottom="10"/></VBox.margin>
            </Region>

            <VBox spacing="2" style="-fx-padding: 10 15;">
                <Button text="🏠  Accueil" alignment="CENTER_LEFT" maxWidth="Infinity"
                        style="-fx-background-color: transparent; -fx-text-fill: #cbd5e0; -fx-font-size: 13px; -fx-padding: 11 15; -fx-background-radius: 8; -fx-cursor: hand;"><VBox.margin><Insets bottom="3"/></VBox.margin></Button>
                <Button text="📊  Suivi Mental" alignment="CENTER_LEFT" maxWidth="Infinity"
                        style="-fx-background-color: transparent; -fx-text-fill: #cbd5e0; -fx-font-size: 13px; -fx-padding: 11 15; -fx-background-radius: 8; -fx-cursor: hand;"><VBox.margin><Insets bottom="3"/></VBox.margin></Button>
                <Button text="💬  Forum" alignment="CENTER_LEFT" maxWidth="Infinity"
                        style="-fx-background-color: transparent; -fx-text-fill: #cbd5e0; -fx-font-size: 13px; -fx-padding: 11 15; -fx-background-radius: 8; -fx-cursor: hand;"><VBox.margin><Insets bottom="3"/></VBox.margin></Button>
                <Button text="📅  Rendez-vous" alignment="CENTER_LEFT" maxWidth="Infinity"
                        style="-fx-background-color: transparent; -fx-text-fill: #cbd5e0; -fx-font-size: 13px; -fx-padding: 11 15; -fx-background-radius: 8; -fx-cursor: hand;"><VBox.margin><Insets bottom="3"/></VBox.margin></Button>
                <Button text="👥  Utilisateurs" alignment="CENTER_LEFT" maxWidth="Infinity"
                        style="-fx-background-color: transparent; -fx-text-fill: #cbd5e0; -fx-font-size: 13px; -fx-padding: 11 15; -fx-background-radius: 8; -fx-cursor: hand;"><VBox.margin><Insets bottom="3"/></VBox.margin></Button>
                <Button text="📋  Dossiers médicaux" alignment="CENTER_LEFT" maxWidth="Infinity"
                        style="-fx-background-color: transparent; -fx-text-fill: #cbd5e0; -fx-font-size: 13px; -fx-padding: 11 15; -fx-background-radius: 8; -fx-cursor: hand;"><VBox.margin><Insets bottom="3"/></VBox.margin></Button>
                <Button text="📝  Contenus" alignment="CENTER_LEFT" maxWidth="Infinity"
                        style="-fx-background-color: transparent; -fx-text-fill: #cbd5e0; -fx-font-size: 13px; -fx-padding: 11 15; -fx-background-radius: 8; -fx-cursor: hand;"><VBox.margin><Insets bottom="3"/></VBox.margin></Button>
                <Button text="⚡  Activités" alignment="CENTER_LEFT" maxWidth="Infinity"
                        style="-fx-background-color: #4a5568; -fx-text-fill: white; -fx-font-size: 13px; -fx-padding: 11 15; -fx-background-radius: 8; -fx-cursor: hand;"><VBox.margin><Insets bottom="3"/></VBox.margin></Button>
                <Button text="🎟  Réservations" alignment="CENTER_LEFT" maxWidth="Infinity"
                        onAction="#ouvrirReservations"
                        style="-fx-background-color: transparent; -fx-text-fill: #cbd5e0; -fx-font-size: 13px; -fx-padding: 11 15; -fx-background-radius: 8; -fx-cursor: hand;"><VBox.margin><Insets bottom="3"/></VBox.margin></Button>
            </VBox>

            <Region VBox.vgrow="ALWAYS"/>

            <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding: 15; -fx-background-color: #1a202c; -fx-background-radius: 10;">
                <VBox.margin><Insets top="10" right="15" bottom="10" left="15"/></VBox.margin>
                <Label text="👤" style="-fx-font-size: 22px; -fx-background-color: #4a5568; -fx-padding: 7; -fx-background-radius: 50%;"/>
                <VBox spacing="2">
                    <Label text="Admin MentalUp" style="-fx-text-fill: white; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                    <Label text="Super Administrateur" style="-fx-text-fill: #a0aec0; -fx-font-size: 10px;"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="⋮" style="-fx-text-fill: #cbd5e0; -fx-font-size: 18px; -fx-cursor: hand;"/>
            </HBox>
        </VBox>
    </left>

    <!-- Main Content -->
    <center>
        <VBox spacing="15" style="-fx-padding: 25; -fx-background-color: #f5f7fa;">

            <!-- Header -->
            <HBox alignment="CENTER_LEFT" spacing="12">
                <VBox spacing="3">
                    <Label text="Gestion des Activités 📋" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #2d3748;"/>
                    <Label text="mercredi 8 avril 2026" style="-fx-font-size: 12px; -fx-text-fill: #718096;"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="btnAjouter" text="＋ Ajouter une activité" onAction="#ouvrirPopupAjout"
                        style="-fx-background-color: #4a5568; -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-padding: 10 20; -fx-cursor: hand; -fx-background-radius: 8; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 5, 0, 0, 2);"/>
                <Button fx:id="btnVuePublique" text="👁 Vue Publique" onAction="#ouvrirVuePublique"
                        style="-fx-background-color: #6b9fb5; -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-padding: 10 20; -fx-cursor: hand; -fx-background-radius: 8; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 5, 0, 0, 2);"/>
                <Label text="🔔" style="-fx-font-size: 18px; -fx-background-color: white; -fx-padding: 8; -fx-background-radius: 50%; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 5, 0, 0, 2);"/>
            </HBox>

            <!-- Barre recherche + tri -->
            <HBox alignment="CENTER_LEFT" spacing="12">
                <Label fx:id="lblCount" text="0 activité(s)"
                       style="-fx-background-color: #4a5568; -fx-text-fill: white; -fx-font-size: 12px; -fx-padding: 4 12; -fx-background-radius: 12;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <TextField fx:id="searchField" promptText="🔍  Rechercher..."
                           style="-fx-pref-width: 220; -fx-padding: 9; -fx-font-size: 13px; -fx-border-color: #e2e8f0; -fx-border-width: 2; -fx-border-radius: 20; -fx-background-radius: 20; -fx-background-color: white;"/>
                <ComboBox fx:id="sortCombo" promptText="Trier par..."
                          style="-fx-pref-width: 160; -fx-font-size: 13px; -fx-background-color: white; -fx-border-color: #e2e8f0; -fx-border-width: 2; -fx-border-radius: 8; -fx-background-radius: 8;"/>
            </HBox>

            <!-- Cartes activités -->
            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                        style="-fx-background: transparent; -fx-background-color: transparent; -fx-border-color: transparent;">
                <FlowPane fx:id="activitesFlow" hgap="18" vgap="18"
                          style="-fx-padding: 5; -fx-background-color: transparent;"/>
            </ScrollPane>

        </VBox>
    </center>

</BorderPane>
