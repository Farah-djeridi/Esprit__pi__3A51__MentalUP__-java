<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/22" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="Controller.ReservationAdminController"
            style="-fx-background-color: #f5f7fa;">

    <!-- Sidebar Dark (même que GestionActivite) -->
    <left>
        <VBox style="-fx-background-color: #2d3748; -fx-pref-width: 260;">
            <padding><Insets top="20" right="0" bottom="20" left="0"/></padding>

            <HBox alignment="CENTER_LEFT" spacing="12" style="-fx-padding: 20;">
                <Label text="🧠" style="-fx-font-size: 32px;"/>
                <VBox spacing="2">
                    <Label text="MentalUp Admin" style="-fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold;"/>
                    <Label text="Espace d'administration" style="-fx-text-fill: #a0aec0; -fx-font-size: 11px;"/>
                </VBox>
            </HBox>

            <Region style="-fx-background-color: #4a5568; -fx-pref-height: 1;">
                <VBox.margin><Insets top="10" bottom="10"/></VBox.margin>
            </Region>

            <VBox spacing="2" style="-fx-padding: 10 15;">
                <Button text="🏠  Accueil" alignment="CENTER_LEFT" maxWidth="Infinity"
                        style="-fx-background-color: transparent; -fx-text-fill: #cbd5e0; -fx-font-size: 14px; -fx-padding: 12 15; -fx-background-radius: 8; -fx-cursor: hand;">
                    <VBox.margin><Insets bottom="5"/></VBox.margin>
                </Button>
                <Button text="📊  Suivi Mental" alignment="CENTER_LEFT" maxWidth="Infinity"
                        style="-fx-background-color: transparent; -fx-text-fill: #cbd5e0; -fx-font-size: 14px; -fx-padding: 12 15; -fx-background-radius: 8; -fx-cursor: hand;">
                    <VBox.margin><Insets bottom="5"/></VBox.margin>
                </Button>
                <Button text="💬  Forum" alignment="CENTER_LEFT" maxWidth="Infinity"
                        style="-fx-background-color: transparent; -fx-text-fill: #cbd5e0; -fx-font-size: 14px; -fx-padding: 12 15; -fx-background-radius: 8; -fx-cursor: hand;">
                    <VBox.margin><Insets bottom="5"/></VBox.margin>
                </Button>
                <Button text="📅  Rendez-vous" alignment="CENTER_LEFT" maxWidth="Infinity"
                        style="-fx-background-color: transparent; -fx-text-fill: #cbd5e0; -fx-font-size: 14px; -fx-padding: 12 15; -fx-background-radius: 8; -fx-cursor: hand;">
                    <VBox.margin><Insets bottom="5"/></VBox.margin>
                </Button>
                <Button text="👥  Utilisateurs" alignment="CENTER_LEFT" maxWidth="Infinity"
                        style="-fx-background-color: transparent; -fx-text-fill: #cbd5e0; -fx-font-size: 14px; -fx-padding: 12 15; -fx-background-radius: 8; -fx-cursor: hand;">
                    <VBox.margin><Insets bottom="5"/></VBox.margin>
                </Button>
                <Button text="⚡  Activités" alignment="CENTER_LEFT" maxWidth="Infinity"
                        onAction="#ouvrirActivites"
                        style="-fx-background-color: transparent; -fx-text-fill: #cbd5e0; -fx-font-size: 14px; -fx-padding: 12 15; -fx-background-radius: 8; -fx-cursor: hand;">
                    <VBox.margin><Insets bottom="5"/></VBox.margin>
                </Button>
                <!-- Réservations SÉLECTIONNÉ -->
                <Button text="🎟  Réservations" alignment="CENTER_LEFT" maxWidth="Infinity"
                        style="-fx-background-color: #4a5568; -fx-text-fill: white; -fx-font-size: 14px; -fx-padding: 12 15; -fx-background-radius: 8; -fx-cursor: hand; -fx-font-weight: bold;">
                    <VBox.margin><Insets bottom="5"/></VBox.margin>
                </Button>
            </VBox>

            <Region VBox.vgrow="ALWAYS"/>

            <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding: 15; -fx-background-color: #1a202c; -fx-background-radius: 10;">
                <VBox.margin><Insets top="10" right="15" bottom="10" left="15"/></VBox.margin>
                <Label text="👤" style="-fx-font-size: 24px; -fx-background-color: #4a5568; -fx-padding: 8; -fx-background-radius: 50%;"/>
                <VBox spacing="2">
                    <Label text="Admin MentalUp" style="-fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold;"/>
                    <Label text="Super Administrateur" style="-fx-text-fill: #a0aec0; -fx-font-size: 10px;"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="⋮" style="-fx-text-fill: #cbd5e0; -fx-font-size: 20px; -fx-cursor: hand;"/>
            </HBox>
        </VBox>
    </left>

    <!-- Main Content -->
    <center>
        <VBox spacing="20" style="-fx-padding: 25; -fx-background-color: #f5f7fa;">

            <!-- Header -->
            <HBox alignment="CENTER_LEFT" spacing="12">
                <Label text="🎟 Gestion des Réservations" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #2d3748;"/>
                <Label fx:id="lblTotal" text="0"
                       style="-fx-background-color: #4a5568; -fx-text-fill: white; -fx-font-size: 12px; -fx-font-weight: bold; -fx-padding: 4 12; -fx-background-radius: 15;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="🔔" style="-fx-font-size: 20px; -fx-background-color: white; -fx-padding: 8; -fx-background-radius: 50%; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 5, 0, 0, 2);"/>
            </HBox>

            <!-- Cartes réservations -->
            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                        style="-fx-background: transparent; -fx-background-color: transparent; -fx-border-color: transparent;">
                <VBox fx:id="reservationsVBox" spacing="12"
                      style="-fx-padding: 2; -fx-background-color: transparent;"/>
            </ScrollPane>

        </VBox>
    </center>

</BorderPane>
