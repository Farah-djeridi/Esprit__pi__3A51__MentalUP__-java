                                              -fx-font-size: 11px;
                                              -fx-font-weight: 700;"/>
                                <Label fx:id="objectifsEnCoursLabel" text="0"
                                       style="-fx-text-fill: white;
                                              -fx-font-size: 24px;
                                              -fx-font-weight: 900;"/>
                            </VBox>
                        </HBox>

                        <HBox spacing="8">
                            <VBox HBox.hgrow="ALWAYS"
                                  style="-fx-background-color: white;
