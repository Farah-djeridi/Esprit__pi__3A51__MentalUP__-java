<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>


<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="controllers.ControllerRdvConfirmation"
      spacing="0"
      prefWidth="420"
      style="-fx-background-color: #F4F8FF; -fx-background-radius: 18;">


    <VBox alignment="CENTER" spacing="8"
          style="-fx-background-color: linear-gradient(to right, #4A7FA5, #2C5F8A);
                 -fx-background-radius: 18 18 0 0;
                 -fx-padding: 28 24 22 24;">
        <Label text="✅" style="-fx-font-size: 36px;"/>
        <Label text="Confirmer la réservation"
               style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"/>
        <Label text="Vérifiez les détails avant de confirmer"
               style="-fx-text-fill: rgba(255,255,255,0.8); -fx-font-size: 12px;"/>
    </VBox>


    <VBox spacing="12"
          style="-fx-background-color: white; -fx-padding: 24 28;">

        <!-- Psychologue -->
        <HBox spacing="12" alignment="CENTER_LEFT"
              style="-fx-background-color: #F0F7FF; -fx-background-radius: 10; -fx-padding: 12 16;">
            <Label text="👨‍⚕️" style="-fx-font-size: 20px;"/>
            <VBox spacing="2">
                <Label text="Psychologue"
                       style="-fx-text-fill: #5A6C7D; -fx-font-size: 11px; -fx-font-weight: 600;"/>
                <Label fx:id="labelPsyNom" text="Dr. Prénom Nom"
                       style="-fx-text-fill: #2C3E50; -fx-font-size: 14px; -fx-font-weight: bold;"/>
            </VBox>
        </HBox>

        <!-- Date & Heure -->
        <HBox spacing="10">
            <VBox spacing="2" HBox.hgrow="ALWAYS"
                  style="-fx-background-color: #F0FFF4; -fx-background-radius: 10; -fx-padding: 12 16;">
                <Label text="📅  Date"
                       style="-fx-text-fill: #5A6C7D; -fx-font-size: 11px; -fx-font-weight: 600;"/>
                <Label fx:id="labelDate" text="Lundi 14 Avril 2026"
                       style="-fx-text-fill: #2C3E50; -fx-font-size: 13px; -fx-font-weight: bold;"/>
            </VBox>
            <VBox spacing="2" HBox.hgrow="ALWAYS"
                  style="-fx-background-color: #FFF8F0; -fx-background-radius: 10; -fx-padding: 12 16;">
                <Label text="⏰  Horaire"
                       style="-fx-text-fill: #5A6C7D; -fx-font-size: 11px; -fx-font-weight: 600;"/>
                <Label fx:id="labelHeure" text="10:00 – 11:00"
                       style="-fx-text-fill: #2C3E50; -fx-font-size: 13px; -fx-font-weight: bold;"/>
            </VBox>
        </HBox>

        <!-- Type de séance -->
        <HBox spacing="12" alignment="CENTER_LEFT"
              style="-fx-background-color: #FDF0FF; -fx-background-radius: 10; -fx-padding: 12 16;">
            <Label text="💼" style="-fx-font-size: 20px;"/>
            <VBox spacing="2">
                <Label text="Type de séance"
                       style="-fx-text-fill: #5A6C7D; -fx-font-size: 11px; -fx-font-weight: 600;"/>
                <Label fx:id="labelType" text="Consultation individuelle"
                       style="-fx-text-fill: #2C3E50; -fx-font-size: 14px; -fx-font-weight: bold;"/>
            </VBox>
        </HBox>

        <VBox spacing="8" style="-fx-padding: 4 0 0 0;">
            <Label text="Mode du rendez-vous" textFill="#5A6C7D" style="-fx-font-size: 11px; -fx-font-weight: 600;"/>
            <ComboBox fx:id="comboMode" promptText="Choisir le mode" maxWidth="Infinity"
                      style="-fx-background-color: #F8FAFC; -fx-border-color: #E2E8F0; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 8;"/>
        </VBox>

        <VBox spacing="8" style="-fx-padding: 4 0 0 0;">
            <Label text="Numéro de téléphone" textFill="#5A6C7D" style="-fx-font-size: 11px; -fx-font-weight: 600;"/>
            <TextField fx:id="txtTelephone" promptText="Ex: +21652026846" maxWidth="Infinity"
                       style="-fx-background-color: #F8FAFC; -fx-border-color: #E2E8F0; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 10;"/>
        </VBox>

    </VBox>


    <HBox spacing="12" alignment="CENTER"
          style="-fx-background-color: #F4F8FF; -fx-background-radius: 0 0 18 18;
                 -fx-padding: 16 28 24 28;
                 -fx-border-color: rgba(151,187,228,0.2) transparent transparent transparent;
                 -fx-border-width: 1 0 0 0;">

        <Button text="Annuler" onAction="#onAnnuler"
                style="-fx-background-color: white; -fx-text-fill: #5A6C7D;
                       -fx-font-weight: bold; -fx-font-size: 14px;
                       -fx-background-radius: 10; -fx-padding: 10 28; -fx-cursor: hand;
                       -fx-border-color: rgba(151,187,228,0.4); -fx-border-radius: 10; -fx-border-width: 1;"
                HBox.hgrow="ALWAYS"/>

        <Button fx:id="btnConfirmer" text="✅  Confirmer" onAction="#onConfirmer"
                style="-fx-background-color: linear-gradient(to right, #27AE60, #1E8449);
                       -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px;
                       -fx-background-radius: 10; -fx-padding: 10 28; -fx-cursor: hand;
                       -fx-effect: dropshadow(gaussian, rgba(39,174,96,0.3), 8, 0, 0, 2);"
                HBox.hgrow="ALWAYS"/>

    </HBox>

</VBox>
