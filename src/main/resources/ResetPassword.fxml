<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.shape.*?>

<AnchorPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="Controllor.ResetPasswordController"
            prefWidth="900" prefHeight="620"
            style="-fx-background-color: #F0F4F8;">

    <HBox AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0"
          AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">

        <!-- ÔòÉÔòÉÔòÉ PANNEAU GAUCHE BLEU ÔòÉÔòÉÔòÉ -->
        <VBox prefWidth="360" alignment="CENTER" spacing="22"
              style="-fx-background-color: #2C5F8A; -fx-padding: 50 36;">

            <StackPane>
                <Circle radius="40" style="-fx-fill: rgba(255,255,255,0.12);
                                           -fx-stroke: rgba(255,255,255,0.3);
                                           -fx-stroke-width: 2;"/>
                <ImageView fx:id="logoImage" fitWidth="50" fitHeight="50" preserveRatio="false"/>
            </StackPane>

            <Label text="Mental Up"
                   style="-fx-text-fill: white; -fx-font-size: 26px; -fx-font-weight: bold;"/>

            <Label text="­ƒöÆ" style="-fx-font-size: 58px;"/>

            <Label text="Nouveau mot de passe"
                   style="-fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold;"/>

            <Label text="Choisissez un mot de passe&#10;fort pour s├®curiser&#10;votre compte."
                   style="-fx-text-fill: rgba(255,255,255,0.75); -fx-font-size: 13px;
                          -fx-text-alignment: center; -fx-alignment: center; -fx-wrap-text: true;"/>

            <!-- R├¿gles mot de passe -->
            <VBox spacing="8" style="-fx-padding: 10 0 0 0;">
                <HBox spacing="8" alignment="CENTER_LEFT">
                    <Label text="Ô£à" style="-fx-font-size: 12px;"/>
                    <Label text="Minimum 8 caract├¿res"
                           style="-fx-text-fill: rgba(255,255,255,0.8); -fx-font-size: 12px;"/>
                </HBox>
                <HBox spacing="8" alignment="CENTER_LEFT">
                    <Label text="Ô£à" style="-fx-font-size: 12px;"/>
                    <Label text="Les deux mots de passe&#10;doivent correspondre"
                           style="-fx-text-fill: rgba(255,255,255,0.8); -fx-font-size: 12px;
                                  -fx-wrap-text: true;"/>
                </HBox>
            </VBox>
        </VBox>

        <!-- ÔòÉÔòÉÔòÉ PANNEAU DROIT ÔòÉÔòÉÔòÉ -->
        <VBox HBox.hgrow="ALWAYS" alignment="CENTER" spacing="0"
              style="-fx-background-color: white; -fx-padding: 50 60;">

            <Label text="R├®initialiser votre mot de passe"
                   style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #2C3E50;
                          -fx-padding: 0 0 6 0;"/>

            <Label fx:id="lblEmail" text=""
                   style="-fx-font-size: 13px; -fx-text-fill: #7A9CB8;
                          -fx-padding: 0 0 28 0;"/>

            <!-- Code de v├®rification -->
            <VBox spacing="6" style="-fx-padding: 0 0 16 0;" maxWidth="380">
                <Label text="CODE DE V├ëRIFICATION"
                       style="-fx-font-size: 11px; -fx-font-weight: bold;
                              -fx-text-fill: #7A9CB8;"/>
                <HBox alignment="CENTER_LEFT" spacing="10"
                      style="-fx-background-color: #F0F6FF;
                             -fx-border-color: #C8DDF0; -fx-border-radius: 8;
                             -fx-background-radius: 8; -fx-padding: 0 14; -fx-pref-height: 44;">
                    <Label text="­ƒöæ" style="-fx-text-fill: #7A9CB8; -fx-font-size: 14px;"/>
                    <TextField fx:id="txtCode" promptText="Code ├á 6 chiffres re├ºu par email"
                               style="-fx-background-color: transparent; -fx-border-color: transparent;
                                      -fx-font-size: 14px; -fx-text-fill: #2C3E50;"
                               HBox.hgrow="ALWAYS"/>
                </HBox>
            </VBox>

            <!-- Nouveau mot de passe -->
            <VBox spacing="6" style="-fx-padding: 0 0 16 0;" maxWidth="380">
                <Label text="NOUVEAU MOT DE PASSE"
                       style="-fx-font-size: 11px; -fx-font-weight: bold;
                              -fx-text-fill: #7A9CB8;"/>
                <HBox alignment="CENTER_LEFT" spacing="10"
                      style="-fx-background-color: #F0F6FF;
                             -fx-border-color: #C8DDF0; -fx-border-radius: 8;
                             -fx-background-radius: 8; -fx-padding: 0 14; -fx-pref-height: 44;">
                    <Label text="­ƒöÆ" style="-fx-text-fill: #7A9CB8; -fx-font-size: 14px;"/>
                    <PasswordField fx:id="txtNewPass" promptText="Minimum 8 caract├¿res"
                                   style="-fx-background-color: transparent; -fx-border-color: transparent;
                                          -fx-font-size: 14px; -fx-text-fill: #2C3E50;"
                                   HBox.hgrow="ALWAYS"/>
                </HBox>
            </VBox>

            <!-- Confirmer mot de passe -->
            <VBox spacing="6" style="-fx-padding: 0 0 16 0;" maxWidth="380">
                <Label text="CONFIRMER LE MOT DE PASSE"
                       style="-fx-font-size: 11px; -fx-font-weight: bold;
                              -fx-text-fill: #7A9CB8;"/>
                <HBox alignment="CENTER_LEFT" spacing="10"
                      style="-fx-background-color: #F0F6FF;
                             -fx-border-color: #C8DDF0; -fx-border-radius: 8;
                             -fx-background-radius: 8; -fx-padding: 0 14; -fx-pref-height: 44;">
                    <Label text="­ƒöÆ" style="-fx-text-fill: #7A9CB8; -fx-font-size: 14px;"/>
                    <PasswordField fx:id="txtConfirmPass" promptText="R├®p├®tez le mot de passe"
                                   style="-fx-background-color: transparent; -fx-border-color: transparent;
                                          -fx-font-size: 14px; -fx-text-fill: #2C3E50;"
                                   HBox.hgrow="ALWAYS"/>
                </HBox>
            </VBox>

            <!-- Message feedback -->
            <Label fx:id="lblMessage" text="" wrapText="true"
                   style="-fx-font-size: 12px; -fx-padding: 0 0 12 0;"/>

            <!-- Bouton r├®initialiser -->
            <Button text="Ô£ö  R├®initialiser le mot de passe" onAction="#handleReset"
                    maxWidth="380"
                    style="-fx-background-color: #2C5F8A; -fx-text-fill: white;
                           -fx-font-size: 14px; -fx-font-weight: bold;
                           -fx-pref-height: 46; -fx-background-radius: 8; -fx-cursor: hand;"/>

            <HBox alignment="CENTER" spacing="5" style="-fx-padding: 16 0 0 0;">
                <Hyperlink text="ÔåÉ Retour au login" onAction="#goToLogin"
                           style="-fx-text-fill: #A0B4C8; -fx-font-size: 12px;"/>
            </HBox>
        </VBox>
    </HBox>
</AnchorPane>
