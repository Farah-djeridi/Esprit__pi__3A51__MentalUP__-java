<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<?import javafx.scene.shape.*?>



<?import javafx.scene.image.ImageView?>
<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="controllers.ControllerHome"
            prefWidth="1024" prefHeight="650"
            style="-fx-background-color: linear-gradient(to bottom right, #F4F8FF, #E8F0FE);">


    <left>
        <VBox prefWidth="240" prefHeight="700"
              style="-fx-background-color: linear-gradient(to bottom, #D6E8F7, #2C5F8A);">

            <!-- Logo / Brand -->
            <HBox alignment="CENTER_LEFT" spacing="10"
                  style="-fx-padding: 24 18 20 18;
                         -fx-border-color: transparent transparent rgba(255,255,255,0.12) transparent;
                         -fx-border-width: 0 0 1 0;">
                <StackPane>
                    <ImageView fx:id="logoImage" fitWidth="45" fitHeight="45" preserveRatio="true"/>
                </StackPane>
                <VBox spacing="2">
                    <Label text="MentalUp"
                           style="-fx-text-fill: #1A3A52; -fx-font-size: 16px;
                                  -fx-font-weight: bold;"/>
                    <Label text="Bien-être étudiant"
                           style="-fx-text-fill: #2C5F8A; -fx-font-size: 11px; -fx-font-weight: 600;"/>
                </VBox>
            </HBox>

            <!-- Navigation -->
            <VBox spacing="4" style="-fx-padding: 20 14 0 14;" VBox.vgrow="ALWAYS">

                <!-- Accueil -->
                <HBox alignment="CENTER_LEFT" spacing="12"
                      fx:id="navAccueil"
                      onMouseClicked="#onNavHomeClicked"
                      style="-fx-background-color: #1E4568;
                             -fx-background-radius: 8;
                             -fx-padding: 10 14;
                             -fx-cursor: hand;
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 5, 0, 0, 2);">
                    <Label text="🏠" style="-fx-font-size: 16px; -fx-text-fill: white;"/>
                    <Label text="Accueil"
                           style="-fx-text-fill: white; -fx-font-size: 14px;
                                  -fx-font-weight: bold;"/>
                </HBox>

                <!-- Suivi -->
                <HBox alignment="CENTER_LEFT" spacing="12"
                      fx:id="navSuivi"
                      onMouseClicked="#onNavSuiviClicked"
                      onMouseEntered="#onNavHoverEnter"
                      onMouseExited="#onNavHoverExit"
                      style="-fx-background-color: transparent;
                             -fx-background-radius: 8;
                             -fx-padding: 10 14;
                             -fx-cursor: hand;">
                    <Label text="📈" style="-fx-font-size: 16px; -fx-text-fill: white;"/>
                    <Label text="Suivi"
                           style="-fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: 500;"/>
                </HBox>

                <!-- Rendez-vous -->
                <HBox alignment="CENTER_LEFT" spacing="12"
                      fx:id="navRdv"
                      onMouseClicked="#onNavRdvClicked"
                      onMouseEntered="#onNavHoverEnter"
                      onMouseExited="#onNavHoverExit"
                      style="-fx-background-color: transparent;
                             -fx-background-radius: 8;
                             -fx-padding: 10 14;
                             -fx-cursor: hand;">
                    <Label text="📅" style="-fx-font-size: 16px; -fx-text-fill: white;"/>
                    <Label text="Rendez-vous"
                           style="-fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: 500;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <StackPane style="-fx-background-color: #E74C3C;
                                     -fx-background-radius: 10; -fx-padding: 1 6;">
                        <Label fx:id="badgeRdv" text="3"
                               style="-fx-text-fill: white; -fx-font-size: 11px;
                                      -fx-font-weight: bold;"/>
                    </StackPane>
                </HBox>

                <!-- Forum -->
                <HBox alignment="CENTER_LEFT" spacing="12"
                      fx:id="navForum"
                      onMouseClicked="#onNavBlogClicked"
                      onMouseEntered="#onNavHoverEnter"
                      onMouseExited="#onNavHoverExit"
                      style="-fx-background-color: transparent;
                             -fx-background-radius: 8;
                             -fx-padding: 10 14;
                             -fx-cursor: hand;">
                    <Label text="💬" style="-fx-font-size: 16px; -fx-text-fill: white;"/>
                    <Label text="Forum"
                           style="-fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: 500;"/>
                </HBox>

                <!-- Activités -->
                <HBox alignment="CENTER_LEFT" spacing="12"
                      fx:id="navActivites"
                      onMouseClicked="#onNavActivitesClicked"
                      onMouseEntered="#onNavHoverEnter"
                      onMouseExited="#onNavHoverExit"
                      style="-fx-background-color: transparent;
                             -fx-background-radius: 8;
                             -fx-padding: 10 14;
                             -fx-cursor: hand;">
                    <Label text="⚡" style="-fx-font-size: 16px; -fx-text-fill: white;"/>
                    <Label text="Activités"
                           style="-fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: 500;"/>
                </HBox>

                <!-- Ressources -->
                <HBox alignment="CENTER_LEFT" spacing="12"
                      fx:id="navRessources"
                      onMouseClicked="#onNavRessourcesClicked"
                      onMouseEntered="#onNavHoverEnter"
                      onMouseExited="#onNavHoverExit"
                      style="-fx-background-color: transparent;
                             -fx-background-radius: 8;
                             -fx-padding: 10 14;
                             -fx-cursor: hand;">
                    <Label text="📚" style="-fx-font-size: 16px; -fx-text-fill: white;"/>
                    <Label text="Ressources"
                           style="-fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: 500;"/>
                </HBox>

            </VBox>

            <!-- Profil utilisateur -->
            <VBox spacing="6" style="-fx-padding: 16 14 20 14; -fx-border-color: rgba(255,255,255,0.2); -fx-border-width: 1 0 0 0;">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Circle radius="18" style="-fx-fill: rgba(255,255,255,0.25);"/>
                    <Label fx:id="avatarInitials" text="SA"
                           style="-fx-text-fill: white; -fx-font-size: 13px;
                                  -fx-font-weight: bold; -fx-translate-x: -28;"/>
                    <VBox spacing="1">
                        <Label fx:id="labelUserName" text="Sophie Amara"
                               style="-fx-text-fill: white; -fx-font-size: 13px;
                                      -fx-font-weight: bold;"/>
                        <Label text="L3 Informatique"
                               style="-fx-text-fill: rgba(255,255,255,0.65); -fx-font-size: 11px; -fx-font-weight: 500;"/>
                    </VBox>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button fx:id="logoutButton" text="⏻" onAction="#onLogout"
                            style="-fx-background-color: rgba(255,255,255,0.15);
                                   -fx-text-fill: white;
                                   -fx-background-radius: 6;
                                   -fx-padding: 5 10;
                                   -fx-cursor: hand;
                                   -fx-font-size: 12px;
                                   -fx-font-weight: bold;"/>
                </HBox>
            </VBox>

        </VBox>
    </left>

    <!-- ═══════════════════════════════════════════
         CONTENU PRINCIPAL - ACCUEIL
    ═══════════════════════════════════════════ -->
    <center>
        <VBox spacing="0" prefWidth="784" prefHeight="700"
              style="-fx-background-color: #F4F8FF;">

            <!-- Barre supérieure -->
            <HBox alignment="CENTER_LEFT" spacing="12"
                  style="-fx-background-color: rgba(255,255,255,0.95);
                         -fx-padding: 14 24;
                         -fx-border-color: transparent transparent rgba(151,187,228,0.2) transparent;
                         -fx-border-width: 0 0 1 0;">
                <VBox spacing="2">
                    <Label text="Bonjour, Sophie 👋"
                           style="-fx-font-size: 18px; -fx-font-weight: bold;
                                  -fx-text-fill: #2C3E50;"/>
                    <Label fx:id="labelDate" text="Mardi 7 Avril 2026"
                           style="-fx-font-size: 12px; -fx-text-fill: #5A6C7D; -fx-font-weight: 500;"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="notifButton" text="🔔" onAction="#onNotifications"
                        style="-fx-background-color: rgba(151,187,228,0.15);
                               -fx-text-fill: #2C5F8A;
                               -fx-padding: 6;
                               -fx-cursor: hand;
                               -fx-font-size: 16px;
                               -fx-border-color: rgba(151,187,228,0.4);
                               -fx-border-radius: 50;
                               -fx-border-width: 1;
                               -fx-min-width: 32;
                               -fx-min-height: 32;"/>
            </HBox>

            <!-- Page d'accueil -->
            <VBox spacing="16" style="-fx-padding: 20 24 24 24;" VBox.vgrow="ALWAYS">

                <!-- Bannière principale -->
                <HBox fx:id="bannerBox"
                      style="-fx-background-color: linear-gradient(to right, #7BA6C9, #2C5F8A);
                             -fx-background-radius: 20;
                             -fx-padding: 35 40;
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 15, 0, 0, 5);"
                      alignment="CENTER_LEFT">
                    <VBox spacing="12" HBox.hgrow="ALWAYS">
                        <Label text="✨ Bienvenue sur MentalUp ✨"
                               style="-fx-text-fill: rgba(255,255,255,0.95);
                                      -fx-font-size: 15px; -fx-font-weight: bold;"/>
                        <Label text="Prenez soin de votre santé mentale"
                               style="-fx-text-fill: white; -fx-font-size: 26px;
                                      -fx-font-weight: bold;"/>
                        <Label text="Une plateforme dédiée à votre bien-être avec des outils de suivi,&#10;des ressources et une communauté bienveillante."
                               style="-fx-text-fill: rgba(255,255,255,0.9);
                                      -fx-font-size: 14px; -fx-font-weight: 500;"/>
                        <HBox spacing="12">
                            <Button fx:id="startButton" text="Commencer l'aventure →" onAction="#onStartSuivi"
                                    style="-fx-background-color: white;
                                           -fx-text-fill: #2C5F8A;
                                           -fx-font-weight: bold;
                                           -fx-font-size: 14px;
                                           -fx-background-radius: 25;
                                           -fx-padding: 10 24;
                                           -fx-cursor: hand;
                                           -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 5, 0, 0, 2);"/>
                        </HBox>
                    </VBox>
                    <Label text="🌸" style="-fx-font-size: 80px; -fx-opacity: 0.15;"
                           HBox.hgrow="NEVER"/>
                </HBox>

                <!-- 3 cartes de présentation -->
                <HBox spacing="14">

                    <VBox fx:id="card1" spacing="10" HBox.hgrow="ALWAYS"
                          style="-fx-background-color: white;
                                 -fx-background-radius: 16;
                                 -fx-padding: 22;
                                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 10, 0, 0, 2);
                                 -fx-cursor: hand;"
                          onMouseEntered="#onCardHoverEnter"
                          onMouseExited="#onCardHoverExit">
                        <Label text="📊" style="-fx-font-size: 38px;"/>
                        <Label text="Suivi émotionnel"
                               style="-fx-font-size: 16px; -fx-font-weight: bold;
                                      -fx-text-fill: #2C3E50;"/>
                        <Label text="Enregistrez votre humeur quotidienne et visualisez votre progression."
                               style="-fx-font-size: 13px; -fx-text-fill: #5A6C7D; -fx-wrap-text: true; -fx-font-weight: 500;"/>
                        <Label text="Découvrir →"
                               style="-fx-font-size: 13px; -fx-text-fill: #2C5F8A; -fx-font-weight: bold;"/>
                    </VBox>

                    <VBox fx:id="card2" spacing="10" HBox.hgrow="ALWAYS"
                          style="-fx-background-color: white;
                                 -fx-background-radius: 16;
                                 -fx-padding: 22;
                                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 10, 0, 0, 2);
                                 -fx-cursor: hand;"
                          onMouseEntered="#onCardHoverEnter"
                          onMouseExited="#onCardHoverExit">
                        <Label text="👥" style="-fx-font-size: 38px;"/>
                        <Label text="Accompagnement"
                               style="-fx-font-size: 16px; -fx-font-weight: bold;
                                      -fx-text-fill: #2C3E50;"/>
                        <Label text="Professionnels à votre écoute et communauté bienveillante."
                               style="-fx-font-size: 13px; -fx-text-fill: #5A6C7D; -fx-wrap-text: true; -fx-font-weight: 500;"/>
                        <Label text="Découvrir →"
                               style="-fx-font-size: 13px; -fx-text-fill: #2C5F8A; -fx-font-weight: bold;"/>
                    </VBox>

                    <VBox fx:id="card3" spacing="10" HBox.hgrow="ALWAYS"
                          style="-fx-background-color: white;
                                 -fx-background-radius: 16;
                                 -fx-padding: 22;
                                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 10, 0, 0, 2);
                                 -fx-cursor: hand;"
                          onMouseEntered="#onCardHoverEnter"
                          onMouseExited="#onCardHoverExit">
                        <Label text="📚" style="-fx-font-size: 38px;"/>
                        <Label text="Ressources"
                               style="-fx-font-size: 16px; -fx-font-weight: bold;
                                      -fx-text-fill: #2C3E50;"/>
                        <Label text="Articles, méditations et outils pour votre bien-être."
                               style="-fx-font-size: 13px; -fx-text-fill: #5A6C7D; -fx-wrap-text: true; -fx-font-weight: 500;"/>
                        <Label text="Découvrir →"
                               style="-fx-font-size: 13px; -fx-text-fill: #2C5F8A; -fx-font-weight: bold;"/>
                    </VBox>

                </HBox>

                <!-- Section Mes Rendez-vous -->
                <VBox spacing="12"
                      style="-fx-background-color: white;
                             -fx-background-radius: 16;
                             -fx-padding: 22 25;
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 10, 0, 0, 2);">
                    <HBox alignment="CENTER_LEFT">
                        <Label text="Mes Prochains Rendez-vous"
                               style="-fx-font-size: 17px; -fx-font-weight: bold;
                                      -fx-text-fill: #2C3E50;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Hyperlink text="Voir tout" onAction="#onNavRdvClicked_Btn"
                                   style="-fx-text-fill: #2C5F8A; -fx-font-weight: bold; -fx-cursor: hand; -fx-underline: false;"/>
                    </HBox>
                    <VBox fx:id="rdvHomeContainer" spacing="10">
                        <Label text="Chargement de vos rendez-vous..." style="-fx-text-fill: #94A3B8; -fx-font-size: 13px;"/>
                    </VBox>
                </VBox>

                <!-- Section avantages -->
                <VBox spacing="12"
                      style="-fx-background-color: white;
                             -fx-background-radius: 16;
                             -fx-padding: 22 25;
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 10, 0, 0, 2);">

                    <Label text="Pourquoi choisir MentalUp ?"
                           style="-fx-font-size: 17px; -fx-font-weight: bold;
                                  -fx-text-fill: #2C3E50;"/>

                    <HBox spacing="25">
                        <VBox fx:id="adv1" spacing="6" HBox.hgrow="ALWAYS" alignment="CENTER"
                              style="-fx-padding: 10; -fx-background-radius: 12; -fx-cursor: hand;"
                              onMouseEntered="#onAdvantageHoverEnter"
                              onMouseExited="#onAdvantageHoverExit">
                            <Label text="🎯" style="-fx-font-size: 28px;"/>
                            <Label text="100% Gratuit"
                                   style="-fx-font-size: 14px; -fx-font-weight: bold;
                                          -fx-text-fill: #2C3E50;"/>
                            <Label text="Pour tous les étudiants"
                                   style="-fx-font-size: 12px; -fx-text-fill: #5A6C7D; -fx-font-weight: 500;"/>
                        </VBox>

                        <VBox fx:id="adv2" spacing="6" HBox.hgrow="ALWAYS" alignment="CENTER"
                              style="-fx-padding: 10; -fx-background-radius: 12; -fx-cursor: hand;"
                              onMouseEntered="#onAdvantageHoverEnter"
                              onMouseExited="#onAdvantageHoverExit">
                            <Label text="🔒" style="-fx-font-size: 28px;"/>
                            <Label text="Confidentiel"
                                   style="-fx-font-size: 14px; -fx-font-weight: bold;
                                          -fx-text-fill: #2C3E50;"/>
                            <Label text="Données protégées"
                                   style="-fx-font-size: 12px; -fx-text-fill: #5A6C7D; -fx-font-weight: 500;"/>
                        </VBox>

                        <VBox fx:id="adv3" spacing="6" HBox.hgrow="ALWAYS" alignment="CENTER"
                              style="-fx-padding: 10; -fx-background-radius: 12; -fx-cursor: hand;"
                              onMouseEntered="#onAdvantageHoverEnter"
                              onMouseExited="#onAdvantageHoverExit">
                            <Label text="⏱️" style="-fx-font-size: 28px;"/>
                            <Label text="Disponible 24/7"
                                   style="-fx-font-size: 14px; -fx-font-weight: bold;
                                          -fx-text-fill: #2C3E50;"/>
                            <Label text="À tout moment"
                                   style="-fx-font-size: 12px; -fx-text-fill: #5A6C7D; -fx-font-weight: 500;"/>
                        </VBox>

                        <VBox fx:id="adv4" spacing="6" HBox.hgrow="ALWAYS" alignment="CENTER"
                              style="-fx-padding: 10; -fx-background-radius: 12; -fx-cursor: hand;"
                              onMouseEntered="#onAdvantageHoverEnter"
                              onMouseExited="#onAdvantageHoverExit">
                            <Label text="🤝" style="-fx-font-size: 28px;"/>
                            <Label text="Communauté active"
                                   style="-fx-font-size: 14px; -fx-font-weight: bold;
                                          -fx-text-fill: #2C3E50;"/>
                            <Label text="Entraide et partage"
                                   style="-fx-font-size: 12px; -fx-text-fill: #5A6C7D; -fx-font-weight: 500;"/>
                        </VBox>
                    </HBox>
                </VBox>



                <!-- Section Psychologues -->
                <VBox spacing="12"
                      style="-fx-background-color: white;
                             -fx-background-radius: 16;
                             -fx-padding: 22 25;
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 10, 0, 0, 2);">

                    <Label text="Nos Psychologues les mieux notés"
                           style="-fx-font-size: 17px; -fx-font-weight: bold;
                                  -fx-text-fill: #2C3E50;"/>

                    <HBox fx:id="psyListContainer" spacing="14" alignment="CENTER_LEFT">
                        <Label text="Chargement des praticiens..." style="-fx-text-fill: #94A3B8; -fx-font-size: 13px;"/>
                    </HBox>
                </VBox>
            </VBox>

        </VBox>
    </center>

</BorderPane>