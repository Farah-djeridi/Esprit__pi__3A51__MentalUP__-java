<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.ObjectifController"
            style="-fx-background-color: linear-gradient(to bottom, #f4f8ff, #eef4fb);">

    <top>
        <VBox spacing="0" style="-fx-padding: 4 10 0 10;">

            <VBox spacing="8"
                  style="-fx-background-color: white;
                         -fx-background-radius: 18;
                         -fx-effect: dropshadow(gaussian, rgba(30,58,95,0.08), 12, 0, 0, 2);
                         -fx-padding: 12 14 12 14;">

                <HBox alignment="CENTER_LEFT" spacing="10">
                    <VBox spacing="2">
                        <Label text="✨ MentalUp"
                               style="-fx-text-fill: #1e3a5f;
                                      -fx-font-size: 19px;
                                      -fx-font-weight: bold;"/>
                        <Label text="Espace objectifs"
                               style="-fx-text-fill: #7b8ba1;
                                      -fx-font-size: 11px;"/>
                    </VBox>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label text="mercredi 8 avril 2026"
                           style="-fx-text-fill: #9aa8b8;
                                  -fx-font-size: 11px;
                                  -fx-font-weight: 600;"/>
                </HBox>

                <VBox spacing="10"
                      style="-fx-background-color: linear-gradient(to right, #7BA6C9, #2C5F8A);
                             -fx-background-radius: 22;
                             -fx-padding: 28 26 28 26;
                             -fx-effect: dropshadow(gaussian, rgba(44,95,138,0.20), 12, 0, 0, 3);">

                    <Label text="Mes Objectifs"
                           style="-fx-text-fill: white;
                                  -fx-font-size: 32px;
                                  -fx-font-weight: 900;"/>

                    <Label text="Créez des objectifs simples, suivez votre progression, et gardez un historique clair"
                           style="-fx-text-fill: rgba(255,255,255,0.9);
                                  -fx-font-size: 14px;
                                  -fx-font-weight: 500;"/>
                </VBox>

                <HBox spacing="8">
                    <Button fx:id="ajouterTabButton"
                            text="➕ Ajouter"
                            onAction="#showAjouterSection"
                            style="-fx-background-color: linear-gradient(to right, #3b82f6, #2C5F8A);
                                   -fx-text-fill: white;
                                   -fx-font-size: 14px;
                                   -fx-font-weight: 800;
                                   -fx-background-radius: 20;
                                   -fx-padding: 8 18;
                                   -fx-cursor: hand;"/>

                    <Button fx:id="historiqueTabButton"
                            text="📅 Historique"
                            onAction="#showHistoriqueSection"
                            style="-fx-background-color: #f8fbff;
                                   -fx-text-fill: #234b7d;
                                   -fx-font-size: 14px;
                                   -fx-font-weight: 800;
                                   -fx-border-color: #d7e5f7;
                                   -fx-border-radius: 20;
                                   -fx-background-radius: 20;
                                   -fx-padding: 8 18;
                                   -fx-cursor: hand;"/>

                    <Button fx:id="resumeTabButton"
                            text="📊 Résumé"
                            onAction="#showResumeSection"
                            style="-fx-background-color: #f8fbff;
                                   -fx-text-fill: #234b7d;
                                   -fx-font-size: 14px;
                                   -fx-font-weight: 800;
                                   -fx-border-color: #d7e5f7;
                                   -fx-border-radius: 20;
                                   -fx-background-radius: 20;
                                   -fx-padding: 8 18;
                                   -fx-cursor: hand;"/>
                </HBox>
            </VBox>

            <Label fx:id="globalMessageLabel"
                   text=""
                   style="-fx-padding: 0;
                          -fx-font-size: 0;
                          -fx-background-color: transparent;"/>
        </VBox>
    </top>

    <center>
        <StackPane style="-fx-padding: 0 10 8 10;">

            <!-- AJOUT -->
            <ScrollPane fx:id="ajouterSectionScroll"
                        fitToWidth="true"
                        visible="true"
                        managed="true"
                        hbarPolicy="NEVER"
                        style="-fx-background-color: transparent;
                               -fx-background: transparent;
                               -fx-border-color: transparent;">
                <content>
                    <VBox fx:id="ajouterSection" spacing="4" style="-fx-padding: 0;">

                        <VBox spacing="8"
                              style="-fx-background-color: white;
                                     -fx-background-radius: 18;
                                     -fx-effect: dropshadow(gaussian, rgba(30,58,95,0.05), 8, 0, 0, 2);
                                     -fx-padding: 12;">

                            <HBox spacing="10" alignment="CENTER_LEFT">
                                <Label text="🎯" style="-fx-font-size: 24px;"/>
                                <Label text="Nouvel objectif"
                                       style="-fx-text-fill: #1e3a5f;
                                              -fx-font-size: 18px;
                                              -fx-font-weight: 900;"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Label text="Formulaire"
                                       style="-fx-text-fill: #1e3a5f;
                                              -fx-font-size: 10px;
                                              -fx-font-weight: 800;
                                              -fx-background-color: #eaf3ff;
                                              -fx-background-radius: 14;
                                              -fx-padding: 4 11;"/>
                            </HBox>

                            <Label text="Titre • Description • Dates • Activité • Type • Cible • Statut"
                                   style="-fx-text-fill: #7f8c9f;
                                          -fx-font-size: 12px;"/>
                        </VBox>

                        <VBox spacing="14"
                              style="-fx-background-color: white;
                                     -fx-background-radius: 18;
                                     -fx-effect: dropshadow(gaussian, rgba(30,58,95,0.05), 8, 0, 0, 2);
                                     -fx-padding: 14;">

                            <GridPane hgap="14" vgap="12">
                                <columnConstraints>
                                    <ColumnConstraints percentWidth="50"/>
                                    <ColumnConstraints percentWidth="50"/>
                                </columnConstraints>

                                <VBox spacing="6" GridPane.rowIndex="0" GridPane.columnIndex="0">
                                    <Label text="📝 Titre"
                                           style="-fx-text-fill: #1e3a5f;
                                                  -fx-font-size: 13px;
                                                  -fx-font-weight: 800;"/>
                                    <TextField fx:id="titreField"
                                               promptText="Ex: Réduire mon stress"
                                               style="-fx-background-color: #fbfdff;
                                                      -fx-background-radius: 12;
                                                      -fx-border-radius: 12;
                                                      -fx-border-color: #dbe7f5;
                                                      -fx-pref-height: 38px;
                                                      -fx-padding: 0 12;"/>
                                </VBox>

                                <VBox spacing="6" GridPane.rowIndex="0" GridPane.columnIndex="1">
                                    <Label text="📌 Statut"
                                           style="-fx-text-fill: #1e3a5f;
                                                  -fx-font-size: 13px;
                                                  -fx-font-weight: 800;"/>
                                    <ComboBox fx:id="statutCombo"
                                              style="-fx-background-color: #fbfdff;
                                                     -fx-background-radius: 12;
                                                     -fx-border-radius: 12;
                                                     -fx-border-color: #dbe7f5;
                                                     -fx-pref-height: 38px;"/>
                                </VBox>
                            </GridPane>

                            <VBox spacing="6">
                                <Label text="📖 Description"
                                       style="-fx-text-fill: #1e3a5f;
                                              -fx-font-size: 13px;
                                              -fx-font-weight: 800;"/>
                                <TextArea fx:id="descriptionArea"
                                          promptText="Décrivez votre objectif en quelques mots..."
                                          wrapText="true"
                                          prefRowCount="4"
                                          style="-fx-background-color: #fbfdff;
                                                 -fx-background-radius: 12;
                                                 -fx-border-radius: 12;
                                                 -fx-border-color: #dbe7f5;
                                                 -fx-padding: 8 10;"/>
                            </VBox>

                            <GridPane hgap="14" vgap="12">
                                <columnConstraints>
                                    <ColumnConstraints percentWidth="33"/>
                                    <ColumnConstraints percentWidth="33"/>
                                    <ColumnConstraints percentWidth="34"/>
                                </columnConstraints>

                                <VBox spacing="6" GridPane.rowIndex="0" GridPane.columnIndex="0">
                                    <Label text="📅 Date début"
                                           style="-fx-text-fill: #1e3a5f;
                                                  -fx-font-size: 13px;
                                                  -fx-font-weight: 800;"/>
                                    <DatePicker fx:id="dateDebutPicker"
                                                style="-fx-background-color: #fbfdff;
                                                       -fx-background-radius: 12;
                                                       -fx-border-radius: 12;
                                                       -fx-border-color: #dbe7f5;
                                                       -fx-pref-height: 38px;"/>
                                </VBox>

                                <VBox spacing="6" GridPane.rowIndex="0" GridPane.columnIndex="1">
                                    <Label text="🏁 Date fin"
                                           style="-fx-text-fill: #1e3a5f;
                                                  -fx-font-size: 13px;
                                                  -fx-font-weight: 800;"/>
                                    <DatePicker fx:id="dateFinPicker"
                                                style="-fx-background-color: #fbfdff;
                                                       -fx-background-radius: 12;
                                                       -fx-border-radius: 12;
                                                       -fx-border-color: #dbe7f5;
                                                       -fx-pref-height: 38px;"/>
                                </VBox>

                                <VBox spacing="6" GridPane.rowIndex="0" GridPane.columnIndex="2">
                                    <Label text="🎯 Activité"
                                           style="-fx-text-fill: #1e3a5f;
                                                  -fx-font-size: 13px;
                                                  -fx-font-weight: 800;"/>
                                    <ComboBox fx:id="activiteCombo"
                                              style="-fx-background-color: #fbfdff;
                                                     -fx-background-radius: 12;
                                                     -fx-border-radius: 12;
                                                     -fx-border-color: #dbe7f5;
                                                     -fx-pref-height: 38px;"/>
                                </VBox>
                            </GridPane>

                            <GridPane hgap="14" vgap="12">
                                <columnConstraints>
                                    <ColumnConstraints percentWidth="50"/>
                                    <ColumnConstraints percentWidth="50"/>
                                </columnConstraints>

                                <VBox spacing="6" GridPane.rowIndex="0" GridPane.columnIndex="0">
                                    <Label text="🏷️ Type d'objectif"
                                           style="-fx-text-fill: #1e3a5f;
                                                  -fx-font-size: 13px;
                                                  -fx-font-weight: 800;"/>
                                    <ComboBox fx:id="typeObjectifCombo"
                                              style="-fx-background-color: #fbfdff;
                                                     -fx-background-radius: 12;
                                                     -fx-border-radius: 12;
                                                     -fx-border-color: #dbe7f5;
                                                     -fx-pref-height: 38px;"/>
                                </VBox>

                                <VBox spacing="6" GridPane.rowIndex="0" GridPane.columnIndex="1">
                                    <Label text="🎯 Valeur cible"
                                           style="-fx-text-fill: #1e3a5f;
                                                  -fx-font-size: 13px;
                                                  -fx-font-weight: 800;"/>
                                    <TextField fx:id="valeurCibleField"
                                               promptText="Ex: 3.5"
                                               style="-fx-background-color: #fbfdff;
                                                      -fx-background-radius: 12;
                                                      -fx-border-radius: 12;
                                                      -fx-border-color: #dbe7f5;
                                                      -fx-pref-height: 38px;
                                                      -fx-padding: 0 12;"/>
                                </VBox>
                            </GridPane>

                            <Label fx:id="messageLabel" text=""
                                   style="-fx-font-size: 12px; -fx-font-weight: bold;"/>

                            <HBox spacing="10" alignment="CENTER_RIGHT">
                                <Button text="🗑️ Annuler"
                                        onAction="#annulerFormulaire"
                                        style="-fx-background-color: #f1f5f9;
                                               -fx-text-fill: #64748b;
                                               -fx-font-size: 12px;
                                               -fx-font-weight: 800;
                                               -fx-background-radius: 18;
                                               -fx-padding: 9 18;
                                               -fx-cursor: hand;"/>

                                <Button fx:id="saveButton"
                                        text="💾 Ajouter"
                                        onAction="#ajouterObjectif"
                                        style="-fx-background-color: linear-gradient(to right, #234b7d, #2f5d97);
                                               -fx-text-fill: white;
                                               -fx-font-size: 12px;
                                               -fx-font-weight: 900;
                                               -fx-background-radius: 18;
                                               -fx-padding: 9 22;
                                               -fx-cursor: hand;"/>
                            </HBox>
                        </VBox>
                    </VBox>
                </content>
            </ScrollPane>

            <!-- HISTORIQUE -->
            <VBox fx:id="historiqueSection"
                  spacing="4"
                  visible="false"
                  managed="false">

                <VBox spacing="6"
                      style="-fx-background-color: white;
                             -fx-background-radius: 18;
                             -fx-effect: dropshadow(gaussian, rgba(30,58,95,0.05), 8, 0, 0, 2);
                             -fx-padding: 12;">

                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Label text="📅" style="-fx-font-size: 24px;"/>
                        <Label text="Historique des objectifs"
                               style="-fx-text-fill: #1e3a5f;
                                      -fx-font-size: 18px;
                                      -fx-font-weight: 900;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label text="Recherche"
                               style="-fx-text-fill: #1e3a5f;
                                      -fx-font-size: 10px;
                                      -fx-font-weight: 800;
                                      -fx-background-color: #eaf3ff;
                                      -fx-background-radius: 14;
                                      -fx-padding: 4 11;"/>
                    </HBox>

                    <Label text="Recherchez et gérez vos objectifs"
                           style="-fx-text-fill: #7f8c9f;
                                  -fx-font-size: 12px;"/>

                    <HBox spacing="10" style="-fx-padding: 4 0 0 0;">
                        <TextField fx:id="searchTitreField"
                                   promptText="🔍 Rechercher par titre..."
                                   onKeyReleased="#filtrerHistorique"
                                   prefWidth="320"
                                   style="-fx-background-color: #fbfdff;
                                          -fx-background-radius: 12;
                                          -fx-border-radius: 12;
                                          -fx-border-color: #dbe7f5;
                                          -fx-pref-height: 36px;
                                          -fx-padding: 0 12;"/>

                        <DatePicker fx:id="searchDateCreationPicker"
                                    onAction="#filtrerHistorique"
                                    prefWidth="200"
                                    promptText="Date création"
                                    style="-fx-background-color: #fbfdff;
                                           -fx-background-radius: 12;
                                           -fx-border-radius: 12;
                                           -fx-border-color: #dbe7f5;
                                           -fx-pref-height: 36px;"/>

                        <ComboBox fx:id="searchStatutCombo"
                                  onAction="#filtrerHistorique"
                                  prefWidth="200"
                                  promptText="Statut"
                                  style="-fx-background-color: #fbfdff;
                                         -fx-background-radius: 12;
                                         -fx-border-radius: 12;
                                         -fx-border-color: #dbe7f5;
                                         -fx-pref-height: 36px;"/>

                        <Button text="🔄 Réinitialiser"
                                onAction="#resetFiltresHistorique"
                                style="-fx-background-color: #f1f5f9;
                                       -fx-text-fill: #64748b;
                                       -fx-font-size: 12px;
                                       -fx-font-weight: 800;
                                       -fx-background-radius: 18;
                                       -fx-padding: 8 18;
                                       -fx-cursor: hand;"/>
                    </HBox>
                </VBox>

                <ScrollPane fitToWidth="true"
                            style="-fx-background-color: transparent;
                                   -fx-background: transparent;
                                   -fx-border-color: transparent;">
                    <content>
                        <VBox fx:id="historiqueContainer"
                              spacing="8"
                              style="-fx-background-color: transparent; -fx-padding: 0;"/>
                    </content>
                </ScrollPane>
            </VBox>

            <!-- RÉSUMÉ -->
            <VBox fx:id="resumeSection"
                  spacing="8"
                  visible="false"
                  managed="false">

                <VBox spacing="6"
                      style="-fx-background-color: white;
                             -fx-background-radius: 18;
                             -fx-effect: dropshadow(gaussian, rgba(30,58,95,0.05), 8, 0, 0, 2);
                             -fx-padding: 12;">

                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Label text="📊" style="-fx-font-size: 24px;"/>
                        <Label text="Résumé"
                               style="-fx-text-fill: #1e3a5f;
                                      -fx-font-size: 18px;
                                      -fx-font-weight: 900;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label text="Tableau de bord"
                               style="-fx-text-fill: #1e3a5f;
                                      -fx-font-size: 10px;
                                      -fx-font-weight: 800;
                                      -fx-background-color: #eaf3ff;
                                      -fx-background-radius: 14;
                                      -fx-padding: 4 11;"/>
                    </HBox>

                    <Label text="Vue d'ensemble de vos objectifs"
                           style="-fx-text-fill: #7f8c9f;
                                  -fx-font-size: 12px;"/>
                </VBox>

                <HBox spacing="8">
                    <VBox spacing="6" HBox.hgrow="ALWAYS"
                          style="-fx-background-color: linear-gradient(to bottom right, #234b7d, #2f5d97);
                                 -fx-background-radius: 16;
                                 -fx-padding: 14;">
                        <Label text="📋 Total objectifs"
                               style="-fx-text-fill: #dbe8f8;
                                      -fx-font-size: 11px;
                                      -fx-font-weight: 700;"/>
                        <Label fx:id="totalObjectifsLabel" text="0"
                               style="-fx-text-fill: white;
                                      -fx-font-size: 24px;
                                      -fx-font-weight: 900;"/>
                    </VBox>

                    <VBox spacing="6" HBox.hgrow="ALWAYS"
                          style="-fx-background-color: linear-gradient(to bottom right, #315f97, #3f75b8);
                                 -fx-background-radius: 16;
                                 -fx-padding: 14;">
                        <Label text="✅ Objectifs atteints"
                               style="-fx-text-fill: #dbe8f8;
                                      -fx-font-size: 11px;
                                      -fx-font-weight: 700;"/>
                        <Label fx:id="objectifsAtteintsLabel" text="0"
                               style="-fx-text-fill: white;
                                      -fx-font-size: 24px;
                                      -fx-font-weight: 900;"/>
                    </VBox>

                    <VBox spacing="6" HBox.hgrow="ALWAYS"
                          style="-fx-background-color: linear-gradient(to bottom right, #3f75b8, #4d87c8);
                                 -fx-background-radius: 16;
                                 -fx-padding: 14;">
                        <Label text="🔄 En cours"
                               style="-fx-text-fill: #dbe8f8;
                                      -fx-font-size: 11px;
                                      -fx-font-weight: 700;"/>
                        <Label fx:id="objectifsEnCoursLabel" text="0"
                               style="-fx-text-fill: white;
                                      -fx-font-size: 24px;
                                      -fx-font-weight: 900;"/>
                    </VBox>
                </HBox>

                <HBox spacing="8">
                    <VBox HBox.hgrow="ALWAYS"
                          style="-fx-background-color: white;
                                 -fx-background-radius: 18;
                                 -fx-effect: dropshadow(gaussian, rgba(30,58,95,0.05), 8, 0, 0, 2);
                                 -fx-padding: 14;">
                        <Label text="Répartition des statuts"
                               style="-fx-text-fill: #1e3a5f;
                                      -fx-font-size: 15px;
                                      -fx-font-weight: 900;"/>
                        <PieChart fx:id="pieChartStatuts"
                                  prefHeight="280"
                                  legendVisible="false"
                                  labelsVisible="true"
                                  style="-fx-background-color: transparent;"/>
                    </VBox>

                    <VBox HBox.hgrow="ALWAYS"
                          style="-fx-background-color: white;
                                 -fx-background-radius: 18;
                                 -fx-effect: dropshadow(gaussian, rgba(30,58,95,0.05), 8, 0, 0, 2);
                                 -fx-padding: 14;">
                        <Label text="Progression moyenne par type"
                               style="-fx-text-fill: #1e3a5f;
                                      -fx-font-size: 15px;
                                      -fx-font-weight: 900;"/>
                        <BarChart fx:id="barChartProgressionType"
                                  prefHeight="280"
                                  animated="false"
                                  legendVisible="false"
                                  style="-fx-background-color: transparent;">
                            <xAxis>
                                <CategoryAxis fx:id="xAxisProgressionType"
                                              label="Types"
                                              tickLabelRotation="-15"
                                              tickLabelFill="#4B5563"/>
                            </xAxis>
                            <yAxis>
                                <NumberAxis fx:id="yAxisProgressionType"
                                            label="Progression moyenne"
                                            tickLabelFill="#4B5563"/>
                            </yAxis>
                        </BarChart>
                    </VBox>
                </HBox>
            </VBox>

        </StackPane>
    </center>
</BorderPane>