<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.shape.*?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="Controllor.ObjectifController"
            prefWidth="1500" prefHeight="920"
            style="-fx-background-color: linear-gradient(to bottom, #f4f8ff, #eef4fb);">

    <left>
        <VBox prefWidth="240"
              style="-fx-background-color: linear-gradient(to bottom, #D6E8F7, #2C5F8A);">

            <VBox alignment="CENTER"
                  spacing="8"
                  style="-fx-padding: 22 0 18 0;
                         -fx-border-color: transparent transparent rgba(255,255,255,0.12) transparent;
                         -fx-border-width: 0 0 1 0;">

                <StackPane style="-fx-background-color: rgba(255,255,255,0.18);
                                  -fx-background-radius: 50;
                                  -fx-padding: 10;">
                    <ImageView fx:id="logoImage"
                               fitWidth="72"
                               fitHeight="72"
                               preserveRatio="true"/>
                </StackPane>

                <Label text="MentalUp"
                       style="-fx-text-fill: #123553;
                              -fx-font-size: 18px;
                              -fx-font-weight: bold;"/>

                <Label text="Bien-être étudiant"
                       style="-fx-text-fill: #355f84;
                              -fx-font-size: 12px;
                              -fx-font-weight: 600;"/>
            </VBox>

            <VBox spacing="4" style="-fx-padding: 20 14 0 14;" VBox.vgrow="ALWAYS">

                <HBox alignment="CENTER_LEFT" spacing="12"
                      fx:id="navAccueil"
                      onMouseClicked="#onNavHomeClicked"
                      onMouseEntered="#onNavHoverEnter"
                      onMouseExited="#onNavHoverExit"
                      style="-fx-background-color: transparent;
                             -fx-background-radius: 8;
                             -fx-padding: 10 14;
                             -fx-cursor: hand;">
                    <Label text="🏠" style="-fx-font-size: 16px; -fx-text-fill: white;"/>
                    <Label text="Accueil"
                           style="-fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: 500;"/>
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="12"
                      fx:id="navSuivi"
                      onMouseClicked="#onNavSuiviClicked"
                      onMouseEntered="#onNavHoverEnter"
                      onMouseExited="#onNavHoverExit"
                      style="-fx-background-color: transparent;
                             -fx-background-radius: 8;
                             -fx-padding: 10 14;
                             -fx-cursor: hand;">
                    <Label text="📈" style="-fx-font-size: 16px; -fx-text-fill: white;"/>
                    <Label text="Suivi"
                           style="-fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: 500;"/>
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="12"
                      fx:id="navObjectifs"
                      onMouseClicked="#onNavObjectifsClicked"
                      onMouseEntered="#onNavHoverEnter"
                      onMouseExited="#onNavHoverExit"
                      style="-fx-background-color: #1E4568;
                             -fx-background-radius: 8;
                             -fx-padding: 10 14;
                             -fx-cursor: hand;
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 5, 0, 0, 2);">
                    <Label text="🎯" style="-fx-font-size: 16px; -fx-text-fill: white;"/>
                    <Label text="Objectifs"
                           style="-fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="12"
                      fx:id="navRdv"
                      onMouseClicked="#onNavRdvClicked"
                      onMouseEntered="#onNavHoverEnter"
                      onMouseExited="#onNavHoverExit"
                      style="-fx-background-color: transparent;
                             -fx-background-radius: 8;
                             -fx-padding: 10 14;
                             -fx-cursor: hand;">
                    <Label text="📅" style="-fx-font-size: 16px; -fx-text-fill: white;"/>
                    <Label text="Rendez-vous"
                           style="-fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: 500;"/>
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="12"
                      fx:id="navForum"
                      onMouseClicked="#onNavBlogClicked"
                      onMouseEntered="#onNavHoverEnter"
                      onMouseExited="#onNavHoverExit"
                      style="-fx-background-color: transparent;
                             -fx-background-radius: 8;
                             -fx-padding: 10 14;
                             -fx-cursor: hand;">
                    <Label text="💬" style="-fx-font-size: 16px; -fx-text-fill: white;"/>
                    <Label text="Forum"
                           style="-fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: 500;"/>
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="12"
                      fx:id="navActivites"
                      onMouseClicked="#onNavActivitesClicked"
                      onMouseEntered="#onNavHoverEnter"
                      onMouseExited="#onNavHoverExit"
                      style="-fx-background-color: transparent;
                             -fx-background-radius: 8;
                             -fx-padding: 10 14;
                             -fx-cursor: hand;">
                    <Label text="⚡" style="-fx-font-size: 16px; -fx-text-fill: white;"/>
                    <Label text="Activités"
                           style="-fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: 500;"/>
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="12"
                      fx:id="navRessources"
                      onMouseClicked="#onNavRessourcesClicked"
                      onMouseEntered="#onNavHoverEnter"
                      onMouseExited="#onNavHoverExit"
                      style="-fx-background-color: transparent;
                             -fx-background-radius: 8;
                             -fx-padding: 10 14;
                             -fx-cursor: hand;">
                    <Label text="📚" style="-fx-font-size: 16px; -fx-text-fill: white;"/>
                    <Label text="Ressources"
                           style="-fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: 500;"/>
                </HBox>
            </VBox>

            <VBox spacing="6"
                  style="-fx-padding: 16 14 20 14;
                         -fx-border-color: rgba(255,255,255,0.2);
                         -fx-border-width: 1 0 0 0;">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Circle radius="18" style="-fx-fill: rgba(255,255,255,0.25);"/>
                    <Label fx:id="avatarInitials" text="SA"
                           style="-fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-translate-x: -28;"/>
                    <VBox spacing="1">
                        <Label fx:id="labelUserName" text="Sophie Amara"
                               style="-fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold;"/>
                        <Label text="Étudiant"
                               style="-fx-text-fill: rgba(255,255,255,0.65); -fx-font-size: 11px; -fx-font-weight: 500;"/>
                    </VBox>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button fx:id="logoutButton" text="⏻" onAction="#onLogout"
                            style="-fx-background-color: rgba(255,255,255,0.15);
                                   -fx-text-fill: white;
                                   -fx-background-radius: 6;
                                   -fx-padding: 5 10;
                                   -fx-cursor: hand;
                                   -fx-font-size: 12px;
                                   -fx-font-weight: bold;"/>
                </HBox>
            </VBox>
        </VBox>
    </left>

    <center>
        <VBox spacing="0">
            <VBox spacing="10" style="-fx-padding: 15 20 0 20;">

                <VBox spacing="12"
                      style="-fx-background-color: white;
                             -fx-background-radius: 18;
                             -fx-effect: dropshadow(gaussian, rgba(30,58,95,0.08), 12, 0, 0, 2);
                             -fx-padding: 20 25 20 25;">

                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <VBox spacing="2">
                            <Label text="✨ MentalUp"
                                   style="-fx-text-fill: #1e3a5f;
                                          -fx-font-size: 19px;
                                          -fx-font-weight: bold;"/>
                            <Label text="Espace objectifs"
                                   style="-fx-text-fill: #7b8ba1;
                                          -fx-font-size: 11px;"/>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="labelDate" text="mercredi 8 avril 2026"
                               style="-fx-text-fill: #9aa8b8;
                                      -fx-font-size: 11px;
                                      -fx-font-weight: 600;"/>
                    </HBox>

                    <VBox spacing="10"
                          style="-fx-background-color: linear-gradient(to right, #7BA6C9, #2C5F8A);
                                 -fx-background-radius: 22;
                                 -fx-padding: 28 26 28 26;
                                 -fx-effect: dropshadow(gaussian, rgba(44,95,138,0.20), 12, 0, 0, 3);">

                        <Label text="Mes Objectifs"
                               style="-fx-text-fill: white;
                                      -fx-font-size: 32px;
                                      -fx-font-weight: 900;"/>

                        <Label text="Créez des objectifs simples, suivez votre progression, et gardez un historique clair"
                               style="-fx-text-fill: rgba(255,255,255,0.9);
                                      -fx-font-size: 14px;
                                      -fx-font-weight: 500;"/>
                    </VBox>

                    <HBox spacing="8">
                        <Button fx:id="ajouterTabButton"
                                text="➕ Ajouter"
                                onAction="#showAjouterSection"
                                style="-fx-background-color: linear-gradient(to right, #3b82f6, #2C5F8A);
                                       -fx-text-fill: white;
                                       -fx-font-size: 14px;
                                       -fx-font-weight: 800;
                                       -fx-background-radius: 20;
                                       -fx-padding: 8 18;
                                       -fx-cursor: hand;"/>

                        <Button fx:id="historiqueTabButton"
                                text="📅 Historique"
                                onAction="#showHistoriqueSection"
                                style="-fx-background-color: #f8fbff;
                                       -fx-text-fill: #234b7d;
                                       -fx-font-size: 14px;
                                       -fx-font-weight: 800;
                                       -fx-border-color: #d7e5f7;
                                       -fx-border-radius: 20;
                                       -fx-background-radius: 20;
                                       -fx-padding: 8 18;
                                       -fx-cursor: hand;"/>

                        <Button fx:id="resumeTabButton"
                                text="📊 Résumé"
                                onAction="#showResumeSection"
                                style="-fx-background-color: #f8fbff;
                                       -fx-text-fill: #234b7d;
                                       -fx-font-size: 14px;
                                       -fx-font-weight: 800;
                                       -fx-border-color: #d7e5f7;
                                       -fx-border-radius: 20;
                                       -fx-background-radius: 20;
                                       -fx-padding: 8 18;
                                       -fx-cursor: hand;"/>
                    </HBox>
                </VBox>

                <Label fx:id="globalMessageLabel"
                       text=""
                       style="-fx-padding: 0;
                              -fx-font-size: 0;
                              -fx-background-color: transparent;"/>
            </VBox>

            <StackPane style="-fx-padding: 15 20 20 20;" VBox.vgrow="ALWAYS">
                <children>
                    <!-- AJOUT -->
                    <ScrollPane fx:id="ajouterSectionScroll"
                                fitToWidth="true"
                                visible="true"
                                managed="true"
                                hbarPolicy="NEVER"
                                style="-fx-background-color: transparent;
                                       -fx-background: transparent;
                                       -fx-border-color: transparent;">
                        <content>
                            <VBox fx:id="ajouterSection" spacing="4" style="-fx-padding: 0;">

                                <VBox spacing="8"
                                      style="-fx-background-color: white;
                                             -fx-background-radius: 18;
                                             -fx-effect: dropshadow(gaussian, rgba(30,58,95,0.05), 8, 0, 0, 2);
                                             -fx-padding: 12;">

                                    <HBox spacing="10" alignment="CENTER_LEFT">
                                        <Label text="🎯" style="-fx-font-size: 24px;"/>
                                        <Label text="Nouvel objectif"
                                               style="-fx-text-fill: #1e3a5f;
                                                      -fx-font-size: 18px;
                                                      -fx-font-weight: 900;"/>
                                        <Region HBox.hgrow="ALWAYS"/>
                                        <Label text="Formulaire"
                                               style="-fx-text-fill: #1e3a5f;
                                                      -fx-font-size: 10px;
                                                      -fx-font-weight: 800;
                                                      -fx-background-color: #eaf3ff;
                                                      -fx-background-radius: 14;
                                                      -fx-padding: 4 11;"/>
                                    </HBox>

                                    <Label text="Titre • Description • Dates • Activité • Type • Cible • Statut"
                                           style="-fx-text-fill: #7f8c9f;
                                                  -fx-font-size: 12px;"/>
                                </VBox>

                                <VBox spacing="14"
                                      style="-fx-background-color: white;
                                             -fx-background-radius: 18;
                                             -fx-effect: dropshadow(gaussian, rgba(30,58,95,0.05), 8, 0, 0, 2);
                                             -fx-padding: 14;">

                                    <GridPane hgap="14" vgap="12">
                                        <columnConstraints>
                                            <ColumnConstraints percentWidth="50"/>
                                            <ColumnConstraints percentWidth="50"/>
                                        </columnConstraints>

                                        <VBox spacing="6" GridPane.rowIndex="0" GridPane.columnIndex="0">
                                            <Label text="📝 Titre"
                                                   style="-fx-text-fill: #1e3a5f;
                                                          -fx-font-size: 13px;
                                                          -fx-font-weight: 800;"/>
                                            <TextField fx:id="titreField"
                                                       promptText="Ex: Réduire mon stress"
                                                       style="-fx-background-color: #fbfdff;
                                                              -fx-background-radius: 12;
                                                              -fx-border-radius: 12;
                                                              -fx-border-color: #dbe7f5;
                                                              -fx-pref-height: 38px;
                                                              -fx-padding: 0 12;"/>
                                        </VBox>

                                        <VBox spacing="6" GridPane.rowIndex="0" GridPane.columnIndex="1">
                                            <Label text="📌 Statut"
                                                   style="-fx-text-fill: #1e3a5f;
                                                          -fx-font-size: 13px;
                                                          -fx-font-weight: 800;"/>
                                            <ComboBox fx:id="statutCombo"
                                                      style="-fx-background-color: #fbfdff;
                                                             -fx-background-radius: 12;
                                                             -fx-border-radius: 12;
                                                             -fx-border-color: #dbe7f5;
                                                             -fx-pref-height: 38px;"/>
                                        </VBox>
                                    </GridPane>

                                    <VBox spacing="6">
                                        <Label text="📖 Description"
                                               style="-fx-text-fill: #1e3a5f;
                                                      -fx-font-size: 13px;
                                                      -fx-font-weight: 800;"/>
                                        <TextArea fx:id="descriptionArea"
                                                  promptText="Décrivez votre objectif en quelques mots..."
                                                  wrapText="true"
                                                  prefRowCount="4"
                                                  style="-fx-background-color: #fbfdff;
                                                         -fx-background-radius: 12;
                                                         -fx-border-radius: 12;
                                                         -fx-border-color: #dbe7f5;
                                                         -fx-padding: 8 10;"/>
                                    </VBox>

                                    <GridPane hgap="14" vgap="12">
                                        <columnConstraints>
                                            <ColumnConstraints percentWidth="33"/>
                                            <ColumnConstraints percentWidth="33"/>
                                            <ColumnConstraints percentWidth="34"/>
                                        </columnConstraints>

                                        <VBox spacing="6" GridPane.rowIndex="0" GridPane.columnIndex="0">
                                            <Label text="📅 Date début"
                                                   style="-fx-text-fill: #1e3a5f;
                                                          -fx-font-size: 13px;
                                                          -fx-font-weight: 800;"/>
                                            <DatePicker fx:id="dateDebutPicker"
                                                        style="-fx-background-color: #fbfdff;
                                                               -fx-background-radius: 12;
                                                               -fx-border-radius: 12;
                                                               -fx-border-color: #dbe7f5;
                                                               -fx-pref-height: 38px;"/>
                                        </VBox>

                                        <VBox spacing="6" GridPane.rowIndex="0" GridPane.columnIndex="1">
                                            <Label text="🏁 Date fin"
                                                   style="-fx-text-fill: #1e3a5f;
                                                          -fx-font-size: 13px;
                                                          -fx-font-weight: 800;"/>
                                            <DatePicker fx:id="dateFinPicker"
                                                        style="-fx-background-color: #fbfdff;
                                                               -fx-background-radius: 12;
                                                               -fx-border-radius: 12;
                                                               -fx-border-color: #dbe7f5;
                                                               -fx-pref-height: 38px;"/>
                                        </VBox>

                                        <VBox spacing="6" GridPane.rowIndex="0" GridPane.columnIndex="2">
                                            <Label text="🎯 Activité"
                                                   style="-fx-text-fill: #1e3a5f;
                                                          -fx-font-size: 13px;
                                                          -fx-font-weight: 800;"/>
                                            <ComboBox fx:id="activiteCombo"
                                                      style="-fx-background-color: #fbfdff;
                                                             -fx-background-radius: 12;
                                                             -fx-border-radius: 12;
                                                             -fx-border-color: #dbe7f5;
                                                             -fx-pref-height: 38px;"/>
                                        </VBox>
                                    </GridPane>

                                    <GridPane hgap="14" vgap="12">
                                        <columnConstraints>
                                            <ColumnConstraints percentWidth="50"/>
                                            <ColumnConstraints percentWidth="50"/>
                                        </columnConstraints>

                                        <VBox spacing="6" GridPane.rowIndex="0" GridPane.columnIndex="0">
                                            <Label text="🏷️ Type d'objectif"
                                                   style="-fx-text-fill: #1e3a5f;
                                                          -fx-font-size: 13px;
                                                          -fx-font-weight: 800;"/>
                                            <ComboBox fx:id="typeObjectifCombo"
                                                      style="-fx-background-color: #fbfdff;
                                                             -fx-background-radius: 12;
                                                             -fx-border-radius: 12;
                                                             -fx-border-color: #dbe7f5;
                                                             -fx-pref-height: 38px;"/>
                                        </VBox>

                                        <VBox spacing="6" GridPane.rowIndex="0" GridPane.columnIndex="1">
                                            <Label text="🎯 Valeur cible"
                                                   style="-fx-text-fill: #1e3a5f;
                                                          -fx-font-size: 13px;
                                                          -fx-font-weight: 800;"/>
                                            <TextField fx:id="valeurCibleField"
                                                       promptText="Ex: 3.5"
                                                       style="-fx-background-color: #fbfdff;
                                                              -fx-background-radius: 12;
                                                              -fx-border-radius: 12;
                                                              -fx-border-color: #dbe7f5;
                                                              -fx-pref-height: 38px;
                                                              -fx-padding: 0 12;"/>
                                        </VBox>
                                    </GridPane>

                                    <Label fx:id="messageLabel" text=""
                                           style="-fx-font-size: 12px; -fx-font-weight: bold;"/>

                                    <HBox spacing="10" alignment="CENTER_RIGHT">
                                        <Button text="🗑️ Annuler"
                                                onAction="#annulerFormulaire"
                                                style="-fx-background-color: #f1f5f9;
                                                       -fx-text-fill: #64748b;
                                                       -fx-font-size: 12px;
                                                       -fx-font-weight: 800;
                                                       -fx-background-radius: 18;
                                                       -fx-padding: 9 18;
                                                       -fx-cursor: hand;"/>

                                        <Button fx:id="saveButton"
                                                text="💾 Ajouter"
                                                onAction="#ajouterObjectif"
                                                style="-fx-background-color: linear-gradient(to right, #234b7d, #2f5d97);
                                                       -fx-text-fill: white;
                                                       -fx-font-size: 12px;
                                                       -fx-font-weight: 900;
                                                       -fx-background-radius: 18;
                                                       -fx-padding: 9 22;
                                                       -fx-cursor: hand;"/>
                                    </HBox>
                                </VBox>
                            </VBox>
                        </content>
                    </ScrollPane>

                    <!-- HISTORIQUE -->
                    <VBox fx:id="historiqueSection"
                          spacing="4"
                          visible="false"
                          managed="false">

                        <VBox spacing="6"
                              style="-fx-background-color: white;
                                     -fx-background-radius: 18;
                                     -fx-effect: dropshadow(gaussian, rgba(30,58,95,0.05), 8, 0, 0, 2);
                                     -fx-padding: 12;">

                            <HBox spacing="10" alignment="CENTER_LEFT">
                                <Label text="📅" style="-fx-font-size: 24px;"/>
                                <Label text="Historique des objectifs"
                                       style="-fx-text-fill: #1e3a5f;
                                              -fx-font-size: 18px;
                                              -fx-font-weight: 900;"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Label text="Recherche"
                                       style="-fx-text-fill: #1e3a5f;
                                              -fx-font-size: 10px;
                                              -fx-font-weight: 800;
                                              -fx-background-color: #eaf3ff;
                                              -fx-background-radius: 14;
                                              -fx-padding: 4 11;"/>
                            </HBox>

                            <Label text="Recherchez et gérez vos objectifs"
                                   style="-fx-text-fill: #7f8c9f;
                                          -fx-font-size: 12px;"/>

                            <HBox spacing="10" style="-fx-padding: 4 0 0 0;">
                                <TextField fx:id="searchTitreField"
                                           promptText="🔍 Rechercher par titre..."
                                           onKeyReleased="#filtrerHistorique"
                                           prefWidth="320"
                                           style="-fx-background-color: #fbfdff;
                                                  -fx-background-radius: 12;
                                                  -fx-border-radius: 12;
                                                  -fx-border-color: #dbe7f5;
                                                  -fx-pref-height: 36px;
                                                  -fx-padding: 0 12;"/>

                                <DatePicker fx:id="searchDateCreationPicker"
                                            onAction="#filtrerHistorique"
                                            prefWidth="200"
                                            promptText="Date création"
                                            style="-fx-background-color: #fbfdff;
                                                   -fx-background-radius: 12;
                                                   -fx-border-radius: 12;
                                                   -fx-border-color: #dbe7f5;
                                                   -fx-pref-height: 36px;"/>

                                <ComboBox fx:id="searchStatutCombo"
                                          onAction="#filtrerHistorique"
                                          prefWidth="200"
                                          promptText="Statut"
                                          style="-fx-background-color: #fbfdff;
                                                 -fx-background-radius: 12;
                                                 -fx-border-radius: 12;
                                                 -fx-border-color: #dbe7f5;
                                                 -fx-pref-height: 36px;"/>

                                <Button text="🔄 Réinitialiser"
                                        onAction="#resetFiltresHistorique"
                                        style="-fx-background-color: #f1f5f9;
                                               -fx-text-fill: #64748b;
                                               -fx-font-size: 12px;
                                               -fx-font-weight: 800;
                                               -fx-background-radius: 18;
                                               -fx-padding: 8 18;
                                               -fx-cursor: hand;"/>
                            </HBox>
                        </VBox>

                        <ScrollPane fitToWidth="true"
                                    style="-fx-background-color: transparent;
                                           -fx-background: transparent;
                                           -fx-border-color: transparent;">
                            <content>
                                <VBox fx:id="historiqueContainer"
                                      spacing="8"
                                      style="-fx-background-color: transparent; -fx-padding: 0;"/>
                            </content>
                        </ScrollPane>
                    </VBox>

                    <!-- RÉSUMÉ -->
                    <VBox fx:id="resumeSection"
                          spacing="8"
                          visible="false"
                          managed="false">

                        <VBox spacing="6"
                              style="-fx-background-color: white;
                                     -fx-background-radius: 18;
                                     -fx-effect: dropshadow(gaussian, rgba(30,58,95,0.05), 8, 0, 0, 2);
                                     -fx-padding: 12;">

                            <HBox spacing="10" alignment="CENTER_LEFT">
                                <Label text="📊" style="-fx-font-size: 24px;"/>
                                <Label text="Résumé"
                                       style="-fx-text-fill: #1e3a5f;
                                              -fx-font-size: 18px;
                                              -fx-font-weight: 900;"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Label text="Tableau de bord"
                                       style="-fx-text-fill: #1e3a5f;
                                              -fx-font-size: 10px;
                                              -fx-font-weight: 800;
                                              -fx-background-color: #eaf3ff;
                                              -fx-background-radius: 14;
                                              -fx-padding: 4 11;"/>
                            </HBox>

                            <Label text="Vue d'ensemble de vos objectifs"
                                   style="-fx-text-fill: #7f8c9f;
                                          -fx-font-size: 12px;"/>
                        </VBox>

                        <HBox spacing="8">
                            <VBox spacing="6" HBox.hgrow="ALWAYS"
