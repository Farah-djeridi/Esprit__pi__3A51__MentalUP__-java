<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<?import javafx.scene.shape.*?>
<?import javafx.scene.chart.*?>


<?import javafx.scene.image.ImageView?>
<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="controllers.ControllerHomeAdmin"
            prefWidth="1024" prefHeight="700"
            style="-fx-background-color: #F4F8FF;">

    <left>
        <VBox prefWidth="260" prefHeight="700"
              style="-fx-background-color: #2C3E50;">

            <!-- Logo / Brand -->
            <HBox alignment="CENTER_LEFT" spacing="10"
                  style="-fx-padding: 24 18 20 18;
                         -fx-border-color: transparent transparent rgba(255,255,255,0.1) transparent;
                         -fx-border-width: 0 0 1 0;">
                <StackPane>
                    <ImageView fx:id="logoImage" fitWidth="45" fitHeight="45" preserveRatio="true"/>
                </StackPane>
                <VBox spacing="2">
                    <Label text="MentalUp Admin"
                           style="-fx-text-fill: white; -fx-font-size: 15px;
                                  -fx-font-weight: bold;"/>
                    <Label text="Espace d'administration"
                           style="-fx-text-fill: rgba(255,255,255,0.65); -fx-font-size: 11px; -fx-font-weight: 500;"/>
                </VBox>
            </HBox>


            <VBox spacing="2" style="-fx-padding: 16 12 0 12;" VBox.vgrow="ALWAYS">

                <!-- Accueil -->
                <HBox alignment="CENTER_LEFT" spacing="12"
                      fx:id="navAccueil"
                      onMouseClicked="#onNavHomeClicked"
                      style="-fx-background-color: #34495E;
                             -fx-background-radius: 8;
                             -fx-padding: 10 14;
                             -fx-cursor: hand;
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 5, 0, 0, 2);">
                    <Label text="🏠" style="-fx-font-size: 16px; -fx-text-fill: white;"/>
                    <Label text="Accueil"
                           style="-fx-text-fill: white; -fx-font-size: 14px;
                                  -fx-font-weight: bold;"/>
                </HBox>

                <!-- Suivi Mental avec sous-menu -->
                <VBox spacing="0">
                    <HBox alignment="CENTER_LEFT" spacing="12"
                          fx:id="navSuivi"
                          onMouseClicked="#toggleSuiviMenu"
                          onMouseEntered="#onNavHoverEnter"
                          onMouseExited="#onNavHoverExit"
                          style="-fx-background-color: transparent;
                                 -fx-background-radius: 8;
                                 -fx-padding: 10 14;
                                 -fx-cursor: hand;">
                        <Label text="📈" style="-fx-font-size: 16px; -fx-text-fill: rgba(255,255,255,0.85);"/>
                        <Label text="Suivi Mental"
                               style="-fx-text-fill: rgba(255,255,255,0.85); -fx-font-size: 14px; -fx-font-weight: 500;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="arrowSuivi" text="▶" style="-fx-text-fill: rgba(255,255,255,0.5); -fx-font-size: 11px;"/>
                    </HBox>

                    <!-- Sous-menu Suivi (masqué au départ) -->
                    <VBox fx:id="submenuSuivi" spacing="2" style="-fx-padding: 4 0 6 28; -fx-display: none;">
                        <HBox alignment="CENTER_LEFT" spacing="10"
                              fx:id="navSuiviStats"
                              onMouseClicked="#onNavSuiviStatsClicked"
                              onMouseEntered="#onSubmenuHoverEnter"
                              onMouseExited="#onSubmenuHoverExit"
                              style="-fx-background-radius: 6; -fx-padding: 8 12; -fx-cursor: hand;">
                            <Label text="📊" style="-fx-font-size: 13px; -fx-text-fill: rgba(255,255,255,0.55);"/>
                            <Label text="Statistiques"
                                   style="-fx-text-fill: rgba(255,255,255,0.7); -fx-font-size: 13px; -fx-font-weight: 500;"/>
                        </HBox>
                        <HBox alignment="CENTER_LEFT" spacing="10"
                              fx:id="navObjectifs"
                              onMouseClicked="#onNavObjectifsClicked"
                              onMouseEntered="#onSubmenuHoverEnter"
                              onMouseExited="#onSubmenuHoverExit"
                              style="-fx-background-radius: 6; -fx-padding: 8 12; -fx-cursor: hand;">
                            <Label text="🎯" style="-fx-font-size: 13px; -fx-text-fill: rgba(255,255,255,0.55);"/>
                            <Label text="Objectifs"
                                   style="-fx-text-fill: rgba(255,255,255,0.7); -fx-font-size: 13px; -fx-font-weight: 500;"/>
                        </HBox>
                    </VBox>
                </VBox>

                <!-- Forum avec sous-menu -->
                <VBox spacing="0">
                    <HBox alignment="CENTER_LEFT" spacing="12"
                          fx:id="navForum"
                          onMouseClicked="#toggleForumMenu"
                          onMouseEntered="#onNavHoverEnter"
                          onMouseExited="#onNavHoverExit"
                          style="-fx-background-color: transparent;
                                 -fx-background-radius: 8;
                                 -fx-padding: 10 14;
                                 -fx-cursor: hand;">
                        <Label text="💬" style="-fx-font-size: 16px; -fx-text-fill: rgba(255,255,255,0.85);"/>
                        <Label text="Forum"
                               style="-fx-text-fill: rgba(255,255,255,0.85); -fx-font-size: 14px; -fx-font-weight: 500;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="arrowForum" text="▶" style="-fx-text-fill: rgba(255,255,255,0.5); -fx-font-size: 11px;"/>
                    </HBox>

                    <!-- Sous-menu Forum (masqué au départ) -->
                    <VBox fx:id="submenuForum" spacing="2" style="-fx-padding: 4 0 6 28; -fx-display: none;">
                        <HBox alignment="CENTER_LEFT" spacing="10"
                              fx:id="navSujets"
                              onMouseClicked="#onNavSujetsClicked"
                              onMouseEntered="#onSubmenuHoverEnter"
                              onMouseExited="#onSubmenuHoverExit"
                              style="-fx-background-radius: 6; -fx-padding: 8 12; -fx-cursor: hand;">
                            <Label text="📝" style="-fx-font-size: 13px; -fx-text-fill: rgba(255,255,255,0.55);"/>
                            <Label text="Sujets"
                                   style="-fx-text-fill: rgba(255,255,255,0.7); -fx-font-size: 13px; -fx-font-weight: 500;"/>
                        </HBox>
                        <HBox alignment="CENTER_LEFT" spacing="10"
                              fx:id="navCommentaires"
                              onMouseClicked="#onNavCommentairesClicked"
                              onMouseEntered="#onSubmenuHoverEnter"
                              onMouseExited="#onSubmenuHoverExit"
                              style="-fx-background-radius: 6; -fx-padding: 8 12; -fx-cursor: hand;">
                            <Label text="💬" style="-fx-font-size: 13px; -fx-text-fill: rgba(255,255,255,0.55);"/>
                            <Label text="Commentaires"
                                   style="-fx-text-fill: rgba(255,255,255,0.7); -fx-font-size: 13px; -fx-font-weight: 500;"/>
                        </HBox>
                    </VBox>
                </VBox>

                <!-- Rendez-vous -->
                <HBox alignment="CENTER_LEFT" spacing="12"
                      fx:id="navRdv"
                      onMouseClicked="#onNavRdvClicked"
                      onMouseEntered="#onNavHoverEnter"
                      onMouseExited="#onNavHoverExit"
                      style="-fx-background-color: transparent;
                             -fx-background-radius: 8;
                             -fx-padding: 10 14;
                             -fx-cursor: hand;">
                    <Label text="📅" style="-fx-font-size: 16px; -fx-text-fill: rgba(255,255,255,0.85);"/>
                    <Label text="Rendez-vous"
                           style="-fx-text-fill: rgba(255,255,255,0.85); -fx-font-size: 14px; -fx-font-weight: 500;"/>
                </HBox>

                <!-- Utilisateurs -->
                <HBox alignment="CENTER_LEFT" spacing="12"
                      fx:id="navUtilisateurs"
                      onMouseClicked="#onNavUtilisateursClicked"
                      onMouseEntered="#onNavHoverEnter"
                      onMouseExited="#onNavHoverExit"
                      style="-fx-background-color: transparent;
                             -fx-background-radius: 8;
                             -fx-padding: 10 14;
                             -fx-cursor: hand;">
                    <Label text="👥" style="-fx-font-size: 16px; -fx-text-fill: rgba(255,255,255,0.85);"/>
                    <Label text="Utilisateurs"
                           style="-fx-text-fill: rgba(255,255,255,0.85); -fx-font-size: 14px; -fx-font-weight: 500;"/>
                </HBox>

                <!-- Dossiers médicaux -->
                <HBox alignment="CENTER_LEFT" spacing="12"
                      fx:id="navDossiers"
                      onMouseClicked="#onNavDossiersClicked"
                      onMouseEntered="#onNavHoverEnter"
                      onMouseExited="#onNavHoverExit"
                      style="-fx-background-color: transparent;
                             -fx-background-radius: 8;
                             -fx-padding: 10 14;
                             -fx-cursor: hand;">
                    <Label text="📋" style="-fx-font-size: 16px; -fx-text-fill: rgba(255,255,255,0.85);"/>
                    <Label text="Dossiers médicaux"
                           style="-fx-text-fill: rgba(255,255,255,0.85); -fx-font-size: 14px; -fx-font-weight: 500;"/>
                </HBox>

                <!-- Contenus -->
                <HBox alignment="CENTER_LEFT" spacing="12"
                      fx:id="navContenus"
                      onMouseClicked="#onNavContenusClicked"
                      onMouseEntered="#onNavHoverEnter"
                      onMouseExited="#onNavHoverExit"
                      style="-fx-background-color: transparent;
                             -fx-background-radius: 8;
                             -fx-padding: 10 14;
                             -fx-cursor: hand;">
                    <Label text="📝" style="-fx-font-size: 16px; -fx-text-fill: rgba(255,255,255,0.85);"/>
                    <Label text="Contenus"
                           style="-fx-text-fill: rgba(255,255,255,0.85); -fx-font-size: 14px; -fx-font-weight: 500;"/>
                </HBox>

                <!-- Activités -->
                <HBox alignment="CENTER_LEFT" spacing="12"
                      fx:id="navActivites"
                      onMouseClicked="#onNavActivitesClicked"
                      onMouseEntered="#onNavHoverEnter"
                      onMouseExited="#onNavHoverExit"
                      style="-fx-background-color: transparent;
                             -fx-background-radius: 8;
                             -fx-padding: 10 14;
                             -fx-cursor: hand;">
                    <Label text="⚡" style="-fx-font-size: 16px; -fx-text-fill: rgba(255,255,255,0.85);"/>
                    <Label text="Activités"
                           style="-fx-text-fill: rgba(255,255,255,0.85); -fx-font-size: 14px; -fx-font-weight: 500;"/>
                </HBox>

            </VBox>

            <!-- Profil administrateur -->
            <VBox spacing="6" style="-fx-padding: 16 14 20 14; -fx-border-color: rgba(255,255,255,0.08); -fx-border-width: 1 0 0 0;">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Circle radius="18" style="-fx-fill: rgba(255,255,255,0.15);"/>
                    <Label fx:id="avatarInitials" text="AD"
                           style="-fx-text-fill: white; -fx-font-size: 13px;
                                  -fx-font-weight: bold; -fx-translate-x: -28;"/>
                    <VBox spacing="1">
                        <Label fx:id="labelUserName" text="Admin MentalUp"
                               style="-fx-text-fill: white; -fx-font-size: 13px;
                                      -fx-font-weight: bold;"/>
                        <Label text="Super Administrateur"
                               style="-fx-text-fill: rgba(255,255,255,0.55); -fx-font-size: 11px; -fx-font-weight: 500;"/>
                    </VBox>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button fx:id="logoutButton" text="⏻" onAction="#onLogout"
                            style="-fx-background-color: rgba(255,255,255,0.1);
                                   -fx-text-fill: white;
                                   -fx-background-radius: 6;
                                   -fx-padding: 5 10;
                                   -fx-cursor: hand;
                                   -fx-font-size: 12px;
                                   -fx-font-weight: bold;"/>
                </HBox>
            </VBox>

        </VBox>
    </left>

   
    <center>
        <VBox spacing="0" prefWidth="764" prefHeight="700"
              style="-fx-background-color: #F4F8FF;">

            <!-- Barre supérieure -->
            <HBox alignment="CENTER_LEFT" spacing="12"
                  style="-fx-background-color: white;
                         -fx-padding: 14 24;
                         -fx-border-color: transparent transparent #E8EEF4 transparent;
                         -fx-border-width: 0 0 1 0;">
                <VBox spacing="2">
                    <Label text="Tableau de bord Administrateur 👑"
                           style="-fx-font-size: 18px; -fx-font-weight: bold;
                                  -fx-text-fill: #2C3E50;"/>
                    <Label fx:id="labelDate" text="Mardi 7 Avril 2026"
                           style="-fx-font-size: 12px; -fx-text-fill: #5A6C7D; -fx-font-weight: 500;"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="📄 Rapport Global" onAction="#handleDownloadGlobalPDF"
                        style="-fx-background-color: #f8fafc; -fx-text-fill: #2c3e50;
                               -fx-border-color: #2c3e50; -fx-border-radius: 8;
                               -fx-background-radius: 8; -fx-padding: 8 16;
                               -fx-cursor: hand; -fx-font-size: 13px;
                               -fx-font-weight: bold; -fx-font-family: 'Segoe UI';"/>
                <Button fx:id="notifButton" text="🔔" onAction="#onNotifications"
                        style="-fx-background-color: transparent;
                               -fx-text-fill: #5A6E7A;
                               -fx-padding: 6;
                               -fx-cursor: hand;
                               -fx-font-size: 16px;
                               -fx-border-color: #E8EEF4;
                               -fx-border-radius: 50;
                               -fx-border-width: 1;
                               -fx-min-width: 32;
                               -fx-min-height: 32;"/>
            </HBox>

            <!-- Page d'accueil Admin -->
            <VBox spacing="20" style="-fx-padding: 24 28 28 28;" VBox.vgrow="ALWAYS">

                <!-- Bannière Admin -->
                <HBox style="-fx-background-color: linear-gradient(to right, #2C3E50, #34495E);
                             -fx-background-radius: 20;
                             -fx-padding: 35 40;
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 15, 0, 0, 5);"
                      alignment="CENTER_LEFT">
                    <VBox spacing="12" HBox.hgrow="ALWAYS">
                        <Label text="🔐 Espace Administration"
                               style="-fx-text-fill: rgba(255,255,255,0.8);
                                      -fx-font-size: 15px; -fx-font-weight: bold;"/>
                        <Label text="Gérez MentalUp depuis un seul tableau de bord"
                               style="-fx-text-fill: white; -fx-font-size: 24px;
                                      -fx-font-weight: bold;"/>
                        <Label text="Utilisateurs, rendez-vous, forums, contenus et bien plus encore."
                               style="-fx-text-fill: rgba(255,255,255,0.75);
                                      -fx-font-size: 14px; -fx-font-weight: 500;"/>
                    </VBox>
                    <Label text="⚙️" style="-fx-font-size: 70px; -fx-opacity: 0.12;"
                           HBox.hgrow="NEVER"/>
                </HBox>

                <!-- Statistiques rapides (4 cartes) -->
                <HBox spacing="16">

                    <!-- Patients Actifs -->
                    <VBox spacing="8" HBox.hgrow="ALWAYS" onMouseClicked="#onNavUtilisateursClicked"
                          style="-fx-background-color: white;
                                 -fx-background-radius: 14;
                                 -fx-padding: 18;
                                 -fx-cursor: hand;
                                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 8, 0, 0, 2);">
                        <Label text="👥" style="-fx-font-size: 32px;"/>
                        <Label text="Patients Actifs"
                               style="-fx-font-size: 14px; -fx-text-fill: #5A6C7D; -fx-font-weight: 600;"/>
                        <Label fx:id="statPatients" text="1,234"
                               style="-fx-font-size: 28px; -fx-font-weight: bold;
                                      -fx-text-fill: #2C3E50;"/>
                        <Label text="Voir les détails →"
                               style="-fx-font-size: 12px; -fx-text-fill: #3498DB; -fx-font-weight: bold;"/>
                    </VBox>

                    <!-- Psychologues -->
                    <VBox spacing="8" HBox.hgrow="ALWAYS" onMouseClicked="#onNavUtilisateursClicked"
                          style="-fx-background-color: white;
                                 -fx-background-radius: 14;
                                 -fx-padding: 18;
                                 -fx-cursor: hand;
                                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 8, 0, 0, 2);">
                        <Label text="⚕️" style="-fx-font-size: 32px;"/>
                        <Label text="Psychologues"
                               style="-fx-font-size: 14px; -fx-text-fill: #5A6C7D; -fx-font-weight: 600;"/>
                        <Label fx:id="statPsychologues" text="45"
                               style="-fx-font-size: 28px; -fx-font-weight: bold;
                                      -fx-text-fill: #2C3E50;"/>
                        <Label text="Voir les détails →"
                               style="-fx-font-size: 12px; -fx-text-fill: #3498DB; -fx-font-weight: bold;"/>
                    </VBox>

                    <!-- Dossiers Médicaux -->
                    <VBox spacing="8" HBox.hgrow="ALWAYS" onMouseClicked="#onNavDossiersClicked"
                          style="-fx-background-color: white;
                                 -fx-background-radius: 14;
                                 -fx-padding: 18;
                                 -fx-cursor: hand;
                                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 8, 0, 0, 2);">
                        <Label text="📋" style="-fx-font-size: 32px;"/>
                        <Label text="Dossiers Médicaux"
                               style="-fx-font-size: 14px; -fx-text-fill: #5A6C7D; -fx-font-weight: 600;"/>
                        <Label fx:id="statDossiers" text="856"
                               style="-fx-font-size: 28px; -fx-font-weight: bold;
                                      -fx-text-fill: #2C3E50;"/>
                        <Label text="Voir les détails →"
                               style="-fx-font-size: 12px; -fx-text-fill: #3498DB; -fx-font-weight: bold;"/>
                    </VBox>

                    <!-- Rendez-vous -->
                    <VBox spacing="8" HBox.hgrow="ALWAYS" onMouseClicked="#onNavRdvClicked"
                          style="-fx-background-color: white;
                                 -fx-background-radius: 14;
                                 -fx-padding: 18;
                                 -fx-cursor: hand;
                                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 8, 0, 0, 2);">
                        <Label text="📅" style="-fx-font-size: 32px;"/>
                        <Label text="Rendez-vous"
                               style="-fx-font-size: 14px; -fx-text-fill: #5A6C7D; -fx-font-weight: 600;"/>
                        <Label fx:id="statRdvs" text="312"
                               style="-fx-font-size: 28px; -fx-font-weight: bold;
                                      -fx-text-fill: #2C3E50;"/>
                        <Label text="Voir les détails →"
                               style="-fx-font-size: 12px; -fx-text-fill: #3498DB; -fx-font-weight: bold;"/>
                    </VBox>

                </HBox>

                <!-- Charts -->
                <HBox spacing="16" VBox.vgrow="ALWAYS">
                    <VBox spacing="12" HBox.hgrow="ALWAYS"
                          style="-fx-background-color: white; -fx-background-radius: 16;
                                 -fx-padding: 22 25; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 8, 0, 0, 2);">
                        <Label text="📊 Répartition des Rendez-vous"
                               style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #2C3E50;"/>
                        <PieChart fx:id="pieChartRdvs" VBox.vgrow="ALWAYS" />
                    </VBox>

                    <VBox spacing="12" HBox.hgrow="ALWAYS"
                          style="-fx-background-color: white; -fx-background-radius: 16;
                                 -fx-padding: 22 25; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 8, 0, 0, 2);">
                        <Label text="📈 Répartition des Dossiers (Risque)"
                               style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #2C3E50;"/>
                        <PieChart fx:id="pieChartDossiers" VBox.vgrow="ALWAYS" />
                    </VBox>
                </HBox>

            </VBox>

        </VBox>
    </center>

</BorderPane>