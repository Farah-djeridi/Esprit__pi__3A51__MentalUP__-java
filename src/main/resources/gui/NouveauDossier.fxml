<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<?import javafx.scene.shape.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.collections.FXCollections?>
<?import java.lang.String?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="controllers.NouveauDossierController"
            prefWidth="1200" prefHeight="800">

    <left>
        <VBox prefWidth="280" style="-fx-background-color: #1a4a5f;">
            <HBox alignment="CENTER_LEFT" spacing="12" style="-fx-padding: 28 22 24 22;">
                <StackPane>
                    <ImageView fx:id="logoImage" fitWidth="40" fitHeight="40" preserveRatio="true"/>
                </StackPane>
                <VBox spacing="3">
                    <Label text="MentalUp" textFill="white" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
                    <Label text="Espace Psychologue" textFill="#8ca3b3" style="-fx-font-size: 12px;"/>
                </VBox>
            </HBox>

            <Separator style="-fx-background-color: #2a5a6f;"/>

            <VBox spacing="6" style="-fx-padding: 20 16 0 16;" VBox.vgrow="ALWAYS">
                <Label text="MENU PRINCIPAL" textFill="#6a8a9a" style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-padding: 0 0 8 12;"/>

                <HBox fx:id="navHome" onMouseClicked="#goHome" alignment="CENTER_LEFT" spacing="12" style="-fx-padding: 12 14; -fx-background-radius: 10; -fx-cursor: hand;">
                    <Label text="Accueil" textFill="white" style="-fx-font-size: 15px;"/>
                </HBox>

                <VBox spacing="2">
                    <HBox fx:id="navRdv" alignment="CENTER_LEFT" spacing="12" style="-fx-padding: 12 14; -fx-background-radius: 10; -fx-cursor: hand;">
                        <Label text="Rendez-vous" textFill="white" style="-fx-font-size: 15px;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="arrowRdv" text="▶" textFill="#6a8a9a" style="-fx-font-size: 10px;"/>
                    </HBox>
                </VBox>

                <VBox spacing="2">
                    <HBox fx:id="navDossiers" alignment="CENTER_LEFT" spacing="12" style="-fx-padding: 12 14; -fx-background-radius: 10; -fx-cursor: hand; -fx-background-color: #2a5a6f;">
                        <Label text="Dossiers médicaux" textFill="white" style="-fx-font-size: 15px;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="arrowDossiers" text="▼" textFill="white" style="-fx-font-size: 10px;"/>
                    </HBox>
                    <VBox fx:id="submenuDossiers" spacing="2" style="-fx-padding: 4 0 4 20;">
                        <HBox fx:id="navConsulterDossiers" alignment="CENTER_LEFT" spacing="10" style="-fx-padding: 10 12; -fx-background-radius: 8; -fx-cursor: hand;">
                            <Label text="• Consulter dossiers" textFill="#b0c4d4" style="-fx-font-size: 13px;"/>
                        </HBox>
                        <HBox fx:id="navNouveauDossier" alignment="CENTER_LEFT" spacing="10" style="-fx-padding: 10 12; -fx-background-radius: 8; -fx-cursor: hand; -fx-background-color: #2a5a6f;">
                            <Label text="• Nouveau dossier" textFill="white" style="-fx-font-size: 13px;"/>
                        </HBox>
                    </VBox>
                </VBox>
            </VBox>

            <Region VBox.vgrow="ALWAYS"/>

            <VBox spacing="14" style="-fx-padding: 20 20 25 20; -fx-border-color: #2a5a6f; -fx-border-width: 1 0 0 0;">
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <Circle radius="22" fill="#2a5a6f"/>
                    <VBox spacing="2">
                        <Label text="Psychologue" textFill="white" style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
                        <Label text="Compte professionnel" textFill="#6a8a9a" style="-fx-font-size: 11px;"/>
                    </VBox>
                </HBox>
                <Button fx:id="logoutBtn" text="Déconnexion" style="-fx-background-color: transparent; -fx-text-fill: #b0c4d4; -fx-border-color: #e74c3c; -fx-border-width: 1.5; -fx-background-radius: 8; -fx-border-radius: 8; -fx-padding: 10; -fx-cursor: hand; -fx-font-size: 13px; maxWidth: Infinity;"/>
            </VBox>
        </VBox>
    </left>

    <center>
        <VBox style="-fx-background-color: #F8FAFC;">

            <VBox style="-fx-background-color: #1a4a5f; -fx-padding: 20 30;">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label text="📊" textFill="white" style="-fx-font-size: 20px;"/>
                    <Label text="Informations du dossier médical" textFill="white" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
                </HBox>
            </VBox>

            <ScrollPane fitToWidth="true" style="-fx-background: transparent; -fx-background-color: transparent;" VBox.vgrow="ALWAYS">

                <VBox spacing="25" style="-fx-padding: 30;">

                    <VBox spacing="15" style="-fx-background-color: white; -fx-background-radius: 8; -fx-border-color: #E2E8F0 #E2E8F0 #E2E8F0 #1a4a5f; -fx-border-radius: 8; -fx-border-width: 1 1 1 4; -fx-padding: 25;">

                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <Label text="👤" style="-fx-font-size: 16px;"/>
                            <Label text="Sélection du patient" textFill="#1a4a5f" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
                        </HBox>

                        <VBox spacing="8">
                            <Label text="Patient" textFill="#475569" style="-fx-font-weight: bold; -fx-font-size: 14px;"/>
                            <ComboBox fx:id="patientComboBox" promptText="🔍  Sélectionner un patient" maxWidth="Infinity" style="-fx-background-color: white; -fx-border-color: #CBD5E1; -fx-border-radius: 6; -fx-padding: 4; -fx-font-size: 14px;"/>
                            <Label text="ℹ Sélectionnez un patient existant dans le système" textFill="#94A3B8" style="-fx-font-size: 12px;"/>
                        </VBox>
                    </VBox>

                    <HBox spacing="25">

                        <VBox spacing="15" HBox.hgrow="ALWAYS" style="-fx-background-color: white; -fx-background-radius: 8; -fx-border-color: #E2E8F0 #E2E8F0 #E2E8F0 #1a4a5f; -fx-border-radius: 8; -fx-border-width: 1 1 1 4; -fx-padding: 25;">
                            <HBox alignment="CENTER_LEFT" spacing="10">
                                <Label text="📅" style="-fx-font-size: 16px;"/>
                                <Label text="Date de création" textFill="#1a4a5f" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
                            </HBox>
                            <VBox spacing="8">
                                <Label text="Date de création" textFill="#475569" style="-fx-font-weight: bold; -fx-font-size: 14px;"/>
                                <DatePicker fx:id="datePicker" maxWidth="Infinity" style="-fx-background-color: white; -fx-border-color: #CBD5E1; -fx-border-radius: 6; -fx-padding: 4;"/>
                                <Label text="ℹ Date de création du dossier médical" textFill="#94A3B8" style="-fx-font-size: 12px;"/>
                            </VBox>
                        </VBox>

                        <VBox spacing="15" HBox.hgrow="ALWAYS" style="-fx-background-color: white; -fx-background-radius: 8; -fx-border-color: #E2E8F0 #E2E8F0 #E2E8F0 #1a4a5f; -fx-border-radius: 8; -fx-border-width: 1 1 1 4; -fx-padding: 25;">
                            <HBox alignment="CENTER_LEFT" spacing="10">
                                <Label text="⚠️" style="-fx-font-size: 16px;"/>
                                <Label text="Niveau de risque" textFill="#1a4a5f" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
                            </HBox>
                            <VBox spacing="12">
                                <Label text="Niveau de risque" textFill="#475569" style="-fx-font-weight: bold; -fx-font-size: 14px;"/>
                                <ComboBox fx:id="niveauRisqueBox" promptText="Sélectionner le risque" maxWidth="Infinity" style="-fx-background-color: white; -fx-border-color: #CBD5E1; -fx-border-radius: 6; -fx-padding: 4;">
                                    <items>
                                        <FXCollections fx:factory="observableArrayList">
                                            <String fx:value="Faible"/>
                                            <String fx:value="Modéré"/>
                                            <String fx:value="Élevé"/>
                                            <String fx:value="Critique"/>
                                        </FXCollections>
                                    </items>
                                </ComboBox>

                                <HBox spacing="10">
                                    <Label text="♡ Faible" style="-fx-text-fill: #10B981; -fx-border-color: #10B981; -fx-border-radius: 20; -fx-padding: 4 12; -fx-background-color: #F0FDF4; -fx-background-radius: 20;"/>
                                    <Label text="♡ Modéré" style="-fx-text-fill: #F59E0B; -fx-border-color: #F59E0B; -fx-border-radius: 20; -fx-padding: 4 12; -fx-background-color: #FFFBEB; -fx-background-radius: 20;"/>
                                    <Label text="♡ Élevé" style="-fx-text-fill: #EF4444; -fx-border-color: #EF4444; -fx-border-radius: 20; -fx-padding: 4 12; -fx-background-color: #FEF2F2; -fx-background-radius: 20;"/>
                                    <Label text="♡ Critique" style="-fx-text-fill: #991B1B; -fx-border-color: #991B1B; -fx-border-radius: 20; -fx-padding: 4 12; -fx-background-color: #FEF2F2; -fx-background-radius: 20;"/>
                                </HBox>
                            </VBox>
                        </VBox>
                    </HBox>

                    <VBox spacing="15" style="-fx-background-color: white; -fx-background-radius: 8; -fx-border-color: #E2E8F0 #E2E8F0 #E2E8F0 #1a4a5f; -fx-border-radius: 8; -fx-border-width: 1 1 1 4; -fx-padding: 25;">
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <Label text="📝" style="-fx-font-size: 16px;"/>
                            <Label text="Notes générales" textFill="#1a4a5f" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
                        </HBox>
                        <VBox spacing="8">
                            <Label text="Notes générales" textFill="#475569" style="-fx-font-weight: bold; -fx-font-size: 14px;"/>
                            <TextArea fx:id="notesField" promptText="Décrivez l'état du patient, les observations, les recommandations..." wrapText="true" prefHeight="150" style="-fx-background-color: white; -fx-border-color: #CBD5E1; -fx-border-radius: 6; -fx-padding: 4; -fx-font-size: 14px;"/>
                        </VBox>
                    </VBox>

                    <HBox spacing="15" alignment="CENTER_RIGHT" style="-fx-padding: 10 0 20 0;">
                        <Button text="Annuler" onAction="#handleCancel" style="-fx-background-color: white; -fx-text-fill: #64748B; -fx-border-color: #CBD5E1; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 10 24; -fx-cursor: hand; -fx-font-weight: bold; -fx-font-size: 14px;"/>
                        <Button text="Enregistrer le dossier" onAction="#handleSave" style="-fx-background-color: #1a4a5f; -fx-text-fill: white; -fx-background-radius: 6; -fx-padding: 10 24; -fx-cursor: hand; -fx-font-weight: bold; -fx-font-size: 14px;"/>
                    </HBox>

                </VBox>
            </ScrollPane>
        </VBox>
    </center>
</BorderPane>