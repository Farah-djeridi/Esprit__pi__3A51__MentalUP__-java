<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/22" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="Controller.ReservationAdminController"
            style="-fx-background-color: #f5f7fa;">

    <!-- Sidebar Dark (même que GestionActivite) -->
    <left>
        <VBox style="-fx-background-color: #2d3748; -fx-pref-width: 260;">
            <padding><Insets top="20" right="0" bottom="20" left="0"/></padding>

            <HBox alignment="CENTER_LEFT" spacing="12" style="-fx-padding: 20;">
                <Label text="🧠" style="-fx-font-size: 32px;"/>
                <VBox spacing="2">
                    <Label text="MentalUp Admin" style="-fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold;"/>
                    <Label text="Espace d'administration" style="-fx-text-fill: #a0aec0; -fx-font-size: 11px;"/>
                </VBox>
            </HBox>

            <Region style="-fx-background-color: #4a5568; -fx-pref-height: 1;">
                <VBox.margin><Insets top="10" bottom="10"/></VBox.margin>
            </Region>

            <VBox spacing="2" style="-fx-padding: 10 15;">
                <Button text="🏠  Accueil" alignment="CENTER_LEFT" maxWidth="Infinity"
                        style="-fx-background-color: transparent; -fx-text-fill: #cbd5e0; -fx-font-size: 14px; -fx-padding: 12 15; -fx-background-radius: 8; -fx-cursor: hand;">
                    <VBox.margin><Insets bottom="5"/></VBox.margin>
                </Button>
                <Button text="📊  Suivi Mental" alignment="CENTER_LEFT" maxWidth="Infinity"
                        style="-fx-background-color: transparent; -fx-text-fill: #cbd5e0; -fx-font-size: 14px; -fx-padding: 12 15; -fx-background-radius: 8; -fx-cursor: hand;">
                    <VBox.margin><Insets bottom="5"/></VBox.margin>
                </Button>
                <Button text="💬  Forum" alignment="CENTER_LEFT" maxWidth="Infinity"
                        style="-fx-background-color: transparent; -fx-text-fill: #cbd5e0; -fx-font-size: 14px; -fx-padding: 12 15; -fx-background-radius: 8; -fx-cursor: hand;">
                    <VBox.margin><Insets bottom="5"/></VBox.margin>
                </Button>
                <Button text="📅  Rendez-vous" alignment="CENTER_LEFT" maxWidth="Infinity"
                        style="-fx-background-color: transparent; -fx-text-fill: #cbd5e0; -fx-font-size: 14px; -fx-padding: 12 15; -fx-background-radius: 8; -fx-cursor: hand;">
                    <VBox.margin><Insets bottom="5"/></VBox.margin>
                </Button>
                <Button text="👥  Utilisateurs" alignment="CENTER_LEFT" maxWidth="Infinity"
                        style="-fx-background-color: transparent; -fx-text-fill: #cbd5e0; -fx-font-size: 14px; -fx-padding: 12 15; -fx-background-radius: 8; -fx-cursor: hand;">
                    <VBox.margin><Insets bottom="5"/></VBox.margin>
                </Button>
                <Button text="⚡  Activités" alignment="CENTER_LEFT" maxWidth="Infinity"
                        onAction="#ouvrirActivites"
                        style="-fx-background-color: transparent; -fx-text-fill: #cbd5e0; -fx-font-size: 14px; -fx-padding: 12 15; -fx-background-radius: 8; -fx-cursor: hand;">
                    <VBox.margin><Insets bottom="5"/></VBox.margin>
                </Button>
                <!-- Réservations SÉLECTIONNÉ -->
                <Button text="🎟  Réservations" alignment="CENTER_LEFT" maxWidth="Infinity"
                        style="-fx-background-color: #4a5568; -fx-text-fill: white; -fx-font-size: 14px; -fx-padding: 12 15; -fx-background-radius: 8; -fx-cursor: hand; -fx-font-weight: bold;">
                    <VBox.margin><Insets bottom="5"/></VBox.margin>
                </Button>
            </VBox>

            <Region VBox.vgrow="ALWAYS"/>

            <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding: 15; -fx-background-color: #1a202c; -fx-background-radius: 10;">
                <VBox.margin><Insets top="10" right="15" bottom="10" left="15"/></VBox.margin>
                <Label text="👤" style="-fx-font-size: 24px; -fx-background-color: #4a5568; -fx-padding: 8; -fx-background-radius: 50%;"/>
                <VBox spacing="2">
                    <Label text="Admin MentalUp" style="-fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold;"/>
                    <Label text="Super Administrateur" style="-fx-text-fill: #a0aec0; -fx-font-size: 10px;"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="⋮" style="-fx-text-fill: #cbd5e0; -fx-font-size: 20px; -fx-cursor: hand;"/>
            </HBox>
        </VBox>
    </left>

    <!-- Main Content -->
    <center>
        <ScrollPane fitToWidth="true"
                    style="-fx-background: #f5f7fa; -fx-background-color: #f5f7fa;">
        <VBox spacing="18" style="-fx-padding: 25; -fx-background-color: #f5f7fa;">

            <!-- Header -->
            <HBox alignment="CENTER_LEFT" spacing="12">
                <Label text="🎟 Gestion des Réservations"
                       style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #2d3748;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="🔔" style="-fx-font-size: 20px; -fx-background-color: white;
                       -fx-padding: 8; -fx-background-radius: 50%; -fx-cursor: hand;
                       -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 5, 0, 0, 2);"/>
            </HBox>

            <!-- Stat Cards -->
            <HBox spacing="16">
                <HBox spacing="14" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS"
                      style="-fx-background-color: white; -fx-background-radius: 12;
                             -fx-padding: 16 20; -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.07),8,0,0,2);">
                    <Label text="☑" style="-fx-font-size: 26px; -fx-text-fill: #4299e1;"/>
                    <VBox spacing="2">
                        <Label fx:id="lblTotal" text="0"
                               style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #2d3748;"/>
                        <Label text="Total réservations" style="-fx-font-size: 11px; -fx-text-fill: #718096;"/>
                    </VBox>
                </HBox>
                <HBox spacing="14" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS"
                      style="-fx-background-color: white; -fx-background-radius: 12;
                             -fx-padding: 16 20; -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.07),8,0,0,2);">
                    <Label text="📅" style="-fx-font-size: 26px;"/>
                    <VBox spacing="2">
                        <Label fx:id="lblAujourdhui" text="0"
                               style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #48bb78;"/>
                        <Label text="Aujourd'hui" style="-fx-font-size: 11px; -fx-text-fill: #718096;"/>
                    </VBox>
                </HBox>
                <HBox spacing="14" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS"
                      style="-fx-background-color: white; -fx-background-radius: 12;
                             -fx-padding: 16 20; -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.07),8,0,0,2);">
                    <Label text="🗓" style="-fx-font-size: 26px;"/>
                    <VBox spacing="2">
                        <Label fx:id="lblSemaine" text="0"
                               style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #ed8936;"/>
                        <Label text="Cette semaine" style="-fx-font-size: 11px; -fx-text-fill: #718096;"/>
                    </VBox>
                </HBox>
            </HBox>

            <!-- Graphiques -->
            <HBox spacing="16">
                <VBox HBox.hgrow="ALWAYS"
                      style="-fx-background-color: white; -fx-background-radius: 12;
                             -fx-padding: 14; -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.07),8,0,0,2);">
                    <Label text="Réservations par activité"
                           style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #4a5568; -fx-padding: 0 0 8 0;"/>
                    <HBox fx:id="chartBarContainer" alignment="BOTTOM_LEFT" spacing="8" prefHeight="140"/>
                </VBox>
                <VBox HBox.hgrow="ALWAYS"
                      style="-fx-background-color: white; -fx-background-radius: 12;
                             -fx-padding: 14; -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.07),8,0,0,2);">
                    <Label text="Répartition par étudiant"
                           style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #4a5568; -fx-padding: 0 0 8 0;"/>
                    <VBox fx:id="chartDonutContainer" alignment="CENTER" prefHeight="140"/>
                </VBox>
            </HBox>

            <!-- Calendrier compact -->
            <VBox style="-fx-background-color: white; -fx-background-radius: 14;
                         -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.08),12,0,0,3);">
                <HBox alignment="CENTER" spacing="20"
                      style="-fx-padding: 14 24; -fx-background-color: white; -fx-background-radius: 14 14 0 0;
                             -fx-border-color: #f0f4f8; -fx-border-width: 0 0 1 0;">
                    <Button fx:id="btnPrevMonth" text="‹" onAction="#moisPrecedent"
                            style="-fx-background-color: #f7fafc; -fx-text-fill: #4a5568; -fx-font-size: 18px;
                                   -fx-pref-width: 32; -fx-pref-height: 32; -fx-background-radius: 8;
                                   -fx-cursor: hand; -fx-border-color: #e2e8f0; -fx-border-width: 1; -fx-border-radius: 8;"/>
                    <Label fx:id="lblMoisAnnee" text="Avril 2026"
                           style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #1a202c;
                                  -fx-pref-width: 180; -fx-alignment: CENTER;"/>
                    <Button fx:id="btnNextMonth" text="›" onAction="#moisSuivant"
                            style="-fx-background-color: #f7fafc; -fx-text-fill: #4a5568; -fx-font-size: 18px;
                                   -fx-pref-width: 32; -fx-pref-height: 32; -fx-background-radius: 8;
                                   -fx-cursor: hand; -fx-border-color: #e2e8f0; -fx-border-width: 1; -fx-border-radius: 8;"/>
                </HBox>
                <GridPane fx:id="calendarGrid" hgap="1" vgap="1"
                          style="-fx-padding: 0; -fx-background-color: #f0f4f8; -fx-background-radius: 0 0 14 14;">
                    <columnConstraints>
                        <ColumnConstraints percentWidth="14.28"/>
                        <ColumnConstraints percentWidth="14.28"/>
                        <ColumnConstraints percentWidth="14.28"/>
                        <ColumnConstraints percentWidth="14.28"/>
                        <ColumnConstraints percentWidth="14.28"/>
                        <ColumnConstraints percentWidth="14.28"/>
                        <ColumnConstraints percentWidth="14.28"/>
                    </columnConstraints>
                </GridPane>
            </VBox>

            <!-- Header liste -->
            <HBox alignment="CENTER_LEFT" spacing="10"
                  style="-fx-background-color: #5a67d8; -fx-background-radius: 10; -fx-padding: 12 20;">
                <Label text="≡ Liste des Réservations"
                       style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                <Label fx:id="lblTotalBadge" text=""
                       style="-fx-background-color: rgba(255,255,255,0.25); -fx-text-fill: white;
                              -fx-font-size: 12px; -fx-padding: 2 10; -fx-background-radius: 10;"/>
            </HBox>

            <!-- Liste réservations (pas de ScrollPane interne — le ScrollPane externe gère tout) -->
            <VBox fx:id="reservationsVBox" spacing="12"
                  style="-fx-padding: 0 0 20 0; -fx-background-color: transparent;"/>

        </VBox>
        </ScrollPane>
    </center>

</BorderPane>
