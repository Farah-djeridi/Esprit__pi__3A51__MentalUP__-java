<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.image.ImageView?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="controllers.ControllerHome"
            prefWidth="1500" prefHeight="920"
            style="-fx-background-color: linear-gradient(to bottom right, #F4F8FF, #E8F0FE);">

    <left>
        <VBox prefWidth="240"
              style="-fx-background-color: linear-gradient(to bottom, #D6E8F7, #2C5F8A);">

            <VBox alignment="CENTER"
                  spacing="8"
                  style="-fx-padding: 22 0 18 0;
                         -fx-border-color: transparent transparent rgba(255,255,255,0.12) transparent;
                         -fx-border-width: 0 0 1 0;">

                <StackPane style="-fx-background-color: rgba(255,255,255,0.18);
                                  -fx-background-radius: 50;
                                  -fx-padding: 10;">
                    <ImageView fx:id="logoImage"
                               fitWidth="72"
                               fitHeight="72"
                               preserveRatio="true"/>
                </StackPane>

                <Label text="MentalUp"
                       style="-fx-text-fill: #123553;
                              -fx-font-size: 18px;
                              -fx-font-weight: bold;"/>

                <Label text="Bien-être étudiant"
                       style="-fx-text-fill: #355f84;
                              -fx-font-size: 12px;
                              -fx-font-weight: 600;"/>
            </VBox>

            <VBox spacing="4" style="-fx-padding: 20 14 0 14;" VBox.vgrow="ALWAYS">

                <HBox alignment="CENTER_LEFT" spacing="12"
                      fx:id="navAccueil"
                      onMouseClicked="#onNavHomeClicked"
                      style="-fx-background-color: #1E4568;
                             -fx-background-radius: 8;
                             -fx-padding: 10 14;
                             -fx-cursor: hand;
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 5, 0, 0, 2);">
                    <Label text="🏠" style="-fx-font-size: 16px; -fx-text-fill: white;"/>
                    <Label text="Accueil"
                           style="-fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="12"
                      fx:id="navSuivi"
                      onMouseClicked="#onNavSuiviClicked"
                      onMouseEntered="#onNavHoverEnter"
                      onMouseExited="#onNavHoverExit"
                      style="-fx-background-color: transparent;
                             -fx-background-radius: 8;
                             -fx-padding: 10 14;
                             -fx-cursor: hand;">
                    <Label text="📈" style="-fx-font-size: 16px; -fx-text-fill: white;"/>
                    <Label text="Suivi"
                           style="-fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: 500;"/>
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="12"
                      fx:id="navObjectifs"
                      onMouseClicked="#onNavObjectifsClicked"
                      onMouseEntered="#onNavHoverEnter"
                      onMouseExited="#onNavHoverExit"
                      style="-fx-background-color: transparent;
                             -fx-background-radius: 8;
                             -fx-padding: 10 14;
                             -fx-cursor: hand;">
                    <Label text="🎯" style="-fx-font-size: 16px; -fx-text-fill: white;"/>
                    <Label text="Objectifs"
                           style="-fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: 500;"/>
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="12"
                      fx:id="navRdv"
                      onMouseClicked="#onNavRdvClicked"
                      onMouseEntered="#onNavHoverEnter"
                      onMouseExited="#onNavHoverExit"
                      style="-fx-background-color: transparent;
                             -fx-background-radius: 8;
                             -fx-padding: 10 14;
                             -fx-cursor: hand;">
                    <Label text="📅" style="-fx-font-size: 16px; -fx-text-fill: white;"/>
                    <Label text="Rendez-vous"
                           style="-fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: 500;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <StackPane style="-fx-background-color: #E74C3C; -fx-background-radius: 10; -fx-padding: 1 6;">
                        <Label fx:id="badgeRdv" text="3"
                               style="-fx-text-fill: white; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                    </StackPane>
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="12"
                      fx:id="navForum"
                      onMouseClicked="#onNavBlogClicked"
                      onMouseEntered="#onNavHoverEnter"
                      onMouseExited="#onNavHoverExit"
                      style="-fx-background-color: transparent;
                             -fx-background-radius: 8;
                             -fx-padding: 10 14;
                             -fx-cursor: hand;">
                    <Label text="💬" style="-fx-font-size: 16px; -fx-text-fill: white;"/>
                    <Label text="Forum"
                           style="-fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: 500;"/>
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="12"
                      fx:id="navActivites"
                      onMouseClicked="#onNavActivitesClicked"
                      onMouseEntered="#onNavHoverEnter"
                      onMouseExited="#onNavHoverExit"
                      style="-fx-background-color: transparent;
                             -fx-background-radius: 8;
                             -fx-padding: 10 14;
                             -fx-cursor: hand;">
                    <Label text="⚡" style="-fx-font-size: 16px; -fx-text-fill: white;"/>
                    <Label text="Activités"
                           style="-fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: 500;"/>
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="12"
                      fx:id="navRessources"
                      onMouseClicked="#onNavRessourcesClicked"
                      onMouseEntered="#onNavHoverEnter"
                      onMouseExited="#onNavHoverExit"
                      style="-fx-background-color: transparent;
                             -fx-background-radius: 8;
                             -fx-padding: 10 14;
                             -fx-cursor: hand;">
                    <Label text="📚" style="-fx-font-size: 16px; -fx-text-fill: white;"/>
                    <Label text="Ressources"
                           style="-fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: 500;"/>
                </HBox>
            </VBox>

            <VBox spacing="6"
                  style="-fx-padding: 16 14 20 14;
                         -fx-border-color: rgba(255,255,255,0.2);
                         -fx-border-width: 1 0 0 0;">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Circle radius="18" style="-fx-fill: rgba(255,255,255,0.25);"/>
                    <Label fx:id="avatarInitials" text="SA"
                           style="-fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-translate-x: -28;"/>
                    <VBox spacing="1">
                        <Label fx:id="labelUserName" text="Sophie Amara"
                               style="-fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold;"/>
                        <Label text="L3 Informatique"
                               style="-fx-text-fill: rgba(255,255,255,0.65); -fx-font-size: 11px; -fx-font-weight: 500;"/>
                    </VBox>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button fx:id="logoutButton" text="⏻" onAction="#onLogout"
                            style="-fx-background-color: rgba(255,255,255,0.15);
                                   -fx-text-fill: white;
                                   -fx-background-radius: 6;
                                   -fx-padding: 5 10;
                                   -fx-cursor: hand;
                                   -fx-font-size: 12px;
                                   -fx-font-weight: bold;"/>
                </HBox>
            </VBox>
        </VBox>
    </left>

    <center>
        <StackPane fx:id="contentArea" style="-fx-background-color: #F4F8FF;">
            <children>

                <VBox fx:id="homeContent"
                      spacing="0"
                      style="-fx-background-color: #F4F8FF;">

                    <HBox alignment="CENTER_LEFT" spacing="12"
                          style="-fx-background-color: rgba(255,255,255,0.95);
                                 -fx-padding: 14 24;
                                 -fx-border-color: transparent transparent rgba(151,187,228,0.2) transparent;
                                 -fx-border-width: 0 0 1 0;">
                        <VBox spacing="2">
                            <Label text="Bonjour, Sophie 👋"
                                   style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2C3E50;"/>
                            <Label fx:id="labelDate" text="mercredi 8 avril 2026"
                                   style="-fx-font-size: 12px; -fx-text-fill: #5A6C7D; -fx-font-weight: 500;"/>
                        </VBox>

                        <Region HBox.hgrow="ALWAYS"/>

                        <StackPane alignment="TOP_RIGHT" pickOnBounds="false">
                            <Button fx:id="notifButton"
                                    text="🔔"
                                    onAction="#onNotifications"
                                    style="-fx-background-color: rgba(151,187,228,0.15);
                                           -fx-text-fill: #2C5F8A;
                                           -fx-padding: 6;
                                           -fx-cursor: hand;
                                           -fx-font-size: 16px;
                                           -fx-border-color: rgba(151,187,228,0.4);
                                           -fx-border-radius: 50;
                                           -fx-border-width: 1;
                                           -fx-min-width: 32;
                                           -fx-min-height: 32;"/>

                            <Label fx:id="notifBadgeLabel"
                                   text="2"
                                   StackPane.alignment="TOP_RIGHT"
                                   translateX="8"
                                   translateY="-8"
                                   style="-fx-background-color: #E74C3C;
                                          -fx-text-fill: white;
                                          -fx-font-size: 10px;
                                          -fx-font-weight: bold;
                                          -fx-background-radius: 999;
                                          -fx-padding: 2 6;"/>
                        </StackPane>
                    </HBox>

                    <VBox spacing="16" style="-fx-padding: 20 24 24 24;" VBox.vgrow="ALWAYS">

                        <HBox fx:id="bannerBox"
                              style="-fx-background-color: linear-gradient(to right, #7BA6C9, #2C5F8A);
                                     -fx-background-radius: 20;
                                     -fx-padding: 35 40;
                                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 15, 0, 0, 5);"
                              alignment="CENTER_LEFT">
                            <VBox spacing="12" HBox.hgrow="ALWAYS">
                                <Label text="✨ Bienvenue sur MentalUp ✨"
                                       style="-fx-text-fill: rgba(255,255,255,0.95); -fx-font-size: 15px; -fx-font-weight: bold;"/>
                                <Label text="Prenez soin de votre santé mentale"
                                       style="-fx-text-fill: white; -fx-font-size: 26px; -fx-font-weight: bold;"/>
                                <Label text="Une plateforme dédiée à votre bien-être avec des outils de suivi,&#10;des ressources et une communauté bienveillante."
                                       style="-fx-text-fill: rgba(255,255,255,0.9); -fx-font-size: 14px; -fx-font-weight: 500;"/>
                                <HBox spacing="12">
                                    <Button fx:id="startButton" text="Commencer l'aventure →" onAction="#onStartSuivi"
                                            style="-fx-background-color: white;
                                                   -fx-text-fill: #2C5F8A;
                                                   -fx-font-weight: bold;
                                                   -fx-font-size: 14px;
                                                   -fx-background-radius: 25;
                                                   -fx-padding: 10 24;
                                                   -fx-cursor: hand;
                                                   -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 5, 0, 0, 2);"/>
                                </HBox>
                            </VBox>
                            <Label text="🌸" style="-fx-font-size: 80px; -fx-opacity: 0.15;"/>
                        </HBox>

                        <HBox spacing="14">
                            <VBox fx:id="card1" spacing="10" HBox.hgrow="ALWAYS"
                                  style="-fx-background-color: white;
                                         -fx-background-radius: 16;
                                         -fx-padding: 22;
                                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 10, 0, 0, 2);
                                         -fx-cursor: hand;"
                                  onMouseEntered="#onCardHoverEnter"
                                  onMouseExited="#onCardHoverExit"
                                  onMouseClicked="#onCardSuiviClicked">
                                <Label text="📊" style="-fx-font-size: 38px;"/>
                                <Label text="Suivi émotionnel"
                                       style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #2C3E50;"/>
                                <Label text="Enregistrez votre humeur quotidienne et visualisez votre progression."
                                       style="-fx-font-size: 13px; -fx-text-fill: #5A6C7D; -fx-wrap-text: true; -fx-font-weight: 500;"/>
                                <Label text="Découvrir →"
                                       style="-fx-font-size: 13px; -fx-text-fill: #2C5F8A; -fx-font-weight: bold;"/>
                            </VBox>

                            <VBox fx:id="card2" spacing="10" HBox.hgrow="ALWAYS"
                                  style="-fx-background-color: white;
                                         -fx-background-radius: 16;
                                         -fx-padding: 22;
                                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 10, 0, 0, 2);
                                         -fx-cursor: hand;"
                                  onMouseEntered="#onCardHoverEnter"
                                  onMouseExited="#onCardHoverExit">
                                <Label text="👥" style="-fx-font-size: 38px;"/>
                                <Label text="Accompagnement"
                                       style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #2C3E50;"/>
                                <Label text="Professionnels à votre écoute et communauté bienveillante."
                                       style="-fx-font-size: 13px; -fx-text-fill: #5A6C7D; -fx-wrap-text: true; -fx-font-weight: 500;"/>
                                <Label text="Découvrir →"
                                       style="-fx-font-size: 13px; -fx-text-fill: #2C5F8A; -fx-font-weight: bold;"/>
                            </VBox>

                            <VBox fx:id="card3" spacing="10" HBox.hgrow="ALWAYS"
                                  style="-fx-background-color: white;
                                         -fx-background-radius: 16;
                                         -fx-padding: 22;
                                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 10, 0, 0, 2);
                                         -fx-cursor: hand;"
                                  onMouseEntered="#onCardHoverEnter"
                                  onMouseExited="#onCardHoverExit">
                                <Label text="📚" style="-fx-font-size: 38px;"/>
                                <Label text="Ressources"
                                       style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #2C3E50;"/>
                                <Label text="Articles, méditations et outils pour votre bien-être."
                                       style="-fx-font-size: 13px; -fx-text-fill: #5A6C7D; -fx-wrap-text: true; -fx-font-weight: 500;"/>
                                <Label text="Découvrir →"
                                       style="-fx-font-size: 13px; -fx-text-fill: #2C5F8A; -fx-font-weight: bold;"/>
                            </VBox>
                        </HBox>

                        <VBox spacing="12"
                              style="-fx-background-color: white;
                                     -fx-background-radius: 16;
                                     -fx-padding: 22 25;
                                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 10, 0, 0, 2);">

                            <Label text="Pourquoi choisir MentalUp ?"
                                   style="-fx-font-size: 17px; -fx-font-weight: bold; -fx-text-fill: #2C3E50;"/>

                            <HBox spacing="25">
                                <VBox fx:id="adv1" spacing="6" HBox.hgrow="ALWAYS" alignment="CENTER"
                                      style="-fx-padding: 10; -fx-background-radius: 12; -fx-cursor: hand;"
                                      onMouseEntered="#onAdvantageHoverEnter"
                                      onMouseExited="#onAdvantageHoverExit">
                                    <Label text="🎯" style="-fx-font-size: 28px;"/>
                                    <Label text="100% Gratuit"
                                           style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #2C3E50;"/>
                                    <Label text="Pour tous les étudiants"
                                           style="-fx-font-size: 12px; -fx-text-fill: #5A6C7D; -fx-font-weight: 500;"/>
                                </VBox>

                                <VBox fx:id="adv2" spacing="6" HBox.hgrow="ALWAYS" alignment="CENTER"
                                      style="-fx-padding: 10; -fx-background-radius: 12; -fx-cursor: hand;"
                                      onMouseEntered="#onAdvantageHoverEnter"
                                      onMouseExited="#onAdvantageHoverExit">
                                    <Label text="🔒" style="-fx-font-size: 28px;"/>
                                    <Label text="Confidentiel"
                                           style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #2C3E50;"/>
                                    <Label text="Données protégées"
                                           style="-fx-font-size: 12px; -fx-text-fill: #5A6C7D; -fx-font-weight: 500;"/>
                                </VBox>

                                <VBox fx:id="adv3" spacing="6" HBox.hgrow="ALWAYS" alignment="CENTER"
                                      style="-fx-padding: 10; -fx-background-radius: 12; -fx-cursor: hand;"
                                      onMouseEntered="#onAdvantageHoverEnter"
                                      onMouseExited="#onAdvantageHoverExit">
                                    <Label text="⏱️" style="-fx-font-size: 28px;"/>
                                    <Label text="Disponible 24/7"
                                           style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #2C3E50;"/>
                                    <Label text="À tout moment"
                                           style="-fx-font-size: 12px; -fx-text-fill: #5A6C7D; -fx-font-weight: 500;"/>
                                </VBox>

                                <VBox fx:id="adv4" spacing="6" HBox.hgrow="ALWAYS" alignment="CENTER"
                                      style="-fx-padding: 10; -fx-background-radius: 12; -fx-cursor: hand;"
                                      onMouseEntered="#onAdvantageHoverEnter"
                                      onMouseExited="#onAdvantageHoverExit">
                                    <Label text="🤝" style="-fx-font-size: 28px;"/>
                                    <Label text="Communauté active"
                                           style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #2C3E50;"/>
                                    <Label text="Entraide et partage"
                                           style="-fx-font-size: 12px; -fx-text-fill: #5A6C7D; -fx-font-weight: 500;"/>
                                </VBox>
                            </HBox>
                        </VBox>

                    </VBox>
                </VBox>

                <VBox fx:id="notifPanel"
                      visible="false"
                      managed="false"
                      mouseTransparent="false"
                      pickOnBounds="false"
                      StackPane.alignment="TOP_RIGHT"
                      translateX="-24"
                      translateY="78"
                      prefWidth="370"
                      minWidth="370"
                      maxWidth="370"
                      prefHeight="360"
                      spacing="10"
                      style="-fx-background-color: white;
                             -fx-background-radius: 18;
                             -fx-border-color: #D6E8F7;
                             -fx-border-radius: 18;
                             -fx-padding: 14;
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.20), 18, 0, 0, 4);">

                    <HBox alignment="CENTER_LEFT">
                        <Label text="Notifications"
                               style="-fx-font-size: 15px;
                                      -fx-font-weight: bold;
                                      -fx-text-fill: #2C3E50;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button text="✕"
                                onAction="#onNotifications"
                                style="-fx-background-color: transparent;
                                       -fx-text-fill: #5A6C7D;
                                       -fx-font-size: 12px;
                                       -fx-font-weight: bold;
                                       -fx-cursor: hand;"/>
                    </HBox>

                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <ComboBox fx:id="notifFilterCombo"
                                  onAction="#onNotifFilterChanged"
                                  prefWidth="180"
                                  style="-fx-background-radius: 10;"/>

                        <Button fx:id="clearAllNotifButton"
                                text="Tout supprimer"
                                onAction="#onClearAllNotifications"
                                style="-fx-background-color: #fff1f1;
                                       -fx-text-fill: #d94b4b;
                                       -fx-font-size: 12px;
                                       -fx-font-weight: bold;
                                       -fx-background-radius: 10;
                                       -fx-cursor: hand;"/>
                    </HBox>

                    <ListView fx:id="notifListView"
                              prefHeight="280"
                              minHeight="280"
                              maxHeight="280"
                              focusTraversable="false"
                              style="-fx-background-color: transparent;
                                     -fx-control-inner-background: transparent;
                                     -fx-background-insets: 0;
                                     -fx-padding: 6;
                                     -fx-border-color: transparent;"/>
                </VBox>

            </children>
        </StackPane>
    </center>
</BorderPane>